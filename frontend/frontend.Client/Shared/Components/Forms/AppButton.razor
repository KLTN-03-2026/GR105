<button @attributes="MergedAttributes" 
        type="@Type"
        disabled="@(Disabled || IsLoading)">
    
    @if (IsLoading)
    {
        <div class="app-btn-spinner-container">
            <span class="app-btn-spinner"></span>
        </div>
    }
    
    <span class="app-btn-content @(IsLoading ? "app-btn-content-hidden" : "")">
        @ChildContent
    </span>
</button>

@code {
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public EventCallback OnClick { get; set; }

    [Parameter]
    public bool IsLoading { get; set; }

    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public string Class { get; set; } = string.Empty;

    [Parameter]
    public string Type { get; set; } = "button";

    private Dictionary<string, object> MergedAttributes
    {
        get
        {
            var attrs = AdditionalAttributes != null 
                ? new Dictionary<string, object>(AdditionalAttributes) 
                : new Dictionary<string, object>();

            // Clean class merging logic
            string baseClass = "app-btn-base";
            if (IsLoading) baseClass += " app-btn-loading";
            
            // Add explicit Class parameter
            if (!string.IsNullOrWhiteSpace(Class))
            {
                baseClass += $" {Class}";
            }

            if (attrs.TryGetValue("class", out var customClass))
            {
                attrs["class"] = $"{baseClass} {customClass}";
            }
            else
            {
                attrs["class"] = baseClass;
            }

            // Clean up capitalized parameters if they accidentally slipped into AdditionalAttributes
            if (attrs.ContainsKey("Class")) attrs.Remove("Class");
            if (attrs.ContainsKey("Type")) attrs.Remove("Type");

            // ONLY bind @onclick if a delegate is actually provided.
            // This prevents "swallowing" form submissions when used as a submit button.
            if (OnClick.HasDelegate)
            {
                attrs["onclick"] = EventCallback.Factory.Create(this, HandleClick);
            }

            return attrs;
        }
    }

    private async Task HandleClick()
    {
        if (!Disabled && !IsLoading && OnClick.HasDelegate)
        {
            await OnClick.InvokeAsync();
        }
    }
}