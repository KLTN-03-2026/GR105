@inherits LayoutComponentBase
@using frontend.Client.Core.State
@inject AuthState AuthState

<div class="flex h-screen bg-gray-50 overflow-hidden font-sans">
    <!-- Sidebar -->
    <aside class="w-64 flex-shrink-0 bg-white border-r border-gray-200 flex flex-col">
        <div class="p-4 border-b border-gray-100">
            <div class="flex items-center gap-2 px-2 py-1">
                <div class="w-8 h-8 bg-blue-600 rounded-lg flex items-center justify-center text-white font-bold">D</div>
                <span class="font-bold text-xl tracking-tight">DocuManage</span>
            </div>
        </div>

        <div class="flex-1 overflow-y-auto">
            @if (AuthState.IsInitialized)
            {
                <WorkspaceNavMenu />
            }
            else
            {
                <div class="p-4 space-y-4">
                    @for (int i = 0; i < 5; i++)
                    {
                        <div class="h-8 bg-gray-100 rounded animate-pulse"></div>
                    }
                </div>
            }
        </div>

        <div class="p-4 border-t border-gray-100">
            <button class="flex items-center gap-3 px-3 py-2 w-full text-left text-gray-600 hover:bg-gray-50 rounded-lg transition-colors">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                </svg>
                <span class="font-medium">Logout</span>
            </button>
        </div>
    </aside>

    <!-- Main area -->
    <div class="flex-1 flex flex-col min-w-0 overflow-hidden">
        <!-- Top Bar -->
        <header class="h-16 bg-white border-b border-gray-200 flex items-center justify-between px-6 flex-shrink-0">
            <DashboardTopBar />
        </header>

        <!-- Page Content -->
        <main class="flex-1 overflow-y-auto p-6">
            <div class="max-w-6xl mx-auto">
                @Body
            </div>
        </main>
    </div>
</div>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !AuthState.IsInitialized)
        {
            await AuthState.InitializeAsync();
            StateHasChanged();
        }
    }
}
