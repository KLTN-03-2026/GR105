@page "/home"
@using frontend.Client.Core.State
@using frontend.Client.Features.Auth.Services
@using frontend.Client.Features.Workspace.Services
@using frontend.Client.Features.Workspace.Models
@using frontend.Client.Shared.Layouts
@inject AuthState AuthState
@inject AuthService AuthService
@inject WorkspaceService WorkspaceService
@inject NavigationManager Navigation
@inject LayoutStateService LayoutState
@layout StandardLayout
@rendermode InteractiveAuto

<div class="home-container">
    <section class="welcome-banner">
        <h1 class="welcome-title">Welcome back, @(AuthState.User?.Username ?? "User")!</h1>
        <p class="welcome-subtitle">Continue where you left off or start something new.</p>
    </section>

    <div class="quick-actions">
        <button class="action-card" @onclick='() => Navigation.NavigateTo("/workspace/create")'>
            <div class="action-icon">➕</div>
            <h3>New Workspace</h3>
            <p>Create a new space for your documents</p>
        </button>
        <button class="action-card" @onclick='() => Navigation.NavigateTo("/workspace")'>
            <div class="action-icon">📁</div>
            <h3>My Workspaces</h3>
            <p>Manage your existing document spaces</p>
        </button>
        <button class="action-card" @onclick='() => Navigation.NavigateTo("/support/feedback")'>
            <div class="action-icon">✉️</div>
            <h3>Feedback</h3>
            <p>Check recent feedback and discussions</p>
        </button>
    </div>

    <section class="recent-section">
        <h2 class="section-title">Recent Workspaces</h2>
        <div class="recent-grid">
            @if (recentWorkspaces == null)
            {
                <div class="status-box">Loading workspaces...</div>
            }
            else if (!recentWorkspaces.Any())
            {
                <div class="empty-state-box">
                    <p>No recent workspaces found.</p>
                    <button class="btn-primary-custom" @onclick='() => Navigation.NavigateTo("/workspace/create")'>＋ Create Your First Workspace</button>
                </div>
            }
            else
            {
                @foreach (var ws in recentWorkspaces.Take(3))
                {
                    <div class="recent-card" @onclick='() => Navigation.NavigateTo($"/workspace/files/{ws.Id}")'>
                        <div class="recent-info">
                            <h4>@ws.Name</h4>
                            <p>Owned by @ws.OwnerName</p>
                        </div>
                        <span class="chevron">›</span>
                    </div>
                }
            }
        </div>
    </section>
</div>

@code {
    private List<WorkspaceResponse>? recentWorkspaces;

    protected override async Task OnInitializedAsync()
    {
        LayoutState.SetPageMetadata("Dashboard", "dashboard");

        await AuthState.InitializeAsync();
        if (!AuthState.IsAuthenticated)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        recentWorkspaces = await WorkspaceService.GetOwnedWorkspacesAsync();
    }
}

<style>
    .home-container {
        padding: 60px;
        max-width: 1200px;
        margin: 0 auto;
    }

    .welcome-banner {
        margin-bottom: 50px;
    }

    .welcome-title {
        font-size: 3rem;
        font-weight: 900;
        color: #111;
        margin-bottom: 10px;
    }

    .welcome-subtitle {
        font-size: 1.2rem;
        color: #666;
    }

    .quick-actions {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 30px;
        margin-bottom: 60px;
    }

    .action-card {
        background: white;
        border: 1px solid #eee;
        border-radius: 20px;
        padding: 40px 30px;
        text-align: left;
        cursor: pointer;
        transition: 0.3s;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    }

    .action-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 20px 50px rgba(0,0,0,0.1);
        border-color: #ddd;
    }

    .action-icon {
        font-size: 2.5rem;
        margin-bottom: 20px;
    }

    .action-card h3 {
        font-size: 1.4rem;
        font-weight: 700;
        margin-bottom: 10px;
        color: #111;
    }

    .action-card p {
        color: #777;
        line-height: 1.5;
    }

    .recent-section {
        background: white;
        border-radius: 24px;
        padding: 40px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.03);
    }

    .section-title {
        font-size: 1.8rem;
        font-weight: 800;
        margin-bottom: 30px;
    }

    .recent-grid {
        display: flex;
        flex-direction: column;
        gap: 15px;
    }

    .recent-card {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 20px 25px;
        border: 1px solid #eee;
        border-radius: 15px;
        cursor: pointer;
        transition: 0.2s;
    }

    .recent-card:hover {
        background: #fafafa;
        border-color: #ddd;
    }

    .recent-info h4 {
        margin: 0;
        font-size: 1.1rem;
        font-weight: 700;
    }

    .recent-info p {
        margin: 5px 0 0;
        color: #888;
        font-size: 0.9rem;
    }

    .chevron {
        font-size: 1.5rem;
        color: #ccc;
    }
</style>
