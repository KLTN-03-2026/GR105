@page "/workspace/documents/read/{WorkspaceId:guid}/{FileId:guid}"
@using frontend.Client.Shared.Layouts
@using frontend.Client.Core.State
@using frontend.Client.Features.Workspace.Services
@using frontend.Client.Features.Workspace.Models
@inject FileService FileService
@inject WorkspaceService WorkspaceService
@inject AuthState AuthState
@inject NavigationManager Navigation
@inject LayoutStateService LayoutState
@layout WorkspaceLayout
@rendermode InteractiveAuto

<div class="workspace-page-content">
    <!-- ACTION BAR -->
    <section class="ws-action-bar">
        <div class="ws-breadcrumb">
            <span class="crumb-link" @onclick='() => Navigation.NavigateTo("/workspace")'>Workspaces</span>
            <span class="crumb-sep">/</span>
            <span class="crumb-link" @onclick='() => Navigation.NavigateTo($"/workspace/files/{WorkspaceId}")'>Documents</span>
            <span class="crumb-sep">/</span>
            <span class="crumb-current">Viewer</span>
        </div>
        <div class="ws-actions">
            <button class="ws-btn-outline" @onclick='() => Navigation.NavigateTo($"/workspace/versioning/{WorkspaceId}/{FileId}")'>View History</button>
            <button class="ws-btn-primary">Download</button>
        </div>
    </section>

    <!-- VIEWER AREA -->
    <div class="viewer-container">
        <div class="document-paper">
            @if (file == null)
            {
                <div class="viewer-loading">Loading content...</div>
            }
            else
            {
                <h1 class="doc-title">@file.Title</h1>
                <div class="doc-meta">
                    <span>Owner: @file.OwnerName</span> • 
                    <span>Last Updated: @file.UpdatedAt.ToLongDateString()</span>
                </div>
                <hr class="doc-divider" />
                <div class="doc-content">
                    <p>Document content would be rendered here via a specialized viewer or editor component.</p>
                    <div class="content-placeholder">
                        <div class="p-line"></div>
                        <div class="p-line"></div>
                        <div class="p-line mid"></div>
                        <div class="p-line"></div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public Guid WorkspaceId { get; set; }
    [Parameter] public Guid FileId { get; set; }
    private FileResponse? file;

    protected override async Task OnInitializedAsync()
    {
        var workspace = await WorkspaceService.GetWorkspaceByIdAsync(WorkspaceId);
        bool isOwner = workspace?.OwnerUserId == AuthState.User?.Id;
        LayoutState.SetWorkspaceMetadata("Document Viewer", "documents", WorkspaceId, isOwner);

        if (FileId != Guid.Empty)
        {
            file = await FileService.GetFileByIdAsync(FileId);
        }
    }
}

<style>
    .workspace-page-content { background: #f8f9fa; min-height: calc(100vh - 120px); }

    /* Standardized Action Bar */
    .ws-action-bar { padding: 25px 40px; display: flex; justify-content: space-between; align-items: center; background: white; border-bottom: 1px solid #eee; }
    .ws-breadcrumb { display: flex; align-items: center; gap: 12px; font-size: 0.95rem; }
    .crumb-link { color: #888; cursor: pointer; transition: 0.2s; }
    .crumb-link:hover { color: black; text-decoration: underline; }
    .crumb-sep { color: #ddd; }
    .crumb-current { font-weight: 700; color: #111; }
    .ws-actions { display: flex; gap: 12px; }
    .ws-btn-primary { background: black; color: white; border: none; padding: 10px 24px; border-radius: 10px; font-weight: 600; cursor: pointer; }
    .ws-btn-outline { background: white; color: black; border: 2px solid #000; padding: 8px 24px; border-radius: 10px; font-weight: 700; cursor: pointer; }

    /* Viewer Styles */
    .viewer-container { padding: 50px; display: flex; justify-content: center; }
    .document-paper { background: white; width: 100%; max-width: 900px; padding: 60px 80px; border-radius: 4px; box-shadow: 0 20px 50px rgba(0,0,0,0.05); border: 1.5px solid #eee; min-height: 1000px; }
    .doc-title { font-size: 2.5rem; font-weight: 900; color: #000; margin-bottom: 15px; }
    .doc-meta { color: #888; font-size: 0.9rem; margin-bottom: 30px; }
    .doc-divider { border: none; border-top: 2px solid #000; margin-bottom: 40px; opacity: 0.1; }
    .doc-content { line-height: 1.8; color: #333; font-size: 1.1rem; }
    .viewer-loading { text-align: center; padding: 100px; color: #888; font-style: italic; }

    .content-placeholder { margin-top: 40px; display: flex; flex-direction: column; gap: 15px; }
    .p-line { height: 12px; background: #f0f0f0; border-radius: 6px; width: 100%; }
    .p-line.mid { width: 70%; }
</style>
