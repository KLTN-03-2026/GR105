@page "/workspace/documents/upload/{WorkspaceId:guid}"
@using frontend.Client.Shared.Layouts
@using frontend.Client.Core.State
@using frontend.Client.Features.Workspace.Services
@using frontend.Client.Features.Workspace.Models
@inject WorkspaceService WorkspaceService
@inject AuthState AuthState
@inject NavigationManager Navigation
@inject LayoutStateService LayoutState
@layout WorkspaceLayout
@rendermode InteractiveAuto

<div class="workspace-page-content">
    <!-- ACTION BAR -->
    <section class="ws-action-bar">
        <div class="ws-breadcrumb">
            <span class="crumb-link" @onclick='() => Navigation.NavigateTo("/workspace")'>Workspaces</span>
            <span class="crumb-sep">/</span>
            <span class="crumb-link" @onclick='() => Navigation.NavigateTo($"/workspace/files/{WorkspaceId}")'>Documents</span>
            <span class="crumb-sep">/</span>
            <span class="crumb-current">Upload</span>
        </div>
    </section>

    <!-- UPLOAD AREA -->
    <div class="upload-container">
        <div class="upload-card">
            <h2 class="upload-title">Upload New Document</h2>
            <p class="upload-subtitle">Select a file from your computer to add to this workspace</p>

            <div class="drop-zone">
                <div class="drop-icon">☁️</div>
                <p class="drop-text">Drag and drop files here or <strong>browse</strong></p>
                <input type="file" class="file-input-hidden" />
            </div>

            <div class="upload-options">
                <div class="form-group">
                    <label>Document Title</label>
                    <input type="text" class="custom-input" placeholder="Enter custom title (optional)" />
                </div>
                <div class="form-group">
                    <label>Description</label>
                    <textarea class="custom-textarea" placeholder="Add a short description..."></textarea>
                </div>
            </div>

            <div class="action-footer">
                <button class="ws-btn-secondary" @onclick='() => Navigation.NavigateTo($"/workspace/files/{WorkspaceId}")'>Cancel</button>
                <button class="ws-btn-primary">Start Upload</button>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public Guid WorkspaceId { get; set; }

    protected override async Task OnInitializedAsync()
    {
        var workspace = await WorkspaceService.GetWorkspaceByIdAsync(WorkspaceId);
        bool isOwner = workspace?.OwnerUserId == AuthState.User?.Id;
        LayoutState.SetWorkspaceMetadata("Upload Document", "documents", WorkspaceId, isOwner);
    }
}

<style>
    .workspace-page-content { background: #f8f9fa; min-height: calc(100vh - 120px); }

    /* Standardized Action Bar */
    .ws-action-bar { padding: 25px 40px; display: flex; justify-content: space-between; align-items: center; background: white; border-bottom: 1px solid #eee; }
    .ws-breadcrumb { display: flex; align-items: center; gap: 12px; font-size: 0.95rem; }
    .crumb-link { color: #888; cursor: pointer; transition: 0.2s; }
    .crumb-link:hover { color: black; text-decoration: underline; }
    .crumb-sep { color: #ddd; }
    .crumb-current { font-weight: 700; color: #111; }

    /* Upload Styles */
    .upload-container { padding: 60px; display: flex; justify-content: center; }
    .upload-card { background: white; width: 100%; max-width: 700px; padding: 50px; border-radius: 24px; border: 3px solid #000; box-shadow: 12px 12px 0px #000; }
    .upload-title { font-size: 1.8rem; font-weight: 900; margin-bottom: 10px; }
    .upload-subtitle { color: #666; margin-bottom: 35px; }

    .drop-zone { border: 2.5px dashed #ccc; border-radius: 16px; padding: 40px; text-align: center; margin-bottom: 30px; transition: 0.2s; cursor: pointer; position: relative; }
    .drop-zone:hover { border-color: #000; background: #fafafa; }
    .drop-icon { font-size: 3rem; margin-bottom: 15px; }
    .drop-text { color: #444; }
    .file-input-hidden { position: absolute; inset: 0; opacity: 0; cursor: pointer; }

    .upload-options { display: flex; flex-direction: column; gap: 20px; margin-bottom: 40px; }
    .form-group label { display: block; font-weight: 700; margin-bottom: 8px; font-size: 0.95rem; }
    .custom-input, .custom-textarea { width: 100%; border: 1.5px solid #eee; border-radius: 12px; padding: 12px 18px; font-size: 1rem; outline: none; }
    .custom-textarea { height: 100px; resize: none; }
    .custom-input:focus, .custom-textarea:focus { border-color: #000; }

    .action-footer { display: flex; justify-content: flex-end; gap: 15px; }
    .ws-btn-primary { background: black; color: white; border: none; padding: 12px 30px; border-radius: 12px; font-weight: 700; cursor: pointer; }
    .ws-btn-secondary { background: transparent; color: #666; border: none; padding: 12px 25px; font-weight: 700; cursor: pointer; }
</style>
