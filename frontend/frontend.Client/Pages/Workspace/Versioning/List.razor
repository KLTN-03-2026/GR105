@page "/workspace/versioning/{WorkspaceId:guid}/{FileId:guid}"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "user")]
@using frontend.Client.Features.Workspace.Services
@using frontend.Client.Features.Workspace.Models
@using frontend.Client.Shared.Layouts
@using frontend.Client.Core.State
@inject FileService FileService
@inject WorkspaceService WorkspaceService
@inject AuthState AuthState
@inject NavigationManager Navigation
@inject LayoutStateService LayoutState
@layout WorkspaceLayout
@rendermode InteractiveAuto

<div class="workspace-page-content">
    <!-- ACTION BAR -->
    <section class="ws-action-bar">
        <div class="ws-breadcrumb">
            <span class="crumb-link" @onclick='() => Navigation.NavigateTo("/workspace")'>Workspaces</span>
            <span class="crumb-sep">/</span>
            <span class="crumb-link" @onclick='() => Navigation.NavigateTo($"/workspace/files/{WorkspaceId}")'>Documents</span>
            <span class="crumb-sep">/</span>
            <span class="crumb-current">Versioning</span>
        </div>
        <div class="ws-actions">
            <button class="ws-btn-primary">New version</button>
        </div>
    </section>

    <!-- CONTENT AREA -->
    <div class="ws-version-container">
        <div class="ws-version-controls">
            <div class="ws-toggle-group">
                <button class="ws-toggle-btn active">Version</button>
                <button class="ws-toggle-btn">Tags</button>
            </div>
            <div class="ws-search-wrapper">
                <input type="text" placeholder="Search versions..." />
                <button class="ws-search-icon">🔍</button>
            </div>
        </div>

        <div class="ws-version-list">
            @if (versions == null)
            {
                <div class="ws-loading">Loading versions...</div>
            }
            else if (!versions.Any())
            {
                <div class="ws-empty">No versions found for this file.</div>
            }
            else
            {
                @foreach (var v in versions)
                {
                    <div class="ws-version-row">
                        <div class="ws-version-meta">
                            <div class="ws-meta-item">👤 @v.CreatedBy</div>
                            <div class="ws-meta-item">🏷️ Tags</div>
                            <div class="ws-meta-date">@v.CreatedAt.ToShortDateString()</div>
                        </div>

                        <div class="ws-version-card">
                            <div class="ws-card-header">
                                <div class="ws-header-info">
                                    <h3>Version @v.VersionNumber</h3>
                                    <p>Size: @(v.FileSize / 1024) KB</p>
                                </div>
                                <div class="ws-header-actions">
                                    <button class="ws-card-btn">✏️</button>
                                    <button class="ws-card-btn">🗑️</button>
                                </div>
                            </div>
                            <div class="ws-card-body">
                                <div class="ws-checksum">
                                    <span class="ws-checksum-label">Checksum:</span>
                                    <code class="ws-checksum-value">@v.Checksum</code>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public Guid WorkspaceId { get; set; }
    [Parameter] public Guid FileId { get; set; }
    private List<VersionResponse>? versions;
    private WorkspaceResponse? workspace;

    protected override async Task OnInitializedAsync()
    {
        workspace = await WorkspaceService.GetWorkspaceByIdAsync(WorkspaceId);
        bool isOwner = workspace?.OwnerUserId == AuthState.User?.Id;

        LayoutState.SetWorkspaceMetadata("Versioning", "versioning", WorkspaceId, isOwner);

        if (FileId != Guid.Empty)
        {
            versions = await FileService.GetFileVersionsAsync(FileId);
        }
    }
}

