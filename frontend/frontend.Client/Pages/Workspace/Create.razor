@page "/workspace/create"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "user")]
@using frontend.Client.Core.State
@using frontend.Client.Features.Auth.Services
@using frontend.Client.Features.Workspace.Services
@using frontend.Client.Features.Workspace.Models
@using frontend.Client.Shared.Layouts
@using frontend.Client.Shared.Components.Forms
@inject AuthState AuthState
@inject AuthService AuthService
@inject WorkspaceService WorkspaceService
@inject NavigationManager Navigation
@inject LayoutStateService LayoutState
@layout StandardLayout
@rendermode InteractiveAuto

<div class="stepper-viewport">
    <div class="create-ws-card">
        <h1 class="form-main-title">Create Workspace</h1>

        <div class="stepper-container">
            @* STEP 1 *@
            <div class="step-item">
                <div class="step-line-wrapper">
                    <div class="step-number">1</div>
                    <div class="vertical-line"></div>
                </div>
                <div class="step-content">
                    <h2 class="step-title">General</h2>
                    <EditForm Model="@_request" OnValidSubmit="HandleCreate" FormName="createWorkspaceForm">
                        <DataAnnotationsValidator />
                        <div class="input-group">
                            <AppInput @bind-Value="_request.Name" 
                                      Label="Workspace Name" 
                                      placeholder="E.g. My Awesome Team" 
                                      ValidationFor="@(() => _request.Name)" />
                            <span class="input-hint">*Workspace name must be unique</span>
                        </div>
                        @if (!string.IsNullOrEmpty(_errorMessage))
                        {
                            <div class="alert alert-danger">@_errorMessage</div>
                        }

                        @* STEP 2 *@
                        <div class="step-item" style="margin-top: 40px;">
                            <div class="step-line-wrapper">
                                <div class="step-number">2</div>
                            </div>
                            <div class="step-content" style="padding-bottom: 0;">
                                <AppButton Type="submit" 
                                           Class="px-5 py-3" 
                                           IsLoading="@_isSubmitting"
                                           style="font-size: 1.2rem; font-weight: 800;">
                                    Create Now
                                </AppButton>
                            </div>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private CreateWorkspaceRequest _request = new();
    private bool _isSubmitting;
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        LayoutState.SetPageMetadata("Create Workspace", "workspaces");

        await AuthState.InitializeAsync();
        if (!AuthState.IsAuthenticated)
        {
            Navigation.NavigateTo("/login");
        }
    }

    private async Task HandleCreate()
    {
        if (string.IsNullOrWhiteSpace(_request.Name))
        {
            _errorMessage = "Workspace name is required";
            return;
        }

        _isSubmitting = true;
        _errorMessage = null;

        var result = await WorkspaceService.CreateWorkspaceAsync(_request);
        if (result != null)
        {
            Navigation.NavigateTo("/workspace");
        }
        else
        {
            _errorMessage = "Failed to create workspace. Please try again.";
        }

        _isSubmitting = false;
    }
}

<style>
    .stepper-viewport {
        padding: 60px;
        display: flex;
        justify-content: center;
        background: #f5f5f5;
        min-height: calc(100vh - 65px);
    }

    .create-ws-card {
        background: white;
        padding: 50px;
        border-radius: 20px;
        border: 3.5px solid #000;
        box-shadow: 12px 12px 0px #000;
        max-width: 650px;
        width: 100%;
    }

    .form-main-title {
        font-size: 2.2rem;
        font-weight: 900;
        margin-bottom: 40px;
        color: #000;
        text-transform: uppercase;
    }

    .stepper-container {
        display: flex;
        flex-direction: column;
    }

    .step-item {
        display: flex;
        gap: 25px;
    }

    .step-line-wrapper {
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .step-number {
        width: 45px;
        height: 45px;
        background: #000;
        color: #fff;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 900;
        font-size: 1.2rem;
        z-index: 2;
    }

    .vertical-line {
        width: 3px;
        background: #000;
        flex-grow: 1;
        margin: 10px 0;
    }

    .step-content {
        flex: 1;
        padding-bottom: 50px;
    }

    .step-title {
        font-size: 1.5rem;
        font-weight: 800;
        margin-bottom: 20px;
        color: #000;
    }

    .input-group {
        margin-bottom: 15px;
    }

    .input-label {
        display: block;
        font-weight: 700;
        margin-bottom: 10px;
        font-size: 1rem;
    }

    .form-control-ws {
        width: 100%;
        padding: 15px 20px;
        border: 2px solid #000;
        border-radius: 12px;
        font-size: 1.1rem;
        outline: none;
        transition: 0.2s;
    }

    .form-control-ws:focus {
        box-shadow: 4px 4px 0 rgba(0,0,0,0.1);
    }

    .input-hint {
        font-size: 0.85rem;
        color: #666;
        margin-top: 8px;
        display: block;
    }

    .btn-create-final {
        background: #000;
        color: #fff;
        border: none;
        padding: 15px 40px;
        border-radius: 12px;
        font-size: 1.2rem;
        font-weight: 800;
        cursor: pointer;
        transition: transform 0.15s;
    }

    .btn-create-final:hover:not(:disabled) {
        transform: scale(1.02);
    }

    .btn-create-final:disabled {
        background: #888;
        cursor: not-allowed;
    }

    .alert-danger {
        color: #d11a2a;
        font-weight: 700;
        margin-top: 15px;
    }
</style>
