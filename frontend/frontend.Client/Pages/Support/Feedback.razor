@page "/support/feedback"
@using frontend.Client.Features.Support.Services
@using frontend.Client.Features.Support.Models
@using frontend.Client.Shared.Layouts
@using frontend.Client.Core.State
@inject FeedbackService FeedbackService
@inject NavigationManager Navigation
@inject LayoutStateService LayoutState
@layout StandardLayout
@rendermode InteractiveAuto

<div class="feedback-page-wrapper">
    <div class="cabinet-frame">
        <div class="feedback-paper-sheet">
            <div class="sheet-top-nav">
                <div class="custom-dropdown">
                    <select>
                        <option>Assigned to ▼</option>
                    </select>
                </div>
                <button class="new-feedback-action">
                    <i class="mail-icon">✉</i> New feedback
                </button>
            </div>

            <div class="feedback-results-box">
                <div class="results-title-bar">@(_feedbacks?.Count ?? 0) results</div>

                <div class="scroll-wrapper">
                    <div class="feedback-items-list">
                        @if (_feedbacks == null)
                        {
                            <p style="padding: 20px;">Loading feedbacks...</p>
                        }
                        else if (!_feedbacks.Any())
                        {
                            <p style="padding: 20px;">No feedback found.</p>
                        }
                        else
                        {
                            @foreach (var f in _feedbacks)
                            {
                                <div class="feedback-entry" @onclick='() => Navigation.NavigateTo("/feedback-read")' style="cursor: pointer;">
                                    <div class="entry-main">
                                        <span class="entry-title">@f.Content</span>
                                        <span class="entry-sub">@f.UserName - Updated @f.CreatedAt.ToShortDateString()</span>
                                    </div>
                                    <div class="entry-avatar">👤</div>
                                </div>
                            }
                        }
                    </div>

                    <div class="side-scrollbar-track">
                        <div class="side-scrollbar-thumb">
                            <div class="thumb-grip"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="cabinet-footer-logo">
            <div class="full-logo-display">Logo</div>
        </div>
    </div>
</div>

@code {
    private List<FeedbackResponse>? _feedbacks;

    protected override async Task OnInitializedAsync()
    {
        LayoutState.SetPageMetadata("Feedback", "feedback");
        _feedbacks = await FeedbackService.GetFeedbacksAsync();
    }
}

<style>
    :root {
        --accent-blue: #00aaff;
    }

    .feedback-page-wrapper {
        flex: 1;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 100px 20px 40px;
        background: #f5f5f5;
        min-height: calc(100vh - 65px);
    }

    .cabinet-frame {
        width: 720px;
        height: 450px;
        background: #4a4a4a;
        border: 4px solid #1a1a1a;
        border-radius: 12px;
        position: relative;
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
        box-shadow: 0 40px 60px rgba(0,0,0,0.25);
    }

    .feedback-paper-sheet {
        position: absolute;
        top: -80px;
        left: 50%;
        transform: translateX(-50%);
        width: 90%;
        background: #fff;
        border: 3px solid #1a1a1a;
        border-radius: 15px;
        padding: 20px;
        z-index: 10;
    }

    .sheet-top-nav {
        display: flex;
        justify-content: space-between;
        margin-bottom: 15px;
    }

    .new-feedback-action {
        background: #1a1a1a;
        color: white;
        border: none;
        padding: 8px 15px;
        border-radius: 6px;
        cursor: pointer;
        font-weight: 600;
    }

    .feedback-results-box {
        border: 2px solid #1a1a1a;
        border-radius: 8px;
        overflow: hidden;
    }

    .results-title-bar {
        background: #1a1a1a;
        color: white;
        padding: 10px 15px;
        font-weight: bold;
        font-size: 0.9rem;
    }

    .scroll-wrapper {
        display: flex;
        height: 280px;
        position: relative;
    }

    .feedback-items-list {
        flex: 1;
        overflow-y: auto;
        scrollbar-width: none;
    }

    .feedback-items-list::-webkit-scrollbar {
        display: none;
    }

    .feedback-entry {
        display: flex;
        justify-content: space-between;
        padding: 15px 20px;
        border-bottom: 1px solid #eee;
        align-items: center;
        transition: 0.2s;
    }

    .feedback-entry:hover {
        background: #f9f9f9;
    }

    .entry-main {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .entry-title {
        font-weight: 700;
        color: #111;
    }

    .entry-sub {
        font-size: 0.8rem;
        color: #777;
    }

    .entry-avatar {
        width: 35px;
        height: 35px;
        background: #eee;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
    }

    .side-scrollbar-track {
        width: 40px;
        background: #e0e0e0;
        border-left: 2px solid #1a1a1a;
        position: relative;
    }

    .side-scrollbar-thumb {
        width: 28px;
        min-height: 40px;
        background: #1a1a1a;
        border-radius: 20px;
        position: absolute;
        left: 50%;
        transform: translateX(-50%);
        top: 0;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .thumb-grip {
        width: 12px;
        height: 2px;
        background: #444;
        box-shadow: 0 4px 0 #444, 0 -4px 0 #444;
    }

    .cabinet-footer-logo {
        padding: 20px;
        display: flex;
        justify-content: flex-end;
    }

    .full-logo-display {
        width: 100px;
        height: 70px;
        border: 3px solid var(--accent-blue);
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        color: var(--accent-blue);
        border-radius: 8px;
    }
</style>
