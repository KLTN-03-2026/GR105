@page "/settings/appearance"
@using frontend.Client.Shared.Layouts
@using frontend.Client.Core.State
@inject NavigationManager Navigation
@inject LayoutStateService LayoutState
@layout SettingsLayout
@rendermode InteractiveAuto

<div class="page-header">
    <h1 class="page-title">Appearance</h1>
    <button class="btn-personal-profile">Personal profile</button>
</div>

<div class="appearance-body">

    <div class="theme-grid">

        <!-- DARK THEME -->
        <div class="theme-card dark-mode">
            <div class="theme-info">
                <div class="theme-label">
                    <span class="theme-icon">🌙</span>
                    <span class="theme-name">Dark Theme</span>
                </div>

                <button class="btn-theme-action">
                    Change
                </button>
            </div>

            <div class="mockup-container">
                <div class="mockup-header"></div>

                <div class="mockup-main">
                    <div class="mockup-sidebar"></div>

                    <div class="mockup-content">
                        <div class="mockup-bar short"></div>
                        <div class="mockup-bar long"></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- LIGHT THEME -->
        <div class="theme-card light-mode active">
            <div class="theme-info">
                <div class="theme-label">
                    <span class="theme-icon">☀️</span>
                    <span class="theme-name">Light Theme</span>
                </div>

                <button class="btn-theme-action activated">
                    Activated
                </button>
            </div>

            <div class="mockup-container">
                <div class="mockup-header"></div>

                <div class="mockup-main">
                    <div class="mockup-sidebar"></div>

                    <div class="mockup-content">
                        <div class="mockup-bar short"></div>
                        <div class="mockup-bar long"></div>
                    </div>
                </div>
            </div>
        </div>

    </div>

</div>

@code {
    protected override void OnInitialized()
    {
        LayoutState.SetPageMetadata("Appearance", "appearance");
    }
}

<style>
    /* PAGE SPECIFIC STYLES ONLY */
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 40px 60px 20px;
        border-bottom: 1px solid #ddd;
        margin-bottom: 50px;
    }

    .page-title {
        font-size: 2.3rem;
        font-weight: 800;
        margin: 0;
    }

    .btn-personal-profile {
        background: #111;
        color: white;
        border: none;
        padding: 12px 20px;
        border-radius: 8px;
        cursor: pointer;
    }

    .appearance-body {
        padding: 0 60px 60px;
    }

    .theme-grid {
        display: flex;
        gap: 35px;
        flex-wrap: wrap;
    }

    .theme-card {
        flex: 1;
        min-width: 320px;
        max-width: 470px;
        border-radius: 24px;
        padding: 25px;
        transition: 0.25s;
        border: 2px solid #eee;
    }

    .theme-card:hover {
        transform: translateY(-5px);
    }

    .theme-card.active {
        border-color: black;
    }

    .dark-mode {
        background: #222;
        color: white;
    }

    .light-mode {
        background: #fafafa;
        color: black;
    }

    .theme-info {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 25px;
    }

    .theme-label {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .theme-name {
        font-size: 1.15rem;
        font-weight: 700;
    }

    .btn-theme-action {
        border: none;
        border-radius: 20px;
        padding: 8px 18px;
        font-weight: 700;
        cursor: pointer;
    }

    .dark-mode .btn-theme-action {
        background: white;
        color: black;
    }

    .light-mode .btn-theme-action {
        background: black;
        color: white;
    }

    .btn-theme-action.activated {
        opacity: 0.6;
        cursor: default;
    }

    .mockup-container {
        aspect-ratio: 16/10;
        border-radius: 14px;
        overflow: hidden;
        display: flex;
        flex-direction: column;
    }

    .dark-mode .mockup-container {
        background: #333;
    }

    .light-mode .mockup-container {
        background: white;
        border: 1px solid #eee;
    }

    .mockup-header {
        height: 15%;
        margin: 10px;
        border-radius: 6px;
    }

    .dark-mode .mockup-header,
    .dark-mode .mockup-sidebar,
    .dark-mode .mockup-bar {
        background: #444;
    }

    .light-mode .mockup-header,
    .light-mode .mockup-sidebar,
    .light-mode .mockup-bar {
        background: #eee;
    }

    .mockup-main {
        flex: 1;
        display: flex;
        gap: 10px;
        padding: 0 10px 10px;
    }

    .mockup-sidebar {
        width: 25%;
        border-radius: 6px;
    }

    .mockup-content {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .mockup-bar {
        border-radius: 6px;
    }

    .mockup-bar.short {
        width: 40%;
        height: 20%;
    }

    .mockup-bar.long {
        width: 100%;
        height: 60%;
    }
</style>
