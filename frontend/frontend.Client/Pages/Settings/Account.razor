@page "/settings/account"
@using frontend.Client.Shared.Layouts
@using frontend.Client.Core.State
@using frontend.Client.Shared.Components.Forms
@inject NavigationManager Navigation
@inject LayoutStateService LayoutState
@layout SettingsLayout
@rendermode InteractiveAuto

<div class="page-header">
    <h1 class="page-title">Account</h1>
    <AppButton OnClick='() => Navigation.NavigateTo("/profile")'>Personal profile</AppButton>
</div>

<div class="settings-body">
    <EditForm Model="@_model" FormName="accountSettingsForm">
        <DataAnnotationsValidator />

        <section class="settings-section">
            <h2 class="section-label">Change Username</h2>

            <div class="input-group-stack">
                <AppInput @bind-Value="_model.Username"
                          placeholder="Enter new username"
                          Class="w-100"
                          style="max-width: 500px;" />

                <AppButton OnClick="HandleChangeUsername">
                    Change username
                </AppButton>
            </div>
        </section>

        <section class="settings-section">

            <div class="field-item">
                <h2 class="section-label">Old Password</h2>
                <AppInput @bind-Value="_model.OldPassword" Type="password" Class="w-100" />
            </div>

            <div class="field-item">
                <h2 class="section-label">New Password</h2>
                <AppInput @bind-Value="_model.NewPassword" Type="password" Class="w-100" />
            </div>

            <div class="action-footer">
                <AppButton OnClick="HandleChangePassword">
                    Change password
                </AppButton>

                <p class="auth-hint">
                    You do not have permission to change password,
                    require to change password?
                    <a href="/password-reissue" class="link-action">
                        Password Reissue
                    </a>
                </p>
            </div>
        </section>

        <section class="settings-section danger-zone">
            <h2 class="section-label">Delete Account</h2>

            <p class="auth-hint">
                You do not have permission to delete account
            </p>

            <AppButton OnClick="HandleDeleteAccount">
                Delete Account
            </AppButton>
        </section>
    </EditForm>
</div>

@code {
    private AccountModel _model = new();

    public class AccountModel
    {
        public string Username { get; set; } = string.Empty;
        public string OldPassword { get; set; } = string.Empty;
        public string NewPassword { get; set; } = string.Empty;
    }

    protected override void OnInitialized()
    {
        LayoutState.SetPageMetadata("Account", "account");
    }

    private void HandleChangeUsername() { /* TODO */ }
    private void HandleChangePassword() { /* TODO */ }
    private void HandleDeleteAccount() { /* TODO */ }
}

