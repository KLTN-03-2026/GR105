@page "/404"
@using frontend.Client.Shared.Layouts
@using frontend.Client.Core.State
@inject NavigationManager Navigation
@inject LayoutStateService LayoutState
@layout StandardLayout
@rendermode InteractiveAuto

<div class="error-page-content">
    <div class="shredder-component">

        <div class="top-paper-feeder">
            <div class="feeder-slot"></div>
        </div>

        <div class="input-paper-container">
            <div class="paper-top-piece">
                <div class="content-wrapper">
                    <h1 class="text-error">ERROR</h1>
                    <h2 class="text-404">404</h2>
                    <div class="decoration-lines">
                        <span class="line-long"></span>
                        <span class="line-long"></span>
                        <span class="line-mid"></span>
                        <span class="line-long"></span>
                    </div>
                </div>
            </div>
        </div>

        <div class="shredder-main-frame">
            <div class="shredder-interface">
                <div class="left-controls">
                    <div class="control-hole"></div>
                    <div class="control-hole"></div>
                    <span class="header-text">WE'RE SORRY.</span>
                </div>

                <div class="right-controls">
                    <div class="led green-glow"></div>
                    <button class="nav-button" @onclick='() => Navigation.NavigateTo("/home")'>
                        <span class="icon-back">↩</span> Dashboard
                    </button>
                    <div class="led red-dim"></div>
                </div>
            </div>

            <div class="message-area">
                <p class="main-msg">It seems like this document was shredded or lost.</p>
                <p class="sub-msg">Maybe you can find it in another place?</p>
            </div>

            <div class="shredder-slot">
                <div class="shredded-strips"></div>
            </div>
        </div>

        <div class="corner-deco-x">✖</div>
    </div>
</div>

@code {
    protected override void OnInitialized()
    {
        LayoutState.SetPageMetadata("Error 404", "error");
    }
}

<style>
    .error-page-content {
        flex: 1;
        display: flex;
        justify-content: center;
        align-items: center;
        background: #fff;
        min-height: calc(100vh - 65px);
        padding-top: 100px;
        padding-bottom: 100px;
    }

    .shredder-component {
        position: relative;
        width: 750px;
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .top-paper-feeder {
        width: 450px;
        height: 160px;
        background-color: #333;
        border-radius: 15px 15px 0 0;
        position: absolute;
        top: 150px;
        z-index: 0;
        display: flex;
        justify-content: center;
    }

    .feeder-slot {
        width: 340px;
        height: 10px;
        background: #000;
        margin-top: 10px;
        border-radius: 5px;
    }

    .input-paper-container {
        perspective: 1000px;
        z-index: 1;
        margin-bottom: -15px;
        position: relative;
    }

    .paper-top-piece {
        width: 380px;
        height: 320px;
        background: #ffffff;
        border: 3px solid #1a1a1a;
        transform: rotateX(10deg);
        padding: 40px 30px;
        text-align: center;
        box-shadow: 0 -5px 15px rgba(0,0,0,0.05);
    }

    .text-error {
        font-size: 70px;
        font-weight: 900;
        line-height: 1;
        margin: 0;
    }

    .text-404 {
        font-size: 75px;
        font-weight: 900;
        border-top: 5px solid #000;
        border-bottom: 5px solid #000;
        display: inline-block;
        padding: 0 15px;
        margin: 5px 0;
    }

    .decoration-lines {
        margin-top: 20px;
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .line-long {
        height: 4px;
        background: #eee;
        width: 100%;
    }

    .line-mid {
        height: 4px;
        background: #eee;
        width: 70%;
    }

    .shredder-main-frame {
        width: 100%;
        background-color: #1a1a1a;
        border-radius: 24px;
        padding: 25px;
        position: relative;
        z-index: 2;
        box-shadow: 0 25px 60px rgba(0,0,0,0.3);
        border: 4px solid #000;
    }

    .shredder-interface {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 40px;
    }

    .left-controls {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .control-hole {
        width: 25px;
        height: 25px;
        border-radius: 50%;
        background: #444;
        border: 2px solid #000;
    }

    .header-text {
        color: #fff;
        font-weight: bold;
        font-size: 16px;
        margin-left: 10px;
    }

    .right-controls {
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .led {
        width: 10px;
        height: 10px;
        border-radius: 50%;
    }

    .green-glow {
        background: #4df06a;
        box-shadow: 0 0 10px #4df06a;
    }

    .red-dim {
        background: #b32d2d;
    }

    .nav-button {
        background: #3d3d3d;
        color: #fff;
        border: 2px solid #000;
        border-radius: 20px;
        padding: 6px 18px;
        font-size: 14px;
        cursor: pointer;
        font-weight: bold;
    }

    .message-area {
        text-align: center;
        color: #e0e0e0;
        padding: 20px 0 60px;
    }

    .main-msg {
        font-size: 24px;
        margin-bottom: 10px;
    }

    .sub-msg {
        font-size: 18px;
        opacity: 0.8;
    }

    .shredder-slot {
        position: absolute;
        bottom: -40px;
        left: 50%;
        transform: translateX(-50%);
        width: 340px;
        height: 120px;
        overflow: hidden;
        background: #000;
    }

    .shredded-strips {
        width: 100%;
        height: 200%;
        background: linear-gradient(to bottom, rgba(0,0,0,0.4) 0px, rgba(0,0,0,0.4) 15px, transparent 15px), repeating-linear-gradient(90deg, #fff, #fff 12px, transparent 12px, transparent 20px);
        background-size: 100% 100%, 20px 100%;
        animation: shredding-motion 2s linear infinite;
    }

    @@keyframes shredding-motion {
        0% { transform: translateY(-50%); }
        100% { transform: translateY(0); }
    }

    .corner-deco-x {
        position: absolute;
        bottom: 15px;
        right: 15px;
        font-size: 120px;
        color: #000;
        font-weight: 900;
        opacity: 0.9;
        pointer-events: none;
    }
</style>
