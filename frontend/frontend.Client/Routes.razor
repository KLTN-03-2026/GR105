@using Microsoft.AspNetCore.Components.Authorization

<CascadingAuthenticationState>
    <Router AppAssembly="typeof(Routes).Assembly" AdditionalAssemblies="new[] { typeof(Client._Imports).Assembly }" NotFoundPage="typeof(Pages.NotFound)">
        <Found Context="routeData">
            <AuthorizeRouteView RouteData="routeData" DefaultLayout="typeof(Shared.Layouts.MainLayout)">
                <NotAuthorized>
                    @if (context.User.Identity?.IsAuthenticated != true)
                    {
                        <RedirectToLogin />
                    }
                    else
                    {
                        <div style="padding: 100px; text-align: center;">
                            <h1 style="font-size: 80px; font-weight: 900;">403</h1>
                            <p style="font-size: 1.5rem; color: #666;">ACCESS DENIED</p>
                            <p>You do not have permission to view this page.</p>
                            <a href="/home" style="display: inline-block; margin-top: 30px; background: #000; color: #fff; padding: 12px 25px; border-radius: 8px; text-decoration: none; font-weight: 600;">Go Home</a>
                        </div>
                    }
                </NotAuthorized>
            </AuthorizeRouteView>
            <FocusOnNavigate RouteData="routeData" Selector="h1" />
        </Found>
    </Router>
</CascadingAuthenticationState>
