@using frontend.Client.Services.Http
@using frontend.Client.Core.Constants
@inject ApiClient ApiClient

<div class="flex flex-col h-full">
    <!-- Header -->
    <div class="p-4 border-b border-gray-200 bg-gray-50/50 flex justify-between items-center">
        <h1 class="text-xl font-semibold text-gray-900">Recent Activity</h1>
        <div class="flex gap-2">
            <button class="px-3 py-1 text-sm font-medium bg-white border border-gray-300 rounded-md shadow-sm hover:bg-gray-50 text-gray-700 focus:outline-none focus:ring-2 focus:ring-blue-500">
                Filter
            </button>
        </div>
    </div>

    <!-- Feed -->
    <div class="flex-1 overflow-y-auto p-4 space-y-6">
        @if (IsLoading)
        {
            <div class="text-sm text-gray-500">Loading activities...</div>
        }
        else if (Activities.Count == 0)
        {
            <div class="text-sm text-gray-500">No recent activity found.</div>
        }
        else
        {
            @foreach (var activity in Activities)
            {
                <div class="flex gap-4">
                    <div class="flex-shrink-0 mt-1">
                        <img src="@activity.UserAvatar" alt="@activity.UserName" class="w-8 h-8 rounded-full border border-gray-200" />
                    </div>
                    <div class="flex-1 pb-6 border-b border-gray-100 last:border-0">
                        <p class="text-sm text-gray-600">
                            <span class="font-semibold text-gray-900">@activity.UserName</span>
                            @activity.ActionText
                            @if (!string.IsNullOrEmpty(activity.TargetName))
                            {
                                <a href="#" class="font-medium text-blue-600 hover:underline">@activity.TargetName</a>
                            }
                        </p>
                        <p class="text-xs text-gray-500 mt-1 flex items-center gap-1">
                            <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                            @activity.Timestamp
                            <span class="mx-1">&bull;</span>
                            <a href="#" class="hover:underline">@activity.WorkspaceName</a>
                        </p>
                        
                        @if (activity.HasCard)
                        {
                            <div class="mt-3 p-3 bg-gray-50 border border-gray-200 rounded-md">
                                <div class="flex items-center gap-2">
                                    <svg class="w-5 h-5 text-gray-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4z" clip-rule="evenodd" /></svg>
                                    <div>
                                        <h4 class="text-sm font-medium text-gray-900">@activity.TargetName</h4>
                                        <p class="text-xs text-gray-500">Version @activity.Version - @activity.Size</p>
                                    </div>
                                </div>
                                @if (!string.IsNullOrEmpty(activity.Comment))
                                {
                                    <p class="mt-2 text-sm text-gray-700 italic">"@activity.Comment"</p>
                                }
                            </div>
                        }
                    </div>
                </div>
            }
        }
    </div>
</div>

@code {
    public class WorkspaceDto
    {
        public Guid Id { get; set; }
        public string Name { get; set; } = "";
    }

    public class ActivityLogResponseDto
    {
        public Guid Id { get; set; }
        public string Action { get; set; } = string.Empty;
        public string? EntityType { get; set; }
        public Guid? EntityId { get; set; }
        public string? EntityName { get; set; }
        public DateTime CreatedAt { get; set; }
        public Guid? UserId { get; set; }
        public string? Username { get; set; }
        public string? WorkspaceName { get; set; }
    }

    public class ActivityDto
    {
        public string Id { get; set; } = "";
        public string UserName { get; set; } = "";
        public string UserAvatar { get; set; } = "";
        public string ActionText { get; set; } = "";
        public string TargetName { get; set; } = "";
        public string WorkspaceName { get; set; } = "";
        public string Timestamp { get; set; } = "";
        public bool HasCard { get; set; }
        public string Version { get; set; } = "";
        public string Size { get; set; } = "";
        public string Comment { get; set; } = "";
    }

    private List<ActivityDto> Activities = new();
    private bool IsLoading = true;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            IsLoading = true;
            // 1. Fetch Workspaces first to get IDs
            var workspaces = await ApiClient.GetAsync<List<WorkspaceDto>>(ApiRoutes.Workspaces);
            
            if (workspaces != null && workspaces.Any())
            {
                // 2. Fetch logs from the first workspace as a default for the global feed
                var firstWorkspace = workspaces.First();
                var logs = await ApiClient.GetAsync<List<ActivityLogResponseDto>>($"api/workspace/{firstWorkspace.Id}/logs?limit=10");
                
                if (logs != null)
                {
                    Activities = logs.Select(log => new ActivityDto
                    {
                        Id = log.Id.ToString(),
                        UserName = log.Username ?? "Unknown User",
                        UserAvatar = $"https://ui-avatars.com/api/?name={log.Username ?? "User"}&background=random",
                        ActionText = log.Action,
                        TargetName = log.EntityName ?? log.EntityType ?? "an item",
                        WorkspaceName = firstWorkspace.Name,
                        Timestamp = log.CreatedAt.ToString("g"),
                        HasCard = false
                    }).ToList();
                }
            }
            
            IsLoading = false;
            StateHasChanged();
        }
    }
}