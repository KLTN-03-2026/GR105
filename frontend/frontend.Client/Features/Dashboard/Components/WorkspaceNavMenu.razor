@using frontend.Client.Services.Http
@using frontend.Client.Core.Constants
@using frontend.Client.Core.State
@using System.Text.Json.Serialization
@inject ApiClient ApiClient
@inject AuthState AuthState
@rendermode InteractiveAuto

<div class="px-4 py-2 space-y-6">
    <!-- Main Navigation -->
    <div>
        <h3 class="px-3 text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">Navigation</h3>
        <nav class="space-y-1">
            <a href="/dashboard" class="flex items-center gap-3 px-3 py-2 text-sm font-medium text-blue-600 bg-blue-50 rounded-lg">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                </svg>
                Overview
            </a>
            <a href="/tasks" class="flex items-center gap-3 px-3 py-2 text-sm font-medium text-gray-600 hover:bg-gray-50 rounded-lg transition-colors">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
                </svg>
                Tasks
            </a>
            <a href="/settings" class="flex items-center gap-3 px-3 py-2 text-sm font-medium text-gray-600 hover:bg-gray-50 rounded-lg transition-colors">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                Settings
            </a>
        </nav>
    </div>

    <!-- Workspaces Section -->
    <div>
        <div class="px-3 flex items-center justify-between mb-2">
            <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Workspaces</h3>
            <button class="text-gray-400 hover:text-blue-600">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                </svg>
            </button>
        </div>

        <!-- Search Workspaces -->
        <div class="px-3 mb-3">
            <div class="relative">
                <input type="text"
                       @bind="searchQuery"
                       @bind:event="oninput"
                       class="block w-full pl-8 pr-3 py-1.5 bg-gray-50 border border-gray-200 rounded-lg text-xs focus:ring-1 focus:ring-blue-500 focus:bg-white transition-all"
                       placeholder="Find a workspace...">
                <div class="absolute inset-y-0 left-0 pl-2.5 flex items-center pointer-events-none">
                    <svg class="h-3.5 w-3.5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                    </svg>
                </div>
            </div>
        </div>

        @if (IsLoading)
        {
            <div class="px-3 py-2 space-y-2">
                @for (int i = 0; i < 3; i++)
                {
                    <div class="h-8 bg-gray-50 rounded animate-pulse"></div>
                }
            </div>
        }
        else if (Error != null)
        {
            <div class="px-3 py-2 text-xs text-red-500">@Error</div>
        }
        else if (!Workspaces.Any())
        {
             <div class="px-3 py-2 text-xs text-gray-400">No workspaces found.</div>
        }
        else
        {
            <ul class="space-y-1">
                @foreach (var ws in DisplayedWorkspaces)
                {
                    <li>
                        <a href="/workspace/@ws.Id" class="group flex items-center gap-3 px-3 py-2 text-sm font-medium text-gray-600 hover:bg-blue-50 hover:text-blue-600 rounded-lg transition-all">
                            <div class="w-6 h-6 rounded-md bg-gray-100 group-hover:bg-blue-100 flex items-center justify-center text-[10px] font-bold text-gray-500 group-hover:text-blue-600">
                                @(ws.Name.Length > 0 ? ws.Name[0].ToString().ToUpper() : "W")
                            </div>
                            <span class="truncate flex-1">@ws.Name</span>
                        </a>
                    </li>
                }
            </ul>

            @if (FilteredWorkspaces.Count > 5)
            {
                <button @onclick="ToggleShowAll" class="w-full mt-2 text-left px-3 text-xs font-medium text-gray-400 hover:text-blue-600 transition-colors">
                    @(ShowAll ? "Show less" : $"Show {FilteredWorkspaces.Count - 5} more...")
                </button>
            }
        }
    </div>

    <!-- Favorites Section -->
    <div>
        <h3 class="px-3 text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">Favorites</h3>
        <nav class="space-y-1">
            <a href="#" class="flex items-center gap-3 px-3 py-2 text-sm font-medium text-gray-600 hover:bg-gray-50 rounded-lg">
                <span class="w-2 h-2 rounded-full bg-red-400"></span>
                Personal
            </a>
            <a href="#" class="flex items-center gap-3 px-3 py-2 text-sm font-medium text-gray-600 hover:bg-gray-50 rounded-lg">
                <span class="w-2 h-2 rounded-full bg-green-400"></span>
                Work
            </a>
            <a href="#" class="flex items-center gap-3 px-3 py-2 text-sm font-medium text-gray-600 hover:bg-gray-50 rounded-lg">
                <span class="w-2 h-2 rounded-full bg-blue-400"></span>
                Education
            </a>
        </nav>
    </div>
</div>

@code {
    public class WorkspaceDto
    {
        [JsonPropertyName("id")] public Guid Id { get; set; }
        [JsonPropertyName("name")] public string Name { get; set; } = "";
        [JsonPropertyName("ownerUserId")] public Guid OwnerUserId { get; set; }
        [JsonPropertyName("ownerName")] public string OwnerName { get; set; } = "";
        [JsonPropertyName("createdAt")] public DateTime CreatedAt { get; set; }
    }

    private List<WorkspaceDto> Workspaces = new();
    private bool IsLoading = true;
    private string? Error;
    private string searchQuery = "";
    private bool ShowAll = false;

    private List<WorkspaceDto> FilteredWorkspaces =>
        string.IsNullOrWhiteSpace(searchQuery)
            ? Workspaces
            : Workspaces.Where(w => w.Name.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ||
                                    w.OwnerName.Contains(searchQuery, StringComparison.OrdinalIgnoreCase)).ToList();

    private IEnumerable<WorkspaceDto> DisplayedWorkspaces =>
        ShowAll ? FilteredWorkspaces : FilteredWorkspaces.Take(5);

    private void ToggleShowAll() => ShowAll = !ShowAll;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadWorkspaces();
        }
    }

    private async Task LoadWorkspaces()
    {
        IsLoading = true;
        Error = null;
        StateHasChanged();

        try
        {
            // Ensure AuthState is initialized before fetching (reads from Cookie)
            if (!AuthState.IsInitialized)
            {
                Console.WriteLine("[WorkspaceNavMenu] Initializing AuthState...");
                await AuthState.InitializeAsync();
            }

            Console.WriteLine($"[WorkspaceNavMenu] Fetching workspaces. Authenticated: {AuthState.IsAuthenticated}");

            var response = await ApiClient.GetAsync<List<WorkspaceDto>>("api/workspace"); 
            if (response != null)
            {
                Workspaces = response;
                Console.WriteLine($"[WorkspaceNavMenu] Successfully loaded {Workspaces.Count} workspaces.");
            }
            else
            {
                Error = "Could not retrieve workspaces. Please check your connection.";
                Console.WriteLine("[WorkspaceNavMenu] API returned null response.");
            }
        }
        catch (Exception ex)
        {
            Error = "An error occurred while loading workspaces.";
            Console.WriteLine($"[WorkspaceNavMenu] Exception: {ex.Message}");
        }
        finally
        {
            IsLoading = false;
            StateHasChanged();
        }
    }
}
