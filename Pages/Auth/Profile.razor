@page "/profile-detail"
@inject NavigationManager Navigation
@rendermode InteractiveServer

<div class="app-wrapper">
    @* --- TOPBAR (Đồng bộ hệ thống) --- *@
    <header class="top-navbar">
        <div class="nav-left">
            <button class="menu-toggle" @onclick="ToggleMenu">☰</button>
            <div class="app-logo"></div>
            <span class="nav-title">Username</span>
        </div>
        <div class="nav-center">
            <div class="search-box" @onclick="ToggleSearch">
                <span class="search-icon">🔍</span>
                <input type="text" placeholder="Search anything..." readonly />
            </div>
        </div>
        <div class="nav-right">
            <button class="btn-join" @onclick="ToggleJoin">+ Join</button>
            <button class="icon-btn" @onclick='() => Navigation.NavigateTo("/noti")'>🔔</button>
            <button class="icon-btn" @onclick="ToggleProfile">👤</button>
        </div>
    </header>

    <div class="notebook-viewport">
        @* --- THIẾT KẾ CUỐN SỔ TAY --- *@
        <div class="notebook-container">

            @* TRANG TRÁI (Thông tin cá nhân) *@
            <div class="notebook-page left-page">
                <div class="profile-main-info">
                    <div class="avatar-circle">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                            <path d="M20 21V19C20 17.9391 19.5786 16.9217 18.8284 16.1716C18.0783 15.4214 17.0609 15 16 15H8C6.93913 15 5.92172 15.4214 5.17157 16.1716C4.42143 16.9217 4 17.9391 4 19V21" />
                            <circle cx="12" cy="7" r="4" />
                        </svg>
                    </div>
                    <div class="text-info">
                        <h1 class="display-name">Name</h1>
                        <p class="username-sub">Username</p>
                        <p class="role-tag">Role</p>
                        <button class="btn-edit-profile">Edit Profile</button>
                    </div>
                </div>

                <div class="contribution-section">
                    <h3 class="sub-title">Active contribution</h3>
                    <div class="chart-box">
                        <div class="bar" style="height: 40%"></div>
                        <div class="bar" style="height: 80%"></div>
                        <div class="bar" style="height: 30%"></div>
                        <div class="bar" style="height: 60%"></div>
                        <div class="bar" style="height: 90%"></div>
                        <div class="bar" style="height: 50%"></div>
                        <div class="chart-labels">
                            <span>6m</span><span>1m</span><span>1w</span><span class="active">24h</span>
                        </div>
                    </div>
                </div>

                <div class="log-section">
                    <h3 class="sub-title">Contribution Log</h3>
                    <div class="log-item">Day X - At X:YZ AM | Made contribution</div>
                    <div class="log-item">Day X - At X:YZ AM | Made contribution</div>
                    <button class="btn-show-more">Show more activity</button>
                </div>
            </div>

            @* GÁY SỔ (Spiral Binding) *@
            <div class="notebook-spiral">
                @for (int i = 0; i < 15; i++)
                {
                    <div class="spiral-ring"></div>
                }
            </div>

            @* TRANG PHẢI (Danh sách Workspace) *@
            <div class="notebook-page right-page">
                <div class="workspace-search-header">
                    <div class="ws-search-bar">
                        <input type="text" placeholder="Find a workspace..." />
                    </div>
                    <button class="btn-add-ws">📁 Add</button>
                </div>

                <div class="workspace-scroll-list">
                    @for (int i = 0; i < 4; i++)
                    {
                        <div class="ws-item">
                            <h4 class="ws-name">Workspace Name</h4>
                            <p class="ws-desc">Description</p>
                            <div class="ws-footer">
                                <span class="status">Status: Active</span>
                                <span class="updated">Updated X days ago</span>
                            </div>
                        </div>
                    }
                </div>

                <div class="scroll-indicator">
                    <span>▽</span>
                </div>
            </div>
        </div>
    </div>
</div>

@* --- CÁC THÀNH PHẦN UI PHỤ (Modals & Overlays) --- *@

@if (showMenu)
{
    <div class="drawer-menu">
        <div class="drawer-header">
            <i class="user-large-icon">👤</i>
            <button class="close-drawer" @onclick="ToggleMenu">✕</button>
        </div>
        <nav class="drawer-nav">
            <div class="drawer-nav-item" @onclick='() => Navigation.NavigateTo("/")'>⌂ Dashboard</div>
            <div class="drawer-nav-item">✉ Feedback</div>
            <div class="drawer-nav-item">📞 Contact Us</div>
            <div class="nav-divider"></div>
            <div class="nav-label">Top workspaces</div>
            <div class="nav-search-wrap">
                <input type="text" placeholder="Search workspace..." />
            </div>
            <div class="drawer-nav-item small">👤 Project Alpha</div>
            <div class="drawer-nav-item small">👤 Team Beta</div>
        </nav>
    </div>
    <div class="overlay" @onclick="ToggleMenu"></div>
}

@if (showSearch)
{
    <div class="search-modal">
        <div class="search-modal-bar">
            <span>⌕</span>
            <input type="text" placeholder="Search anything..." autofocus />
            <button @onclick="ToggleSearch">✕</button>
        </div>
    </div>
    <div class="overlay" @onclick="ToggleSearch"></div>
}

@if (showJoin)
{
    <div class="join-dropdown">
        <div class="dropdown-header">
            <span style="font-weight: bold;">Join new workspace</span>
            <button @onclick="ToggleJoin" style="background:none; border:none; color:white; cursor:pointer;">✕</button>
        </div>
        <div class="dropdown-body">
            <div class="input-row-dark">
                <i>👤</i>
                <input type="text" placeholder="Username" />
                <button class="copy-btn">⧉</button>
            </div>
            <div class="tab-row-dark">
                <span class="active">HTTPS</span>
                <span>Users</span>
                <span>Workspace ID</span>
            </div>
            <div class="input-row-dark">
                <input type="text" placeholder="Workspace Link/ID" />
                <button class="copy-btn">⧉</button>
            </div>
            <button class="submit-join-btn">Send request to join workspace</button>
        </div>
    </div>
    <div class="overlay transparent" @onclick="ToggleJoin"></div>
}

@if (showProfile)
{
    <div class="profile-dropdown">
        <div class="profile-user-info">
            <i>👤</i>
            <span>Username</span>
        </div>
        <div class="dropdown-divider"></div>
        <div class="drop-item" @onclick='() => Navigation.NavigateTo("/profile-detail")'>👤 Profile</div>
        <div class="drop-item">📁 Workspaces</div>
        <div class="drop-item">✉ Feedback</div>
        <div class="drop-item">⚙ Settings</div>
        <div class="drop-item logout">↪ Sign out</div>
    </div>
    <div class="overlay transparent" @onclick="ToggleProfile"></div>
}

@code {
    private bool showMenu = false;
    private bool showSearch = false;
    private bool showJoin = false;
    private bool showProfile = false;

    private void ToggleMenu() => showMenu = !showMenu;
    private void ToggleSearch() => showSearch = !showSearch;
    private void ToggleJoin() => showJoin = !showJoin;
    private void ToggleProfile() => showProfile = !showProfile;
}

<style>
    /* --- NỀN TẢNG LAYOUT --- */
    :root {
        --dark-bg: #1a1a1a;
        --header-h: 65px;
    }

    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    .app-wrapper {
        background: #f0f0f0;
        min-height: 100vh;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        display: flex;
        flex-direction: column;
    }

    /* --- TOPBAR --- */
    .top-navbar {
        height: var(--header-h);
        background: var(--dark-bg);
        color: white;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 20px;
        z-index: 100;
        position: relative;
    }

    .nav-left {
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .menu-toggle {
        background: none;
        border: none;
        color: white;
        font-size: 22px;
        cursor: pointer;
    }

    .app-logo {
        width: 32px;
        height: 32px;
        background: #444;
        border-radius: 6px;
    }

    .search-box {
        background: #333;
        border-radius: 8px;
        padding: 8px 15px;
        display: flex;
        align-items: center;
        width: 400px;
        cursor: pointer;
    }

        .search-box input {
            background: transparent;
            border: none;
            color: white;
            width: 100%;
            outline: none;
            margin-left: 10px;
        }

    .nav-right {
        display: flex;
        gap: 15px;
        align-items: center;
    }

    .icon-btn {
        background: none;
        border: none;
        color: white;
        font-size: 20px;
        cursor: pointer;
    }

    .btn-join {
        background: transparent;
        border: 1px solid #555;
        color: white;
        padding: 5px 15px;
        border-radius: 6px;
        cursor: pointer;
    }

    /* --- NOTEBOOK DESIGN --- */
    .notebook-viewport {
        flex: 1;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 20px;
    }

    .notebook-container {
        display: flex;
        background: #555;
        padding: 15px;
        border-radius: 20px;
        box-shadow: 0 20px 50px rgba(0,0,0,0.2);
        position: relative;
        max-width: 1100px;
        width: 100%;
    }

    .notebook-page {
        background: white;
        flex: 1;
        min-height: 600px;
        padding: 30px;
        position: relative;
    }

    .left-page {
        border-radius: 10px 0 0 10px;
    }

    .right-page {
        border-radius: 0 10px 10px 0;
    }

    .notebook-spiral {
        width: 40px;
        background: #444;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: space-around;
        padding: 10px 0;
        z-index: 10;
    }

    .spiral-ring {
        width: 50px;
        height: 12px;
        background: linear-gradient(to bottom, #777, #333, #777);
        border-radius: 10px;
        box-shadow: 2px 2px 5px rgba(0,0,0,0.3);
    }

    /* --- PROFILE CONTENT --- */
    .profile-main-info {
        display: flex;
        gap: 20px;
        margin-bottom: 30px;
    }

    .avatar-circle {
        width: 100px;
        height: 100px;
        border-radius: 50%;
        border: 2px solid #333;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .display-name {
        font-size: 1.8rem;
        font-weight: 800;
        margin: 0;
        color: #1a1a1a;
    }

    .btn-edit-profile {
        background: #1a1a1a;
        color: white;
        border: none;
        padding: 8px 20px;
        border-radius: 6px;
        cursor: pointer;
        margin-top: 10px;
    }

    .sub-title {
        font-size: 1.1rem;
        margin-bottom: 15px;
        font-weight: bold;
    }

    .chart-box {
        border: 1.5px solid #000;
        border-radius: 12px;
        height: 120px;
        display: flex;
        align-items: flex-end;
        justify-content: space-around;
        padding: 15px;
        position: relative;
        margin-bottom: 20px;
    }

    .bar {
        width: 20px;
        background: #222;
        border-radius: 4px 4px 0 0;
    }

    .chart-labels {
        position: absolute;
        bottom: 5px;
        right: 10px;
        display: flex;
        gap: 5px;
        font-size: 0.7rem;
    }

        .chart-labels .active {
            background: #000;
            color: white;
            padding: 2px 4px;
            border-radius: 4px;
        }

    .log-item {
        font-size: 0.85rem;
        margin-bottom: 8px;
        border-left: 2px solid #ddd;
        padding-left: 10px;
        color: #444;
    }

    .btn-show-more {
        width: 100%;
        background: #333;
        color: white;
        border: none;
        padding: 10px;
        border-radius: 6px;
        cursor: pointer;
        margin-top: 10px;
    }

    .ws-search-bar input {
        width: 100%;
        padding: 10px;
        border: 1.5px solid #000;
        border-radius: 10px;
        margin-bottom: 20px;
    }

    .ws-item {
        border-bottom: 1.5px solid #eee;
        padding: 15px 0;
    }

    .ws-footer {
        display: flex;
        justify-content: space-between;
        font-size: 0.75rem;
        color: #666;
        margin-top: 5px;
    }

    /* --- OVERLAYS & MODALS --- */
    .overlay {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.5);
        z-index: 150;
    }

        .overlay.transparent {
            background: transparent;
        }

    .drawer-menu {
        position: fixed;
        top: 0;
        left: 0;
        width: 280px;
        height: 100%;
        background: #000;
        color: white;
        z-index: 200;
        padding: 20px;
    }

    .drawer-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
    }

    .user-large-icon {
        font-size: 40px;
    }

    .close-drawer {
        background: transparent;
        border: none;
        color: white;
        font-size: 20px;
        cursor: pointer;
    }

    .drawer-nav-item {
        padding: 12px;
        color: #ccc;
        cursor: pointer;
        border-radius: 8px;
        font-size: 16px;
    }

        .drawer-nav-item:hover {
            background: #222;
            color: white;
        }

    .nav-divider {
        height: 1px;
        background: #333;
        margin: 15px 0;
    }

    .nav-label {
        color: #666;
        font-size: 12px;
        text-transform: uppercase;
        margin-bottom: 10px;
    }

    .nav-search-wrap input {
        width: 100%;
        background: #222;
        border: 1px solid #444;
        padding: 8px;
        color: white;
        border-radius: 4px;
        margin-bottom: 10px;
    }

    .search-modal {
        position: fixed;
        top: 20px;
        left: 50%;
        transform: translateX(-50%);
        width: 90%;
        max-width: 600px;
        z-index: 200;
    }

    .search-modal-bar {
        background: #1a1a1a;
        display: flex;
        padding: 15px;
        border-radius: 12px;
        border: 1px solid #333;
        align-items: center;
        color: white;
    }

        .search-modal-bar input {
            flex: 1;
            background: transparent;
            border: none;
            color: white;
            outline: none;
            margin: 0 15px;
            font-size: 18px;
        }

    .join-dropdown {
        position: fixed;
        top: 75px;
        right: 80px;
        background: #222;
        padding: 20px;
        border-radius: 15px;
        border: 1px solid #444;
        z-index: 200;
        width: 400px;
        color: white;
    }

    .input-row-dark {
        display: flex;
        gap: 10px;
        margin: 15px 0;
        background: #000;
        padding: 10px;
        border-radius: 8px;
        align-items: center;
    }

        .input-row-dark input {
            flex: 1;
            background: transparent;
            border: none;
            color: white;
            outline: none;
        }

    .tab-row-dark {
        display: flex;
        gap: 20px;
        border-bottom: 1px solid #444;
        margin-bottom: 15px;
    }

        .tab-row-dark span {
            cursor: pointer;
            color: #888;
            padding-bottom: 5px;
            font-size: 14px;
        }

            .tab-row-dark span.active {
                color: white;
                border-bottom: 2px solid white;
            }

    .submit-join-btn {
        width: 100%;
        background: #444;
        color: white;
        border: none;
        padding: 12px;
        border-radius: 8px;
        cursor: pointer;
    }

    .profile-dropdown {
        position: fixed;
        top: 75px;
        right: 20px;
        background: #1a1a1a;
        border: 1px solid #333;
        border-radius: 12px;
        z-index: 200;
        width: 220px;
        padding: 10px;
        color: white;
    }

    .profile-user-info {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px;
        font-weight: bold;
    }

    .dropdown-divider {
        height: 1px;
        background: #333;
        margin: 5px 0;
    }

    .drop-item {
        padding: 10px;
        color: #ccc;
        cursor: pointer;
        border-radius: 6px;
    }

        .drop-item:hover {
            background: #222;
            color: white;
        }

        .drop-item.logout {
            color: #ff4d4d;
        }
</style>