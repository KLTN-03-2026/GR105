@page "/noti"
@inject NavigationManager Navigation
@rendermode InteractiveServer

<div class="dashboard-container">
    <!-- SECTION 1: TOP NAVIGATION BAR (Updated) -->
    <header class="top-navbar">
        <div class="nav-left">
            <button class="menu-toggle" @onclick="ToggleMenu">☰</button>
            <div class="app-logo"></div>
            <span class="nav-title">Notification</span>
        </div>
        <div class="nav-center">
            <div class="search-box" @onclick="ToggleSearch">
                <span class="search-icon">🔍</span>
                <input type="text" placeholder="Search anything..." readonly />
            </div>
        </div>
        <div class="nav-right">
            <button class="btn-join" @onclick="ToggleJoin">+ Join</button>
            <button class="icon-btn" @onclick='() => Navigation.NavigateTo("/noti")'>🔔</button>
            <button class="icon-btn" @onclick="ToggleProfile">👤</button>
        </div>
    </header>

    <!-- MAIN CONTENT (Sidebar + Notification List) -->
    <div class="notification-layout">
        <aside class="noti-sidebar">
            <div class="noti-nav-item active">
                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M22 12H16L14 15H10L8 12H2V20H22V12Z" fill="white" opacity="0.2" />
                    <path d="M22 12H16L14 15H10L8 12H2V20H22V12Z" stroke="white" />
                    <path d="M2 12L7.5 4H16.5L22 12" stroke="white" />
                </svg>
                <span class="nav-text">Inbox</span>
            </div>
            <div class="noti-nav-item">
                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M19 21L12 16L5 21V5C5 3.89543 5.89543 3 7 3H17C18.1046 3 19 3.89543 19 5V21Z" stroke="white" />
                </svg>
                <span class="nav-text">Saved</span>
            </div>
            <div class="noti-nav-item">
                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M20 6L9 17L4 12" stroke="white" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
                <span class="nav-text">Done</span>
            </div>
        </aside>

        <main class="noti-main-content">
            <div class="content-wrapper">
                <header class="toolbar">
                    <div class="filter-group">
                        <button class="filter-btn active">All</button>
                        <button class="filter-btn">Unread</button>
                    </div>
                    <div class="noti-search-box">
                        <span class="search-icon-inline">🔍</span>
                        <input type="text" placeholder="Search notifications" />
                    </div>
                    <div class="sort-badge">
                        Sort by: <strong>Newest to oldest</strong>
                    </div>
                </header>

                <div class="notification-list-card">
                    <div class="list-header">
                        <input type="checkbox" class="custom-checkbox" />
                        <span>Select all</span>
                    </div>

                    @for (int i = 1; i <= 6; i++)
                    {
                        <div class="notification-item @(i == 1 ? "selected" : "")">
                            <div class="item-left">
                                <input type="checkbox" checked="@(i == 1)" class="custom-checkbox" />
                                <div class="item-info">
                                    <p class="meta-data">User_@i / Workspace_Gamma</p>
                                    <p class="preview-text">Update available for the project task #@i...</p>
                                </div>
                            </div>
                            <div class="item-actions">
                                <span>👤</span>
                                <span>✔</span>
                                <span>🔖</span>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </main>
    </div>
</div>

<!-- SECTION 4: OVERLAY LOGIC (Consolidated) -->
@if (showMenu)
{
    <div class="drawer-menu">
        <div class="drawer-header">
            <i class="user-large-icon">👤</i>
            <button class="close-drawer" @onclick="ToggleMenu">✕</button>
        </div>
        <nav class="drawer-nav">
            <div class="drawer-nav-item" @onclick='() => Navigation.NavigateTo("/")'>⌂ Dashboard</div>
            <div class="drawer-nav-item">✉ Feedback</div>
            <div class="drawer-nav-item">📞 Contact Us</div>
            <div class="nav-divider"></div>
            <div class="nav-label">Top workspaces</div>
            <div class="nav-search-wrap">
                <input type="text" placeholder="Search workspace..." />
            </div>
            <div class="drawer-nav-item small">👤 Project Alpha</div>
            <div class="drawer-nav-item small">👤 Team Beta</div>
        </nav>
    </div>
    <div class="overlay" @onclick="ToggleMenu"></div>
}

@if (showSearch)
{
    <div class="search-modal">
        <div class="search-modal-bar">
            <span>⌕</span>
            <input type="text" placeholder="Search anything..." autofocus />
            <button @onclick="ToggleSearch">✕</button>
        </div>
    </div>
    <div class="overlay" @onclick="ToggleSearch"></div>
}

@if (showJoin)
{
    <div class="join-dropdown">
        <div class="dropdown-header" style="display:flex; justify-content:space-between; margin-bottom:15px;">
            <span style="font-weight: bold; color:white;">Join new workspace</span>
            <button @onclick="ToggleJoin" style="background:none; border:none; color:white; cursor:pointer;">✕</button>
        </div>
        <div class="dropdown-body">
            <div class="input-row-dark">
                <i>👤</i>
                <input type="text" placeholder="Username" />
                <button class="copy-btn" style="background:none; border:none; color:#888;">⧉</button>
            </div>
            <div class="tab-row-dark">
                <span class="active">HTTPS</span>
                <span>Users</span>
                <span>Workspace ID</span>
            </div>
            <div class="input-row-dark">
                <input type="text" placeholder="Workspace Link/ID" />
                <button class="copy-btn" style="background:none; border:none; color:#888;">⧉</button>
            </div>
            <button class="submit-join-btn">Send request to join workspace</button>
        </div>
    </div>
    <div class="overlay transparent" @onclick="ToggleJoin"></div>
}

@if (showProfile)
{
    <div class="profile-dropdown">
        <div class="profile-user-info">
            <i>👤</i>
            <span>Username</span>
        </div>
        <div class="dropdown-divider"></div>
        <div class="drop-item" @onclick='() => Navigation.NavigateTo("/profile-detail")'>👤 Profile</div>
        <div class="drop-item">📁 Workspaces</div>
        <div class="drop-item">✉ Feedback</div>
        <div class="drop-item">⚙ Settings</div>
        <div class="drop-item logout">↪ Sign out</div>
    </div>
    <div class="overlay transparent" @onclick="ToggleProfile"></div>
}

@code {
    private bool showMenu = false;
    private bool showSearch = false;
    private bool showJoin = false;
    private bool showProfile = false;

    private void ToggleMenu() => showMenu = !showMenu;
    private void ToggleSearch() => showSearch = !showSearch;
    private void ToggleJoin() => showJoin = !showJoin;
    private void ToggleProfile() => showProfile = !showProfile;
}

<style>
    :root {
        --dark-bg: #1a1a1a;
        --header-h: 65px;
        --sidebar-w: 240px;
    }

    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
        font-family: 'Segoe UI', sans-serif;
    }

    .dashboard-container {
        height: 100vh;
        display: flex;
        flex-direction: column;
        background: var(--dark-bg);
    }

    /* --- SECTION 2: TOPBAR CSS --- */
    .top-navbar {
        height: var(--header-h);
        background: #1a1a1a;
        color: white;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 20px;
        z-index: 100;
        position: relative;
        border-bottom: 1px solid #333;
    }

    .nav-left {
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .menu-toggle {
        background: none;
        border: none;
        color: white;
        font-size: 22px;
        cursor: pointer;
    }

    .app-logo {
        width: 32px;
        height: 32px;
        background: #444;
        border-radius: 6px;
    }

    .nav-title {
        font-weight: bold;
        font-size: 18px;
    }

    .search-box {
        background: #333;
        border-radius: 8px;
        padding: 8px 15px;
        display: flex;
        align-items: center;
        width: 400px;
        cursor: pointer;
    }

        .search-box input {
            background: transparent;
            border: none;
            color: white;
            width: 100%;
            outline: none;
            margin-left: 10px;
        }

    .nav-right {
        display: flex;
        gap: 15px;
        align-items: center;
    }

    .icon-btn {
        background: none;
        border: none;
        color: white;
        font-size: 20px;
        cursor: pointer;
    }

    .btn-join {
        background: transparent;
        border: 1px solid #555;
        color: white;
        padding: 5px 15px;
        border-radius: 6px;
        cursor: pointer;
    }

    /* --- NOTIFICATION LAYOUT --- */
    .notification-layout {
        flex: 1;
        display: flex;
        overflow: hidden;
    }

    .noti-sidebar {
        width: var(--sidebar-w);
        padding: 20px 0;
    }

    .noti-nav-item {
        display: flex;
        align-items: center;
        gap: 15px;
        padding: 12px 25px;
        color: #888;
        cursor: pointer;
        transition: 0.2s;
    }

        .noti-nav-item.active {
            color: white;
            background: rgba(255,255,255,0.05);
            border-radius: 0 20px 20px 0;
        }

    .nav-icon {
        width: 20px;
    }

    .noti-main-content {
        flex: 1;
        background: white;
        border-radius: 30px 0 0 0;
        padding: 30px;
        overflow-y: auto;
    }

    .content-wrapper {
        max-width: 900px;
        margin: 0 auto;
    }

    .toolbar {
        display: flex;
        align-items: center;
        gap: 15px;
        margin-bottom: 25px;
    }

    .filter-group {
        display: flex;
        background: #f0f0f0;
        padding: 4px;
        border-radius: 10px;
    }

    .filter-btn {
        border: none;
        padding: 7px 18px;
        border-radius: 8px;
        cursor: pointer;
        background: transparent;
    }

        .filter-btn.active {
            background: white;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
            font-weight: bold;
        }

    .noti-search-box {
        flex: 1;
        position: relative;
    }

        .noti-search-box input {
            width: 100%;
            padding: 10px 40px;
            border-radius: 12px;
            border: 1px solid #ddd;
            background: #f9f9f9;
        }

    .search-icon-inline {
        position: absolute;
        left: 15px;
        top: 50%;
        transform: translateY(-50%);
        color: #aaa;
    }

    .sort-badge {
        background: #1a1a1a;
        color: white;
        padding: 10px 15px;
        border-radius: 10px;
        font-size: 13px;
    }

    /* --- NOTIFICATION LIST --- */
    .notification-list-card {
        background: #000;
        border-radius: 20px;
        color: white;
        overflow: hidden;
    }

    .list-header {
        padding: 15px 25px;
        border-bottom: 1px solid #222;
        color: #666;
        font-size: 14px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .notification-item {
        display: flex;
        justify-content: space-between;
        padding: 20px 25px;
        border-bottom: 1px solid #111;
        transition: 0.2s;
    }

        .notification-item:hover {
            background: #111;
        }

        .notification-item.selected {
            background: #222;
        }

    .item-left {
        display: flex;
        align-items: center;
        gap: 20px;
    }

    .meta-data {
        color: #555;
        font-size: 12px;
    }

    .preview-text {
        font-size: 14px;
        margin-top: 3px;
    }

    .item-actions {
        display: flex;
        gap: 15px;
        opacity: 0;
    }

    .notification-item:hover .item-actions {
        opacity: 0.6;
    }

    .custom-checkbox {
        width: 18px;
        height: 18px;
        accent-color: #444;
    }

    /* --- SECTION 3: OVERLAYS & MODALS CSS --- */
    .overlay {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.5);
        z-index: 150;
    }

        .overlay.transparent {
            background: transparent;
        }

    .drawer-menu {
        position: fixed;
        top: 0;
        left: 0;
        width: 280px;
        height: 100%;
        background: #000;
        color: white;
        z-index: 200;
        padding: 20px;
    }

    .drawer-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
    }

    .user-large-icon {
        font-size: 40px;
    }

    .close-drawer {
        background: transparent;
        border: none;
        color: white;
        font-size: 20px;
        cursor: pointer;
    }

    .drawer-nav-item {
        padding: 12px;
        color: #ccc;
        cursor: pointer;
        border-radius: 8px;
        font-size: 16px;
    }

        .drawer-nav-item:hover {
            background: #222;
            color: white;
        }

    .nav-divider {
        height: 1px;
        background: #333;
        margin: 15px 0;
    }

    .nav-label {
        color: #666;
        font-size: 12px;
        text-transform: uppercase;
        margin-bottom: 10px;
    }

    .nav-search-wrap input {
        width: 100%;
        background: #222;
        border: 1px solid #444;
        padding: 8px;
        color: white;
        border-radius: 4px;
        margin-bottom: 10px;
    }

    .search-modal {
        position: fixed;
        top: 20px;
        left: 50%;
        transform: translateX(-50%);
        width: 90%;
        max-width: 600px;
        z-index: 200;
    }

    .search-modal-bar {
        background: #1a1a1a;
        display: flex;
        padding: 15px;
        border-radius: 12px;
        border: 1px solid #333;
        align-items: center;
        color: white;
    }

        .search-modal-bar input {
            flex: 1;
            background: transparent;
            border: none;
            color: white;
            outline: none;
            margin: 0 15px;
            font-size: 18px;
        }

    .join-dropdown {
        position: fixed;
        top: 75px;
        right: 80px;
        background: #222;
        padding: 20px;
        border-radius: 15px;
        border: 1px solid #444;
        z-index: 200;
        width: 400px;
        color: white;
    }

    .input-row-dark {
        display: flex;
        gap: 10px;
        margin: 15px 0;
        background: #000;
        padding: 10px;
        border-radius: 8px;
        align-items: center;
    }

        .input-row-dark input {
            flex: 1;
            background: transparent;
            border: none;
            color: white;
            outline: none;
        }

    .tab-row-dark {
        display: flex;
        gap: 20px;
        border-bottom: 1px solid #444;
        margin-bottom: 15px;
    }

        .tab-row-dark span {
            cursor: pointer;
            color: #888;
            padding-bottom: 5px;
            font-size: 14px;
        }

            .tab-row-dark span.active {
                color: white;
                border-bottom: 2px solid white;
            }

    .submit-join-btn {
        width: 100%;
        background: #444;
        color: white;
        border: none;
        padding: 12px;
        border-radius: 8px;
        cursor: pointer;
    }

    .profile-dropdown {
        position: fixed;
        top: 75px;
        right: 20px;
        background: #1a1a1a;
        border: 1px solid #333;
        border-radius: 12px;
        z-index: 200;
        width: 220px;
        padding: 10px;
        color: white;
    }

    .profile-user-info {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px;
        font-weight: bold;
    }

    .dropdown-divider {
        height: 1px;
        background: #333;
        margin: 5px 0;
    }

    .drop-item {
        padding: 10px;
        color: #ccc;
        cursor: pointer;
        border-radius: 6px;
    }

        .drop-item:hover {
            background: #222;
            color: white;
        }

        .drop-item.logout {
            color: #ff4d4d;
        }
</style>