@page "/404"
@inject NavigationManager Navigation
@rendermode InteractiveServer

<header class="top-navbar">
    <div class="nav-left">
        <button class="menu-toggle" @onclick="ToggleMenu">☰</button>
        <div class="app-logo"></div>
        <span class="nav-title">Username</span>
    </div>
    <div class="nav-center">
        <div class="search-box" @onclick="ToggleSearch">
            <span class="search-icon">🔍</span>
            <input type="text" placeholder="Search anything..." readonly />
        </div>
    </div>
    <div class="nav-right">
        <button class="btn-join" @onclick="ToggleJoin">+ Join</button>
        <button class="icon-btn" @onclick='() => Navigation.NavigateTo("/noti")'>🔔</button>
        <button class="icon-btn" @onclick="ToggleProfile">👤</button>
    </div>
</header>

    <main class="error-page-content">
        <div class="shredder-component">

            <div class="top-paper-feeder">
                <div class="feeder-slot"></div>
            </div>

            <div class="input-paper-container">
                <div class="paper-top-piece">
                    <div class="content-wrapper">
                        <h1 class="text-error">ERROR</h1>
                        <h2 class="text-404">404</h2>
                        <div class="decoration-lines">
                            <span class="line-long"></span>
                            <span class="line-long"></span>
                            <span class="line-mid"></span>
                            <span class="line-long"></span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="shredder-main-frame">
                <div class="shredder-interface">
                    <div class="left-controls">
                        <div class="control-hole"></div>
                        <div class="control-hole"></div>
                        <span class="header-text">WE'RE SORRY.</span>
                    </div>

                    <div class="right-controls">
                        <div class="led green-glow"></div>
                        <button class="nav-button" @onclick='() => Navigation.NavigateTo("/home")'>
                            <span class="icon-back">↩</span> Dashboard
                        </button>
                        <div class="led red-dim"></div>
                    </div>
                </div>

                <div class="message-area">
                    <p class="main-msg">It seems like this document was shredded or lost.</p>
                    <p class="sub-msg">Maybe you can find it in another place?</p>
                </div>

                <div class="shredder-slot">
                    <div class="shredded-strips"></div>
                </div>
            </div>

            <div class="corner-deco-x">✖</div>
        </div>
    </main>


@if (showMenu)
{
    <div class="drawer-menu">
        <div class="drawer-header">
            <i class="user-large-icon">👤</i>
            <button class="close-drawer" @onclick="ToggleMenu">✕</button>
        </div>
        <nav class="drawer-nav">
            <div class="drawer-nav-item" @onclick='() => Navigation.NavigateTo("/")'>⌂ Dashboard</div>
            <div class="drawer-nav-item">✉ Feedback</div>
            <div class="drawer-nav-item">📞 Contact Us</div>
            <div class="nav-divider"></div>
            <div class="nav-label">Top workspaces</div>
            <div class="nav-search-wrap">
                <input type="text" placeholder="Search workspace..." />
            </div>
            <div class="drawer-nav-item small">👤 Project Alpha</div>
            <div class="drawer-nav-item small">👤 Team Beta</div>
        </nav>
    </div>
    <div class="overlay" @onclick="ToggleMenu"></div>
}

@if (showSearch)
{
    <div class="search-modal">
        <div class="search-modal-bar">
            <span>⌕</span>
            <input type="text" placeholder="Search anything..." autofocus />
            <button @onclick="ToggleSearch">✕</button>
        </div>
    </div>
    <div class="overlay" @onclick="ToggleSearch"></div>
}

@if (showJoin)
{
    <div class="join-dropdown">
        <div class="dropdown-header">
            <span style="font-weight: bold;">Join new workspace</span>
            <button @onclick="ToggleJoin" style="background:none; border:none; color:white; cursor:pointer;">✕</button>
        </div>
        <div class="dropdown-body">
            <div class="input-row-dark">
                <i>👤</i>
                <input type="text" placeholder="Username" />
                <button class="copy-btn">⧉</button>
            </div>
            <div class="tab-row-dark">
                <span class="active">HTTPS</span>
                <span>Users</span>
                <span>Workspace ID</span>
            </div>
            <div class="input-row-dark">
                <input type="text" placeholder="Workspace Link/ID" />
                <button class="copy-btn">⧉</button>
            </div>
            <button class="submit-join-btn">Send request to join workspace</button>
        </div>
    </div>
    <div class="overlay transparent" @onclick="ToggleJoin"></div>
}

@if (showProfile)
{
    <div class="profile-dropdown">
        <div class="profile-user-info">
            <i>👤</i>
            <span>Username</span>
        </div>
        <div class="dropdown-divider"></div>
        <div class="drop-item" @onclick='() => Navigation.NavigateTo("/profile-detail")'>👤 Profile</div>
        <div class="drop-item">📁 Workspaces</div>
        <div class="drop-item">✉ Feedback</div>
        <div class="drop-item">⚙ Settings</div>
        <div class="drop-item logout">↪ Sign out</div>
    </div>
    <div class="overlay transparent" @onclick="ToggleProfile"></div>
}

@code {
    private bool showMenu = false;
    private bool showSearch = false;
    private bool showJoin = false;
    private bool showProfile = false;

    private void ToggleMenu() => showMenu = !showMenu;
    private void ToggleSearch() => showSearch = !showSearch;
    private void ToggleJoin() => showJoin = !showJoin;
    private void ToggleProfile() => showProfile = !showProfile;
}

<style>
    :root {
        --dark-bg: #1a1a1a;
        --header-h: 65px;
        --text-white: #ffffff;
    }

    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
        font-family: 'Segoe UI', sans-serif;
    }

    body {
        overflow: hidden;
        background-color: #fff;
    }

    .dashboard-container {
        display: flex;
        flex-direction: column;
        height: 100vh;
    }

    /* --- TOPBAR STYLE --- */
    .top-navbar {
        height: 65px;
        background: #1a1a1a;
        color: white;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 20px;
        z-index: 100;
        position: relative;
    }

    .nav-left {
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .menu-toggle {
        background: none;
        border: none;
        color: white;
        font-size: 22px;
        cursor: pointer;
    }

    .app-logo {
        width: 32px;
        height: 32px;
        background: #444;
        border-radius: 6px;
    }

    .search-box {
        background: #333;
        border-radius: 8px;
        padding: 8px 15px;
        display: flex;
        align-items: center;
        width: 400px;
        cursor: pointer;
    }

        .search-box input {
            background: transparent;
            border: none;
            color: white;
            width: 100%;
            outline: none;
            margin-left: 10px;
        }

    .nav-right {
        display: flex;
        gap: 15px;
        align-items: center;
    }

    .icon-btn {
        background: none;
        border: none;
        color: white;
        font-size: 20px;
        cursor: pointer;
    }

    .btn-join {
        background: transparent;
        border: 1px solid #555;
        color: white;
        padding: 5px 15px;
        border-radius: 6px;
        cursor: pointer;
    }

    .error-page-content {
        flex: 1;
        display: flex;
        justify-content: center;
        align-items: center;
        background: #fff;
        padding-top: 50px;
    }

    .shredder-component {
        position: relative;
        width: 750px;
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .top-paper-feeder {
        width: 450px;
        height: 160px;
        background-color: #333;
        border-radius: 15px 15px 0 0;
        position: absolute;
        top: 150px;
        z-index: 0;
        display: flex;
        justify-content: center;
    }

    .feeder-slot {
        width: 340px;
        height: 10px;
        background: #000;
        margin-top: 10px;
        border-radius: 5px;
    }

    .input-paper-container {
        perspective: 1000px;
        z-index: 1;
        margin-bottom: -15px;
        position: relative;
    }

    .paper-top-piece {
        width: 380px;
        height: 320px;
        background: #ffffff;
        border: 3px solid #1a1a1a;
        transform: rotateX(10deg);
        padding: 40px 30px;
        text-align: center;
        box-shadow: 0 -5px 15px rgba(0,0,0,0.05);
    }

    .text-error {
        font-size: 70px;
        font-weight: 900;
        line-height: 1;
        margin: 0;
    }

    .text-404 {
        font-size: 75px;
        font-weight: 900;
        border-top: 5px solid #000;
        border-bottom: 5px solid #000;
        display: inline-block;
        padding: 0 15px;
        margin: 5px 0;
    }

    .decoration-lines {
        margin-top: 20px;
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .line-long {
        height: 4px;
        background: #eee;
        width: 100%;
    }

    .line-mid {
        height: 4px;
        background: #eee;
        width: 70%;
    }

    .shredder-main-frame {
        width: 100%;
        background-color: #1a1a1a;
        border-radius: 24px;
        padding: 25px;
        position: relative;
        z-index: 2;
        box-shadow: 0 25px 60px rgba(0,0,0,0.3);
        border: 4px solid #000;
    }

    .shredder-interface {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 40px;
    }

    .left-controls {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .control-hole {
        width: 25px;
        height: 25px;
        border-radius: 50%;
        background: #444;
        border: 2px solid #000;
    }

    .header-text {
        color: #fff;
        font-weight: bold;
        font-size: 16px;
        margin-left: 10px;
    }

    .right-controls {
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .led {
        width: 10px;
        height: 10px;
        border-radius: 50%;
    }

    .green-glow {
        background: #4df06a;
        box-shadow: 0 0 10px #4df06a;
    }

    .red-dim {
        background: #b32d2d;
    }

    .nav-button {
        background: #3d3d3d;
        color: #fff;
        border: 2px solid #000;
        border-radius: 20px;
        padding: 6px 18px;
        font-size: 14px;
        cursor: pointer;
        font-weight: bold;
    }

    .message-area {
        text-align: center;
        color: #e0e0e0;
        padding: 20px 0 60px;
    }

    .main-msg {
        font-size: 24px;
        margin-bottom: 10px;
    }

    .sub-msg {
        font-size: 18px;
        opacity: 0.8;
    }

    .shredder-slot {
        position: absolute;
        bottom: -40px;
        left: 50%;
        transform: translateX(-50%);
        width: 340px;
        height: 120px;
        overflow: hidden;
        background: #000;
    }

    .shredded-strips {
        width: 100%;
        height: 200%;
        background: linear-gradient(to bottom, rgba(0,0,0,0.4) 0px, rgba(0,0,0,0.4) 15px, transparent 15px), repeating-linear-gradient(90deg, #fff, #fff 12px, transparent 12px, transparent 20px);
        background-size: 100% 100%, 20px 100%;
        animation: shredding-motion 2s linear infinite;
    }

    @@keyframes shredding-motion {
        0% {
            transform: translateY(-50%);
        }

        100% {
            transform: translateY(0);
        }
    }

    .corner-deco-x {
        position: absolute;
        bottom: 15px;
        right: 15px;
        font-size: 120px;
        color: #000;
        font-weight: 900;
        opacity: 0.9;
        pointer-events: none;
    }

    .overlay {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.5);
        z-index: 150;
    }

        .overlay.transparent {
            background: transparent;
        }

    .drawer-menu {
        position: fixed;
        top: 0;
        left: 0;
        width: 280px;
        height: 100%;
        background: #000;
        color: white;
        z-index: 200;
        padding: 20px;
    }

    .drawer-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
    }

    .user-large-icon {
        font-size: 40px;
    }

    .close-drawer {
        background: transparent;
        border: none;
        color: white;
        font-size: 20px;
        cursor: pointer;
    }

    .drawer-nav-item {
        padding: 12px;
        color: #ccc;
        cursor: pointer;
        border-radius: 8px;
        font-size: 16px;
    }

        .drawer-nav-item:hover {
            background: #222;
            color: white;
        }

    .nav-divider {
        height: 1px;
        background: #333;
        margin: 15px 0;
    }

    .nav-label {
        color: #666;
        font-size: 12px;
        text-transform: uppercase;
        margin-bottom: 10px;
    }

    .nav-search-wrap input {
        width: 100%;
        background: #222;
        border: 1px solid #444;
        padding: 8px;
        color: white;
        border-radius: 4px;
        margin-bottom: 10px;
    }

    .search-modal {
        position: fixed;
        top: 20px;
        left: 50%;
        transform: translateX(-50%);
        width: 90%;
        max-width: 600px;
        z-index: 200;
    }

    .search-modal-bar {
        background: #1a1a1a;
        display: flex;
        padding: 15px;
        border-radius: 12px;
        border: 1px solid #333;
        align-items: center;
        color: white;
    }

        .search-modal-bar input {
            flex: 1;
            background: transparent;
            border: none;
            color: white;
            outline: none;
            margin: 0 15px;
            font-size: 18px;
        }

    .join-dropdown {
        position: fixed;
        top: 75px;
        right: 80px;
        background: #222;
        padding: 20px;
        border-radius: 15px;
        border: 1px solid #444;
        z-index: 200;
        width: 400px;
        color: white;
    }

    .input-row-dark {
        display: flex;
        gap: 10px;
        margin: 15px 0;
        background: #000;
        padding: 10px;
        border-radius: 8px;
        align-items: center;
    }

        .input-row-dark input {
            flex: 1;
            background: transparent;
            border: none;
            color: white;
            outline: none;
        }

    .tab-row-dark {
        display: flex;
        gap: 20px;
        border-bottom: 1px solid #444;
        margin-bottom: 15px;
    }

        .tab-row-dark span {
            cursor: pointer;
            color: #888;
            padding-bottom: 5px;
            font-size: 14px;
        }

            .tab-row-dark span.active {
                color: white;
                border-bottom: 2px solid white;
            }

    .submit-join-btn {
        width: 100%;
        background: #444;
        color: white;
        border: none;
        padding: 12px;
        border-radius: 8px;
        cursor: pointer;
    }

    .profile-dropdown {
        position: fixed;
        top: 75px;
        right: 20px;
        background: #1a1a1a;
        border: 1px solid #333;
        border-radius: 12px;
        z-index: 200;
        width: 220px;
        padding: 10px;
        color: white;
    }

    .profile-user-info {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px;
        font-weight: bold;
    }

    .dropdown-divider {
        height: 1px;
        background: #333;
        margin: 5px 0;
    }

    .drop-item {
        padding: 10px;
        color: #ccc;
        cursor: pointer;
        border-radius: 6px;
    }

        .drop-item:hover {
            background: #222;
            color: white;
        }

        .drop-item.logout {
            color: #ff4d4d;
        }
</style>