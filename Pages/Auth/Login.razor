<style>
    body {
        margin: 0;
        background-color: #FFFFFF;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .scale-wrapper {
        width: 100vw;
        height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #FFFFFF;
        overflow: hidden;
        position: relative;
    }

    .view-container {
        position: absolute;
        transition: all 0.7s cubic-bezier(0.4, 0, 0.2, 1);
        width: 100vw;
        height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    /* Normal View states */
    .normal-view {
        transform: translateY(0) scale(1);
        opacity: 1;
        pointer-events: auto;
    }

    .admin-active .normal-view {
        transform: translateY(100vh) scale(0.9);
        opacity: 0;
        pointer-events: none;
    }

    /* Admin View states */
    .admin-view {
        transform: translateY(-100vh) scale(0.9);
        opacity: 0;
        pointer-events: none;
    }

    .admin-active .admin-view {
        transform: translateY(0) scale(1);
        opacity: 1;
        pointer-events: auto;
    }

    .figma-artboard {
        width: 1920px;
        height: 1080px;
        position: relative;
        transform-origin: center center;
        transform: scale(min(calc(100vw / 1920), calc(100vh / 1080)));
    }

    .admin-bg-layer {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
    }

    /* Original Normal Login Styles */
    .floating-shapes {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        z-index: 0;
    }

    .dark-container {
        position: absolute;
        left: 464px;
        top: 392px;
        width: 992px;
        height: 544px;
        background-color: #1E1E1E;
        border-radius: 28px;
        box-shadow: 0px 4px 4px rgba(0, 0, 0, 0.25);
        z-index: 1;
    }

    .gray-box {
        position: absolute;
        left: 51px;
        top: 65px;
        width: 889px;
        height: 431px;
        background-color: #636363;
        border-radius: 25px;
    }

    .white-box {
        position: absolute;
        left: 65px;
        top: 77px;
        width: 862px;
        height: 408px;
        background-color: #fff;
    }

    .logo-box {
        position: absolute;
        left: 374.5px;
        top: 15px;
        width: 113px;
        height: 79px;
        background-color: #D9D9D9;
    }

    .system-title {
        position: absolute;
        left: 0;
        top: 115px;
        width: 100%;
        text-align: center;
        font-size: 16px;
        font-weight: 800;
        letter-spacing: 0.5px;
        color: #000000;
    }

    .form-title {
        position: absolute;
        left: 0;
        top: 140px;
        width: 100%;
        text-align: center;
        font-size: 13px;
        font-weight: 500;
        color: #000000;
    }

    .form-container {
        position: absolute;
        left: 212.5px;
        top: 170.5px;
        width: 437px;
    }
</style>

@code {
    private bool _isAdminMode = false;
    private IJSObjectReference? _jsModule;
    private IJSObjectReference? _shortcutDisposer;
    private DotNetObjectReference<Login>? _dotNetRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                _dotNetRef = DotNetObjectReference.Create(this);
                _jsModule = await JSRuntime.InvokeAsync<IJSObjectReference>("import", "/js/adminShortcut.js");
                _shortcutDisposer = await _jsModule.InvokeAsync<IJSObjectReference>("initShortcut", _dotNetRef);
            }
            catch (Exception ex)
            {
                await JSRuntime.InvokeVoidAsync("console.error", $"Could not init shortcut: {ex.Message}");
            }
        }
    }

    [JSInvokable]
    public void ToggleAdminMode()
    {
        _isAdminMode = !_isAdminMode;
        StateHasChanged();
    }

    public async ValueTask DisposeAsync()
    {
        _dotNetRef?.Dispose();
        if (_shortcutDisposer is not null)
        {
            await _shortcutDisposer.InvokeVoidAsync("dispose");
            await _shortcutDisposer.DisposeAsync();
        }
        if (_jsModule is not null)
        {
            await _jsModule.DisposeAsync();
        }
    }
}