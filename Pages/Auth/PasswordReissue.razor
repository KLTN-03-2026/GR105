@page "/password-reissue"

<div class="app-wrapper">
    @* 1. TOP NAVBAR  *@
    <header class="top-navbar">
        <div class="nav-left">
            <button class="menu-toggle">☰</button>
            <div class="app-logo"></div>
            <span class="nav-title">Settings</span>
        </div>
        <div class="nav-right">
            <button class="btn-join">+ Join</button>
            <button class="icon-btn">🔔</button>
            <button class="icon-btn">👤</button>
        </div>
    </header>

    <div class="typewriter-viewport">
        <div class="typewriter-container">

            @* PHẦN GIẤY TRÊN MÁY (Tờ đơn) *@
            <div class="paper-sheet">
                <h2 class="form-title">Password Reissue Form</h2>

                <div class="form-content">
                    <div class="form-group">
                        <label>Username</label>
                        <input type="text" class="typewriter-input" placeholder="..." />
                    </div>

                    <div class="form-group">
                        <label>Reason</label>
                        <div class="custom-select-wrapper">
                            <select class="typewriter-input">
                                <option value="">Select a reason</option>
                                <option value="forgot">Forgot password</option>
                                <option value="security">Security concern</option>
                            </select>
                            <span class="select-arrow">▼</span>
                        </div>
                    </div>

                    <div class="submit-area">
                        <button class="btn-submit-typewriter">Submit</button>
                        @* Mũi tên chỉ xuống tờ giấy *@
                        <div class="paper-pointer">▲</div>
                    </div>
                </div>
            </div>

            @* THÂN MÁY ĐÁNH CHỮ *@
            <div class="typewriter-body">
                @* Trục xoay hai bên *@
                <div class="knob knob-left"></div>
                <div class="knob knob-right"></div>

                @* Khe nạp giấy *@
                <div class="paper-slot"></div>

                @* Bàn phím máy đánh chữ *@
                <div class="keyboard-section">
                    <div class="key-grid">
                        @for (int i = 0; i < 28; i++)
                        {
                            <div class="key-cap"></div>
                        }
                    </div>
                    <div class="space-bar"></div>
                </div>

                @* Chân đế máy *@
                <div class="typewriter-base"></div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Nền tảng Layout */
    .app-wrapper {
        background: #fdfdfd;
        min-height: 100vh;
        font-family: 'Courier New', Courier, monospace;
    }

    .top-navbar {
        height: 60px;
        background: #1a1a1a;
        color: white;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 20px;
    }

    .typewriter-viewport {
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 60px 20px;
    }

    .typewriter-container {
        position: relative;
        display: flex;
        flex-direction: column;
        align-items: center;
        width: 100%;
        max-width: 700px;
    }

    /* Tờ giấy nạp vào máy */
    .paper-sheet {
        background: white;
        width: 80%;
        padding: 40px;
        border: 1px solid #999;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        z-index: 5;
        transform: translateY(20px);
        border-radius: 2px;
    }

    .form-title {
        text-align: center;
        font-weight: 900;
        font-size: 1.8rem;
        margin-bottom: 30px;
        color: #000;
    }

    .form-group {
        margin-bottom: 25px;
    }

        .form-group label {
            display: block;
            font-size: 1.2rem;
            font-weight: bold;
            margin-bottom: 10px;
        }

    .typewriter-input {
        width: 100%;
        padding: 12px;
        border: 2px solid #333;
        border-radius: 12px;
        font-family: inherit;
        font-size: 1.1rem;
        outline: none;
    }

    .custom-select-wrapper {
        position: relative;
    }

    .select-arrow {
        position: absolute;
        right: 15px;
        top: 50%;
        transform: translateY(-50%);
        pointer-events: none;
    }

    .submit-area {
        display: flex;
        flex-direction: column;
        align-items: center;
        margin-top: 20px;
    }

    .btn-submit-typewriter {
        background: #222;
        color: white;
        border: none;
        padding: 12px 40px;
        border-radius: 20px;
        font-size: 1.2rem;
        font-weight: bold;
        cursor: pointer;
        transition: 0.2s;
    }

        .btn-submit-typewriter:hover {
            transform: scale(1.05);
            background: #000;
        }

    .paper-pointer {
        font-size: 1.5rem;
        margin-top: 5px;
        color: #222;
    }

    /* Thân máy đánh chữ */
    .typewriter-body {
        width: 100%;
        background: #444; /* Màu xám đen của thân máy */
        height: 380px;
        border-radius: 20px 20px 50px 50px;
        position: relative;
        padding: 40px;
        box-shadow: 0 20px 40px rgba(0,0,0,0.4);
        display: flex;
        flex-direction: column;
        align-items: center;
        background: linear-gradient(145deg, #4a4a4a, #2a2a2a);
    }

    /* Các núm xoay trục giấy */
    .knob {
        position: absolute;
        top: 30px;
        width: 40px;
        height: 80px;
        background: linear-gradient(to right, #777, #999, #777);
        border-radius: 5px;
        border: 2px solid #333;
    }

    .knob-left {
        left: -20px;
    }

    .knob-right {
        right: -20px;
    }

    .paper-slot {
        width: 85%;
        height: 20px;
        background: #111;
        border-radius: 10px;
        margin-bottom: 40px;
    }

    /* Bàn phím */
    .keyboard-section {
        background: #d1d1d1;
        width: 90%;
        height: 220px;
        border-radius: 10px;
        padding: 20px;
        display: flex;
        flex-direction: column;
        align-items: center;
        box-shadow: inset 0 5px 15px rgba(0,0,0,0.2);
    }

    .key-grid {
        display: grid;
        grid-template-columns: repeat(7, 1fr);
        gap: 12px;
        width: 100%;
        margin-bottom: 15px;
    }

    .key-cap {
        width: 45px;
        height: 35px;
        background: #666;
        border-radius: 4px;
        box-shadow: 0 4px #333;
    }

    .space-bar {
        width: 70%;
        height: 35px;
        background: #333;
        border-radius: 4px;
        box-shadow: 0 4px #000;
    }

    .typewriter-base {
        position: absolute;
        bottom: -15px;
        width: 105%;
        height: 30px;
        background: #000;
        border-radius: 0 0 20px 20px;
    }
</style>