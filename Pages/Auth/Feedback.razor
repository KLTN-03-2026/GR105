@page "/feedback"
@inject IJSRuntime JS
@inject NavigationManager Navigation
@rendermode InteractiveServer

<header class="top-navbar">
    <div class="nav-left">
        <button class="menu-toggle" @onclick="ToggleMenu">☰</button>
        <div class="app-logo"></div>
        <span class="nav-title">Username</span>
    </div>
    <div class="nav-center">
        <div class="search-box" @onclick="ToggleSearch">
            <span class="search-icon">🔍</span>
            <input type="text" placeholder="Search anything..." readonly />
        </div>
    </div>
    <div class="nav-right">
        <button class="btn-join" @onclick="ToggleJoin">+ Join</button>
        <button class="icon-btn" @onclick='() => Navigation.NavigateTo("/noti")'>🔔</button>
        <button class="icon-btn" @onclick="ToggleProfile">👤</button>
    </div>
</header>

<main class="main-content-area">
    <div class="feedback-page-wrapper">
        <div class="cabinet-frame">
            <div class="feedback-paper-sheet">
                <div class="sheet-top-nav">
                    <div class="custom-dropdown">
                        <select>
                            <option>Assigned to ▼</option>
                        </select>
                    </div>
                    <button class="new-feedback-action">
                        <i class="mail-icon">✉</i> New feedback
                    </button>
                </div>

                <div class="feedback-results-box">
                    <div class="results-title-bar">30 results</div>

                    <div class="scroll-wrapper">
                        @* Thêm id và onscroll để đồng bộ hóa *@
                        <div class="feedback-items-list" id="scrollContainer">
                            @for (int i = 1; i <= 30; i++)
                            {
                                <div class="feedback-entry">
                                    <div class="entry-main">
                                        <span class="entry-title">Feedback Item #@i</span>
                                        <span class="entry-sub">User_@i - Updated @(i)h ago</span>
                                    </div>
                                    <div class="entry-avatar">👤</div>
                                </div>
                            }
                        </div>

                        @* Thanh cuộn tùy chỉnh *@
                        <div class="side-scrollbar-track">
                            <div class="side-scrollbar-thumb" id="scrollThumb">
                                <div class="thumb-grip"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="cabinet-footer-logo">
                <div class="full-logo-display">Logo</div>
            </div>
        </div>
    </div>
</main>

@* --- Overlays --- *@
@if (showMenu)
{
    <div class="drawer-menu">
        <div class="drawer-header">
            <i class="user-large-icon">👤</i>
            <button class="close-drawer" @onclick="ToggleMenu">✕</button>
        </div>
        <nav class="drawer-nav">
            <div class="drawer-nav-item" @onclick='() => Navigation.NavigateTo("/")'>⌂ Dashboard</div>
            <div class="drawer-nav-item">✉ Feedback</div>
            <div class="drawer-nav-item">📞 Contact Us</div>
            <div class="nav-divider"></div>
            <div class="nav-label">Top workspaces</div>
            <div class="nav-search-wrap">
                <input type="text" placeholder="Search workspace..." />
            </div>
            <div class="drawer-nav-item small">👤 Project Alpha</div>
            <div class="drawer-nav-item small">👤 Team Beta</div>
        </nav>
    </div>
    <div class="overlay" @onclick="ToggleMenu"></div>
}

@if (showSearch)
{
    <div class="search-modal">
        <div class="search-modal-bar">
            <span>⌕</span>
            <input type="text" placeholder="Search anything..." autofocus />
            <button @onclick="ToggleSearch">✕</button>
        </div>
    </div>
    <div class="overlay" @onclick="ToggleSearch"></div>
}

@if (showJoin)
{
    <div class="join-dropdown">
        <div class="dropdown-header">
            <span style="font-weight: bold;">Join new workspace</span>
            <button @onclick="ToggleJoin" style="background:none; border:none; color:white; cursor:pointer;">✕</button>
        </div>
        <div class="dropdown-body">
            <div class="input-row-dark">
                <i>👤</i>
                <input type="text" placeholder="Username" />
                <button class="copy-btn">⧉</button>
            </div>
            <div class="tab-row-dark">
                <span class="active">HTTPS</span>
                <span>Users</span>
                <span>Workspace ID</span>
            </div>
            <div class="input-row-dark">
                <input type="text" placeholder="Workspace Link/ID" />
                <button class="copy-btn">⧉</button>
            </div>
            <button class="submit-join-btn">Send request to join workspace</button>
        </div>
    </div>
    <div class="overlay transparent" @onclick="ToggleJoin"></div>
}

@if (showProfile)
{
    <div class="profile-dropdown">
        <div class="profile-user-info">
            <i>👤</i>
            <span>Username</span>
        </div>
        <div class="dropdown-divider"></div>
        <div class="drop-item" @onclick='() => Navigation.NavigateTo("/profile-detail")'>👤 Profile</div>
        <div class="drop-item">📁 Workspaces</div>
        <div class="drop-item">✉ Feedback</div>
        <div class="drop-item">⚙ Settings</div>
        <div class="drop-item logout">↪ Sign out</div>
    </div>
    <div class="overlay transparent" @onclick="ToggleProfile"></div>
}

@code {
    private bool showMenu = false;
    private bool showSearch = false;
    private bool showJoin = false;
    private bool showProfile = false;

    private void ToggleMenu() => showMenu = !showMenu;
    private void ToggleSearch() => showSearch = !showSearch;
    private void ToggleJoin() => showJoin = !showJoin;
    private void ToggleProfile() => showProfile = !showProfile;
}

<style>
    :root {
        --dark-bg: #1a1a1a;
        --accent-blue: #00aaff;
    }

    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
        font-family: 'Segoe UI', sans-serif;
    }

    body {
        overflow: hidden;
        background-color: #fff;
    }

    .top-navbar {
        height: 65px;
        background: #1a1a1a;
        color: white;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 20px;
        z-index: 100;
        position: relative;
    }

    .nav-left {
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .menu-toggle {
        background: none;
        border: none;
        color: white;
        font-size: 22px;
        cursor: pointer;
    }

    .app-logo {
        width: 32px;
        height: 32px;
        background: #444;
        border-radius: 6px;
    }

    .search-box {
        background: #333;
        border-radius: 8px;
        padding: 8px 15px;
        display: flex;
        align-items: center;
        width: 400px;
        cursor: pointer;
    }

        .search-box input {
            background: transparent;
            border: none;
            color: white;
            width: 100%;
            outline: none;
            margin-left: 10px;
        }

    .nav-right {
        display: flex;
        gap: 15px;
        align-items: center;
    }

    .icon-btn {
        background: none;
        border: none;
        color: white;
        font-size: 20px;
        cursor: pointer;
    }

    .btn-join {
        background: transparent;
        border: 1px solid #555;
        color: white;
        padding: 5px 15px;
        border-radius: 6px;
        cursor: pointer;
    }

    .main-content-area {
        flex: 1;
        height: calc(100vh - 65px);
        background: #f5f5f5;
        display: flex;
        justify-content: center;
        align-items: center;
        overflow-y: auto;
    }

    .feedback-page-wrapper {
        width: 100%;
        display: flex;
        justify-content: center;
        padding: 40px 20px;
        margin-top: 40px;
    }

    .cabinet-frame {
        width: 720px;
        height: 450px;
        background: #4a4a4a;
        border: 4px solid #1a1a1a;
        border-radius: 12px;
        position: relative;
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
        box-shadow: 0 40px 60px rgba(0,0,0,0.25);
    }

    .feedback-paper-sheet {
        position: absolute;
        top: -80px;
        left: 50%;
        transform: translateX(-50%);
        width: 90%;
        background: #fff;
        border: 3px solid #1a1a1a;
        border-radius: 15px;
        padding: 20px;
        z-index: 10;
    }

    .scroll-wrapper {
        display: flex;
        height: 280px;
        border: 3px solid #1a1a1a;
        border-radius: 8px;
        overflow: hidden;
        position: relative;
    }

    .feedback-items-list {
        flex: 1;
        overflow-y: auto;
        scrollbar-width: none;
    }

        .feedback-items-list::-webkit-scrollbar {
            display: none;
        }

    .feedback-entry {
        display: flex;
        justify-content: space-between;
        padding: 12px 20px;
        border-bottom: 1px solid #eee;
        align-items: center;
    }

    .entry-title {
        font-weight: bold;
        display: block;
    }

    .entry-sub {
        font-size: 0.8rem;
        color: #777;
    }

    .side-scrollbar-track {
        width: 40px;
        background: #e0e0e0;
        border-left: 3px solid #1a1a1a;
        position: relative;
    }

    .side-scrollbar-thumb {
        width: 28px;
        min-height: 40px;
        background: #1a1a1a;
        border-radius: 20px;
        position: absolute;
        left: 50%;
        transform: translateX(-50%);
        top: 0;
        cursor: grab;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .thumb-grip {
        width: 12px;
        height: 2px;
        background: #444;
        box-shadow: 0 4px 0 #444, 0 -4px 0 #444;
    }

    .results-title-bar {
        background: #1a1a1a;
        color: white;
        padding: 10px;
        font-weight: bold;
    }

    .sheet-top-nav {
        display: flex;
        justify-content: space-between;
        margin-bottom: 15px;
    }

    .new-feedback-action {
        background: #1a1a1a;
        color: white;
        border: none;
        padding: 8px 15px;
        border-radius: 6px;
        cursor: pointer;
    }

    .cabinet-footer-logo {
        padding: 20px;
        display: flex;
        justify-content: flex-end;
    }

    .full-logo-display {
        width: 100px;
        height: 70px;
        border: 3px solid var(--accent-blue);
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        color: var(--accent-blue);
        border-radius: 8px;
    }

    /* Modals & Overlays */
    /* --- OVERLAYS & MODALS --- */
    .overlay {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.5);
        z-index: 150;
    }

        .overlay.transparent {
            background: transparent;
        }

    .drawer-menu {
        position: fixed;
        top: 0;
        left: 0;
        width: 280px;
        height: 100%;
        background: #000;
        color: white;
        z-index: 200;
        padding: 20px;
    }

    .drawer-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
    }

    .user-large-icon {
        font-size: 40px;
    }

    .close-drawer {
        background: transparent;
        border: none;
        color: white;
        font-size: 20px;
        cursor: pointer;
    }

    .drawer-nav-item {
        padding: 12px;
        color: #ccc;
        cursor: pointer;
        border-radius: 8px;
        font-size: 16px;
    }

        .drawer-nav-item:hover {
            background: #222;
            color: white;
        }

    .nav-divider {
        height: 1px;
        background: #333;
        margin: 15px 0;
    }

    .nav-label {
        color: #666;
        font-size: 12px;
        text-transform: uppercase;
        margin-bottom: 10px;
    }

    .nav-search-wrap input {
        width: 100%;
        background: #222;
        border: 1px solid #444;
        padding: 8px;
        color: white;
        border-radius: 4px;
        margin-bottom: 10px;
    }

    .search-modal {
        position: fixed;
        top: 20px;
        left: 50%;
        transform: translateX(-50%);
        width: 90%;
        max-width: 600px;
        z-index: 200;
    }

    .search-modal-bar {
        background: #1a1a1a;
        display: flex;
        padding: 15px;
        border-radius: 12px;
        border: 1px solid #333;
        align-items: center;
        color: white;
    }

        .search-modal-bar input {
            flex: 1;
            background: transparent;
            border: none;
            color: white;
            outline: none;
            margin: 0 15px;
            font-size: 18px;
        }

    .join-dropdown {
        position: fixed;
        top: 75px;
        right: 80px;
        background: #222;
        padding: 20px;
        border-radius: 15px;
        border: 1px solid #444;
        z-index: 200;
        width: 400px;
        color: white;
    }

    .input-row-dark {
        display: flex;
        gap: 10px;
        margin: 15px 0;
        background: #000;
        padding: 10px;
        border-radius: 8px;
        align-items: center;
    }

        .input-row-dark input {
            flex: 1;
            background: transparent;
            border: none;
            color: white;
            outline: none;
        }

    .tab-row-dark {
        display: flex;
        gap: 20px;
        border-bottom: 1px solid #444;
        margin-bottom: 15px;
    }

        .tab-row-dark span {
            cursor: pointer;
            color: #888;
            padding-bottom: 5px;
            font-size: 14px;
        }

            .tab-row-dark span.active {
                color: white;
                border-bottom: 2px solid white;
            }

    .submit-join-btn {
        width: 100%;
        background: #444;
        color: white;
        border: none;
        padding: 12px;
        border-radius: 8px;
        cursor: pointer;
    }

    .profile-dropdown {
        position: fixed;
        top: 75px;
        right: 20px;
        background: #1a1a1a;
        border: 1px solid #333;
        border-radius: 12px;
        z-index: 200;
        width: 220px;
        padding: 10px;
        color: white;
    }

    .profile-user-info {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px;
        font-weight: bold;
    }

    .dropdown-divider {
        height: 1px;
        background: #333;
        margin: 5px 0;
    }

    .drop-item {
        padding: 10px;
        color: #ccc;
        cursor: pointer;
        border-radius: 6px;
    }

        .drop-item:hover {
            background: #222;
            color: white;
        }

        .drop-item.logout {
            color: #ff4d4d;
        }
</style>