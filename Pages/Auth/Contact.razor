@page "/contact"
@inject NavigationManager Navigation
@rendermode InteractiveServer

<header class="top-navbar">
    <div class="nav-left">
        <button class="menu-toggle" @onclick="ToggleMenu">☰</button>
        <div class="app-logo"></div>
        <span class="nav-title">Username</span>
    </div>
    <div class="nav-center">
        <div class="search-box" @onclick="ToggleSearch">
            <span class="search-icon">🔍</span>
            <input type="text" placeholder="Search anything..." readonly />
        </div>
    </div>
    <div class="nav-right">
        <button class="btn-join" @onclick="ToggleJoin">+ Join</button>
        <button class="icon-btn" @onclick='() => Navigation.NavigateTo("/noti")'>🔔</button>
        <button class="icon-btn" @onclick="ToggleProfile">👤</button>
    </div>
</header>

    @* --- NỘI DUNG CONTACT (Chiếc điện thoại) --- *@
    <main class="contact-content">
        <div class="skeuomorphic-phone">

            @* --- ỐNG NGHE (HANDSET) --- *@
            <div class="handset-section">
                <div class="handset-handle"></div>
                <div class="phone-cord-long"></div>
            </div>

            @* --- THÂN MÁY (BASE) --- *@
            <div class="base-unit">
                @* Cụm Màn hình LCD *@
                <div class="display-panel">
                    <div class="led-indicators">
                        <span class="led"></span>
                        <span class="led"></span>
                        <span class="led"></span>
                    </div>

                    <div class="lcd-screen">
                        <div class="lcd-inner">
                            <div class="lcd-text">
                                <h2>Contact Us</h2>
                                <button class="email-trigger">Email</button>
                            </div>
                            <div class="lcd-profile-pic">
                                <span class="user-glyph">👤</span>
                            </div>
                        </div>
                    </div>
                </div>

                @* Cụm Phím bấm và Loa *@
                <div class="interaction-area">
                    @* Bàn phím số *@
                    <div class="numpad">
                        @for (int i = 1; i <= 9; i++)
                        {
                            <button class="dial-button">@i</button>
                        }
                        <button class="dial-button">*</button>
                        <button class="dial-button">0</button>
                        <button class="dial-button">#</button>
                    </div>

                    @* Cụm loa và nút chức năng bên phải *@
                    <div class="right-accessory">
                        <div class="speaker-grill-top">
                            <span class="grill-bar"></span>
                            <span class="grill-bar"></span>
                            <span class="grill-bar"></span>
                        </div>
                        <div class="function-knobs">
                            <button class="knob"></button>
                            <button class="knob dark"></button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

@* --- CÁC THÀNH PHẦN UI PHỤ  --- *@

@if (showMenu)
{
    <div class="drawer-menu">
        <div class="drawer-header">
            <i class="user-large-icon">👤</i>
            <button class="close-drawer" @onclick="ToggleMenu">✕</button>
        </div>
        <nav class="drawer-nav">
            <div class="drawer-nav-item" @onclick='() => Navigation.NavigateTo("/")'>⌂ Dashboard</div>
            <div class="drawer-nav-item">✉ Feedback</div>
            <div class="drawer-nav-item">📞 Contact Us</div>
            <div class="nav-divider"></div>
            <div class="nav-label">Top workspaces</div>
            <div class="nav-search-wrap">
                <input type="text" placeholder="Search workspace..." />
            </div>
            <div class="drawer-nav-item small">👤 Project Alpha</div>
            <div class="drawer-nav-item small">👤 Team Beta</div>
        </nav>
    </div>
    <div class="overlay" @onclick="ToggleMenu"></div>
}

@if (showSearch)
{
    <div class="search-modal">
        <div class="search-modal-bar">
            <span>⌕</span>
            <input type="text" placeholder="Search anything..." autofocus />
            <button @onclick="ToggleSearch">✕</button>
        </div>
    </div>
    <div class="overlay" @onclick="ToggleSearch"></div>
}

@if (showJoin)
{
    <div class="join-dropdown">
        <div class="dropdown-header">
            <span style="font-weight: bold;">Join new workspace</span>
            <button @onclick="ToggleJoin" style="background:none; border:none; color:white; cursor:pointer;">✕</button>
        </div>
        <div class="dropdown-body">
            <div class="input-row-dark">
                <i>👤</i>
                <input type="text" placeholder="Username" />
                <button class="copy-btn">⧉</button>
            </div>
            <div class="tab-row-dark">
                <span class="active">HTTPS</span>
                <span>Users</span>
                <span>Workspace ID</span>
            </div>
            <div class="input-row-dark">
                <input type="text" placeholder="Workspace Link/ID" />
                <button class="copy-btn">⧉</button>
            </div>
            <button class="submit-join-btn">Send request to join workspace</button>
        </div>
    </div>
    <div class="overlay transparent" @onclick="ToggleJoin"></div>
}

@if (showProfile)
{
    <div class="profile-dropdown">
        <div class="profile-user-info">
            <i>👤</i>
            <span>Username</span>
        </div>
        <div class="dropdown-divider"></div>
        <div class="drop-item" @onclick='() => Navigation.NavigateTo("/profile-detail")'>👤 Profile</div>
        <div class="drop-item">📁 Workspaces</div>
        <div class="drop-item">✉ Feedback</div>
        <div class="drop-item">⚙ Settings</div>
        <div class="drop-item logout">↪ Sign out</div>
    </div>
    <div class="overlay transparent" @onclick="ToggleProfile"></div>
}

@code {
    private bool showMenu = false;
    private bool showSearch = false;
    private bool showJoin = false;
    private bool showProfile = false;

    private void ToggleMenu() => showMenu = !showMenu;
    private void ToggleSearch() => showSearch = !showSearch;
    private void ToggleJoin() => showJoin = !showJoin;
    private void ToggleProfile() => showProfile = !showProfile;
}

<style>
    :root {
        --dark-bg: #1a1a1a;
        --header-h: 65px;
        --phone-dark: #121212;
    }

    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
        font-family: 'Segoe UI', sans-serif;
    }

    body {
        overflow: hidden;
        background-color: #fff;
    }

    .dashboard-container {
        display: flex;
        flex-direction: column;
        height: 100vh;
    }

    /* --- TOPBAR STYLE --- */
    .top-navbar {
        height: 65px;
        background: #1a1a1a;
        color: white;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 20px;
        z-index: 100;
        position: relative;
    }

    .nav-left {
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .menu-toggle {
        background: none;
        border: none;
        color: white;
        font-size: 22px;
        cursor: pointer;
    }

    .app-logo {
        width: 32px;
        height: 32px;
        background: #444;
        border-radius: 6px;
    }

    .search-box {
        background: #333;
        border-radius: 8px;
        padding: 8px 15px;
        display: flex;
        align-items: center;
        width: 400px;
        cursor: pointer;
    }

        .search-box input {
            background: transparent;
            border: none;
            color: white;
            width: 100%;
            outline: none;
            margin-left: 10px;
        }

    .nav-right {
        display: flex;
        gap: 15px;
        align-items: center;
    }

    .icon-btn {
        background: none;
        border: none;
        color: white;
        font-size: 20px;
        cursor: pointer;
    }

    .btn-join {
        background: transparent;
        border: 1px solid #555;
        color: white;
        padding: 5px 15px;
        border-radius: 6px;
        cursor: pointer;
    }

    /* --- CONTACT CONTENT --- */
    .contact-content {
        flex: 1;
        display: flex;
        justify-content: center;
        align-items: center;
        background: #fcfcfc;
        padding: 20px;
    }

    .skeuomorphic-phone {
        display: flex;
        align-items: flex-end;
        position: relative;
        gap: 15px;
        transform: scale(0.9);
    }

    .handset-handle {
        width: 110px;
        height: 480px;
        background: var(--phone-dark);
        border-radius: 55px;
        box-shadow: -12px 15px 30px rgba(0,0,0,0.3);
        z-index: 5;
    }

    .phone-cord-long {
        width: 80px;
        height: 120px;
        border-left: 3px solid var(--phone-dark);
        border-bottom: 3px solid var(--phone-dark);
        border-radius: 0 0 0 45px;
        margin-top: -30px;
        margin-left: 20px;
    }

    .base-unit {
        width: 680px;
        background: #ffffff;
        border: 2px solid var(--phone-dark);
        border-radius: 45px;
        padding: 45px;
        box-shadow: 20px 25px 0px rgba(0,0,0,0.03);
        display: flex;
        flex-direction: column;
        gap: 40px;
    }

    .display-panel {
        background: #444;
        border-radius: 25px;
        padding: 18px;
        display: flex;
        gap: 15px;
        box-shadow: inset 0 2px 8px rgba(0,0,0,0.4);
    }

    .led {
        width: 40px;
        height: 12px;
        background: #666;
        border-radius: 3px;
    }

    .lcd-screen {
        flex: 1;
        background: white;
        border-radius: 15px;
        padding: 20px 35px;
        box-shadow: inset 2px 2px 5px rgba(0,0,0,0.1);
    }

    .lcd-inner {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .lcd-text h2 {
        font-size: 2.4rem;
        font-weight: 900;
        margin: 0;
    }

    .email-trigger {
        background: var(--phone-dark);
        color: white;
        border: none;
        padding: 10px 40px;
        border-radius: 25px;
        font-weight: bold;
        margin-top: 10px;
        cursor: pointer;
    }

    .lcd-profile-pic {
        width: 100px;
        height: 100px;
        background: #e0e0e0;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 3rem;
    }

    .interaction-area {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
    }

    .numpad {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
    }

    .dial-button {
        width: 70px;
        height: 70px;
        border: 2.5px solid var(--phone-dark);
        background: white;
        border-radius: 50%;
        font-size: 1.5rem;
        font-weight: 900;
        cursor: pointer;
        transition: 0.15s;
        box-shadow: 0 5px 0 var(--phone-dark);
    }

        .dial-button:active {
            transform: translateY(4px);
            box-shadow: 0 1px 0 var(--phone-dark);
        }

    .right-accessory {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 50px;
    }

    .speaker-grill-top {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .grill-bar {
        width: 90px;
        height: 10px;
        background: var(--phone-dark);
        border-radius: 10px;
    }

    .function-knobs {
        display: flex;
        flex-direction: column;
        gap: 25px;
    }

    .knob {
        width: 50px;
        height: 50px;
        border: 2.5px solid var(--phone-dark);
        border-radius: 50%;
        background: #eee;
        cursor: pointer;
    }

        .knob.dark {
            background: #444;
        }

    /* --- COMMON UI OVERLAYS  --- */
    .overlay {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.5);
        z-index: 150;
    }

        .overlay.transparent {
            background: transparent;
        }

    .drawer-menu {
        position: fixed;
        top: 0;
        left: 0;
        width: 280px;
        height: 100%;
        background: #000;
        color: white;
        z-index: 200;
        padding: 20px;
    }

    .drawer-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
    }

    .user-large-icon {
        font-size: 40px;
    }

    .close-drawer {
        background: transparent;
        border: none;
        color: white;
        font-size: 20px;
        cursor: pointer;
    }

    .drawer-nav-item {
        padding: 12px;
        color: #ccc;
        cursor: pointer;
        border-radius: 8px;
        font-size: 16px;
    }

        .drawer-nav-item:hover {
            background: #222;
            color: white;
        }

    .nav-divider {
        height: 1px;
        background: #333;
        margin: 15px 0;
    }

    .nav-label {
        color: #666;
        font-size: 12px;
        text-transform: uppercase;
        margin-bottom: 10px;
    }

    .nav-search-wrap input {
        width: 100%;
        background: #222;
        border: 1px solid #444;
        padding: 8px;
        color: white;
        border-radius: 4px;
        margin-bottom: 10px;
    }

    .search-modal {
        position: fixed;
        top: 20px;
        left: 50%;
        transform: translateX(-50%);
        width: 90%;
        max-width: 600px;
        z-index: 200;
    }

    .search-modal-bar {
        background: #1a1a1a;
        display: flex;
        padding: 15px;
        border-radius: 12px;
        border: 1px solid #333;
        align-items: center;
        color: white;
    }

        .search-modal-bar input {
            flex: 1;
            background: transparent;
            border: none;
            color: white;
            outline: none;
            margin: 0 15px;
            font-size: 18px;
        }

    .join-dropdown {
        position: fixed;
        top: 75px;
        right: 80px;
        background: #222;
        padding: 20px;
        border-radius: 15px;
        border: 1px solid #444;
        z-index: 200;
        width: 400px;
        color: white;
    }

    .input-row-dark {
        display: flex;
        gap: 10px;
        margin: 15px 0;
        background: #000;
        padding: 10px;
        border-radius: 8px;
        align-items: center;
    }

        .input-row-dark input {
            flex: 1;
            background: transparent;
            border: none;
            color: white;
            outline: none;
        }

    .tab-row-dark {
        display: flex;
        gap: 20px;
        border-bottom: 1px solid #444;
        margin-bottom: 15px;
    }

        .tab-row-dark span {
            cursor: pointer;
            color: #888;
            padding-bottom: 5px;
            font-size: 14px;
        }

            .tab-row-dark span.active {
                color: white;
                border-bottom: 2px solid white;
            }

    .submit-join-btn {
        width: 100%;
        background: #444;
        color: white;
        border: none;
        padding: 12px;
        border-radius: 8px;
        cursor: pointer;
    }

    .profile-dropdown {
        position: fixed;
        top: 75px;
        right: 20px;
        background: #1a1a1a;
        border: 1px solid #333;
        border-radius: 12px;
        z-index: 200;
        width: 220px;
        padding: 10px;
        color: white;
    }

    .profile-user-info {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px;
        font-weight: bold;
    }

    .dropdown-divider {
        height: 1px;
        background: #333;
        margin: 5px 0;
    }

    .drop-item {
        padding: 10px;
        color: #ccc;
        cursor: pointer;
        border-radius: 6px;
    }

        .drop-item:hover {
            background: #222;
            color: white;
        }

        .drop-item.logout {
            color: #ff4d4d;
        }
</style>