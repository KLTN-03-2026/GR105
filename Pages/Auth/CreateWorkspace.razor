@page "/create-workspace"
@inject NavigationManager Navigation
@rendermode InteractiveServer

<header class="top-navbar">
    <div class="nav-left">
        <button class="menu-toggle" @onclick="ToggleMenu">☰</button>
        <div class="app-logo"></div>
        <span class="nav-title">Username</span>
    </div>
    <div class="nav-center">
        <div class="search-box" @onclick="ToggleSearch">
            <span class="search-icon">🔍</span>
            <input type="text" placeholder="Search anything..." readonly />
        </div>
    </div>
    <div class="nav-right">
        <button class="btn-join" @onclick="ToggleJoin">+ Join</button>
        <button class="icon-btn" @onclick='() => Navigation.NavigateTo("/noti")'>🔔</button>
        <button class="icon-btn" @onclick="ToggleProfile">👤</button>
    </div>
</header>

    <main class="stepper-viewport">
        <div class="create-ws-card">
            <h1 class="form-main-title">Create Workspace</h1>

            <div class="stepper-container">
                @* STEP 1 *@
                <div class="step-item">
                    <div class="step-line-wrapper">
                        <div class="step-number">1</div>
                        <div class="vertical-line"></div>
                    </div>
                    <div class="step-content">
                        <h2 class="step-title">General</h2>
                        <div class="input-group">
                            <label class="input-label">Workspace Name</label>
                            <input type="text" class="form-control-ws" placeholder="E.g. My Awesome Team" />
                            <span class="input-hint">*Workspace name must be unique</span>
                        </div>
                        <div class="input-group">
                            <label class="input-label">Description</label>
                            <textarea class="form-control-ws textarea-ws" rows="3" placeholder="What is this workspace about?"></textarea>
                            <span class="input-hint">0/200 characters</span>
                        </div>
                    </div>
                </div>

                @* STEP 2 *@
                <div class="step-item">
                    <div class="step-line-wrapper">
                        <div class="step-number">2</div>
                        <div class="vertical-line"></div>
                    </div>
                    <div class="step-content">
                        <h2 class="step-title">Configuration</h2>
                        <div class="config-row">
                            <div class="config-text">
                                <label class="input-label">Choose Visibility</label>
                                <span class="input-hint">Control who can access this workspace</span>
                            </div>
                            <button class="btn-visibility-dropdown">
                                📁 Private <span style="font-size: 0.8rem">▼</span>
                            </button>
                        </div>
                    </div>
                </div>

                @* STEP 3 *@
                <div class="step-item">
                    <div class="step-line-wrapper">
                        <div class="step-number">3</div>
                    </div>
                    <div class="step-content">
                        <button class="btn-create-final">Create Now</button>
                    </div>
                </div>
            </div>
        </div>
    </main>


@* --- UI OVERLAYS (MENU, SEARCH, JOIN, PROFILE) --- *@

@if (showMenu)
{
    <div class="drawer-menu">
        <div class="drawer-header">
            <i class="user-large-icon">👤</i>
            <button class="close-drawer" @onclick="ToggleMenu">✕</button>
        </div>
        <nav class="drawer-nav">
            <div class="drawer-nav-item" @onclick='() => Navigation.NavigateTo("/")'>⌂ Dashboard</div>
            <div class="drawer-nav-item">✉ Feedback</div>
            <div class="drawer-nav-item">📞 Contact Us</div>
            <div class="nav-divider"></div>
            <div class="nav-label">Top workspaces</div>
            <div class="nav-search-wrap">
                <input type="text" placeholder="Search workspace..." />
            </div>
            <div class="drawer-nav-item small">👤 Project Alpha</div>
            <div class="drawer-nav-item small">👤 Team Beta</div>
        </nav>
    </div>
    <div class="overlay" @onclick="ToggleMenu"></div>
}

@if (showSearch)
{
    <div class="search-modal">
        <div class="search-modal-bar">
            <span>⌕</span>
            <input type="text" placeholder="Search anything..." autofocus />
            <button @onclick="ToggleSearch">✕</button>
        </div>
    </div>
    <div class="overlay" @onclick="ToggleSearch"></div>
}

@if (showJoin)
{
    <div class="join-dropdown">
        <div class="dropdown-header">
            <span style="font-weight: bold;">Join new workspace</span>
            <button @onclick="ToggleJoin" style="background:none; border:none; color:white; cursor:pointer;">✕</button>
        </div>
        <div class="dropdown-body">
            <div class="input-row-dark">
                <i>👤</i>
                <input type="text" placeholder="Username" />
                <button class="copy-btn">⧉</button>
            </div>
            <div class="tab-row-dark">
                <span class="active">HTTPS</span>
                <span>Users</span>
                <span>Workspace ID</span>
            </div>
            <div class="input-row-dark">
                <input type="text" placeholder="Workspace Link/ID" />
                <button class="copy-btn">⧉</button>
            </div>
            <button class="submit-join-btn">Send request to join workspace</button>
        </div>
    </div>
    <div class="overlay transparent" @onclick="ToggleJoin"></div>
}

@if (showProfile)
{
    <div class="profile-dropdown">
        <div class="profile-user-info">
            <i>👤</i>
            <span>Username</span>
        </div>
        <div class="dropdown-divider"></div>
        <div class="drop-item" @onclick='() => Navigation.NavigateTo("/profile-detail")'>👤 Profile</div>
        <div class="drop-item">📁 Workspaces</div>
        <div class="drop-item">✉ Feedback</div>
        <div class="drop-item">⚙ Settings</div>
        <div class="drop-item logout">↪ Sign out</div>
    </div>
    <div class="overlay transparent" @onclick="ToggleProfile"></div>
}

@code {
    private bool showMenu = false;
    private bool showSearch = false;
    private bool showJoin = false;
    private bool showProfile = false;

    private void ToggleMenu() => showMenu = !showMenu;
    private void ToggleSearch() => showSearch = !showSearch;
    private void ToggleJoin() => showJoin = !showJoin;
    private void ToggleProfile() => showProfile = !showProfile;
}
<style>
    :root {
        --dark-bg: #1a1a1a;
        --header-h: 65px;
        --brutalist-border: 3px solid #000;
        --brutalist-shadow: 10px 10px 0px #000;
        --phone-dark: #121212;
    }

    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
        font-family: 'Segoe UI', sans-serif;
    }

    body {
        overflow: hidden;
        background-color: #f5f5f5;
    }

    .dashboard-container {
        display: flex;
        flex-direction: column;
        height: 100vh;
    }

    /* --- TOPBAR STYLE (Đã đồng bộ) --- */
    .top-navbar {
        height: 65px;
        background: #1a1a1a;
        color: white;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 20px;
        z-index: 100;
        position: relative;
    }

    .nav-left {
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .menu-toggle {
        background: none;
        border: none;
        color: white;
        font-size: 22px;
        cursor: pointer;
    }

    .app-logo {
        width: 32px;
        height: 32px;
        background: #444;
        border-radius: 6px;
    }

    .search-box {
        background: #333;
        border-radius: 8px;
        padding: 8px 15px;
        display: flex;
        align-items: center;
        width: 400px;
        cursor: pointer;
    }

        .search-box input {
            background: transparent;
            border: none;
            color: white;
            width: 100%;
            outline: none;
            margin-left: 10px;
        }

    .nav-right {
        display: flex;
        gap: 15px;
        align-items: center;
    }

    .icon-btn {
        background: none;
        border: none;
        color: white;
        font-size: 20px;
        cursor: pointer;
    }

    .btn-join {
        background: transparent;
        border: 1px solid #555;
        color: white;
        padding: 5px 15px;
        border-radius: 6px;
        cursor: pointer;
    }

    .stepper-viewport {
        flex: 1;
        display: flex;
        justify-content: center;
        overflow-y: auto;
        padding: 60px 20px;
        background: #fcfcfc;
    }

    .create-ws-card {
        background: white;
        width: 100%;
        max-width: 680px; 
        border: var(--brutalist-border);
        border-radius: 45px; 
        padding: 50px;
        box-shadow: var(--brutalist-shadow);
        height: fit-content;
    }

    .form-main-title {
        text-align: center;
        font-size: 2.4rem;
        font-weight: 900;
        margin-bottom: 50px;
        text-transform: uppercase;
        letter-spacing: -1px;
    }

    .stepper-container {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .step-item {
        display: flex;
        gap: 30px;
    }

    .step-line-wrapper {
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .step-number {
        width: 55px;
        height: 55px;
        background: var(--phone-dark);
        color: #fff;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 900;
        font-size: 1.5rem;
        z-index: 2;
        box-shadow: 0 4px 0px rgba(0,0,0,0.2);
    }

    .vertical-line {
        flex: 1;
        width: 4px;
        background: var(--phone-dark);
        margin: 5px 0;
    }

    .step-content {
        flex: 1;
        padding-bottom: 40px;
    }

    .step-title {
        font-size: 1.8rem;
        font-weight: 900;
        margin-bottom: 25px;
        border-bottom: 5px solid var(--phone-dark);
        display: inline-block;
    }

    .input-group {
        margin-bottom: 25px;
    }

    .input-label {
        display: block;
        font-weight: 800;
        font-size: 1.1rem;
        margin-bottom: 10px;
    }

    .form-control-ws {
        width: 100%;
        padding: 15px;
        border: 2.5px solid var(--phone-dark);
        border-radius: 12px;
        font-size: 1.1rem;
        outline: none;
        font-weight: 600;
        transition: 0.2s;
    }

        .form-control-ws:focus {
            background: #fffcf0;
            box-shadow: 4px 4px 0px var(--phone-dark);
        }

    .textarea-ws {
        resize: none;
    }

    .input-hint {
        display: block;
        font-size: 0.9rem;
        color: #666;
        margin-top: 8px;
        font-weight: 600;
    }

    .config-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: #f9f9f9;
        padding: 20px;
        border-radius: 15px;
        border: 2px dashed #ccc;
    }

    .btn-visibility-dropdown {
        background: var(--phone-dark);
        color: #fff;
        border: none;
        padding: 12px 25px;
        border-radius: 25px;
        font-weight: 800;
        display: flex;
        align-items: center;
        gap: 10px;
        cursor: pointer;
    }

    .btn-create-final {
        width: 100%;
        background: var(--phone-dark);
        color: #fff;
        border: none;
        padding: 20px;
        font-size: 1.6rem;
        font-weight: 900;
        border-radius: 30px;
        cursor: pointer;
        transition: 0.2s;
        text-transform: uppercase;
        box-shadow: 0 8px 0px #444;
    }

        .btn-create-final:active {
            transform: translateY(4px);
            box-shadow: 0 2px 0px #444;
        }

    .overlay {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.5);
        z-index: 150;
    }

        .overlay.transparent {
            background: transparent;
        }

    .drawer-menu {
        position: fixed;
        top: 0;
        left: 0;
        width: 280px;
        height: 100%;
        background: #000;
        color: white;
        z-index: 200;
        padding: 20px;
    }

    .drawer-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
    }

    .user-large-icon {
        font-size: 40px;
    }

    .close-drawer {
        background: transparent;
        border: none;
        color: white;
        font-size: 20px;
        cursor: pointer;
    }

    .drawer-nav-item {
        padding: 12px;
        color: #ccc;
        cursor: pointer;
        border-radius: 8px;
        font-size: 16px;
    }

        .drawer-nav-item:hover {
            background: #222;
            color: white;
        }

    .nav-divider {
        height: 1px;
        background: #333;
        margin: 15px 0;
    }

    .nav-label {
        color: #666;
        font-size: 12px;
        text-transform: uppercase;
        margin-bottom: 10px;
    }

    .nav-search-wrap input {
        width: 100%;
        background: #222;
        border: 1px solid #444;
        padding: 8px;
        color: white;
        border-radius: 4px;
        margin-bottom: 10px;
    }

    .search-modal {
        position: fixed;
        top: 20px;
        left: 50%;
        transform: translateX(-50%);
        width: 90%;
        max-width: 600px;
        z-index: 200;
    }

    .search-modal-bar {
        background: #1a1a1a;
        display: flex;
        padding: 15px;
        border-radius: 12px;
        border: 1px solid #333;
        align-items: center;
        color: white;
    }

        .search-modal-bar input {
            flex: 1;
            background: transparent;
            border: none;
            color: white;
            outline: none;
            margin: 0 15px;
            font-size: 18px;
        }

    .join-dropdown {
        position: fixed;
        top: 75px;
        right: 80px;
        background: #222;
        padding: 20px;
        border-radius: 15px;
        border: 1px solid #444;
        z-index: 200;
        width: 400px;
        color: white;
    }

    .input-row-dark {
        display: flex;
        gap: 10px;
        margin: 15px 0;
        background: #000;
        padding: 10px;
        border-radius: 8px;
        align-items: center;
    }

        .input-row-dark input {
            flex: 1;
            background: transparent;
            border: none;
            color: white;
            outline: none;
        }

    .tab-row-dark {
        display: flex;
        gap: 20px;
        border-bottom: 1px solid #444;
        margin-bottom: 15px;
    }

        .tab-row-dark span {
            cursor: pointer;
            color: #888;
            padding-bottom: 5px;
            font-size: 14px;
        }

            .tab-row-dark span.active {
                color: white;
                border-bottom: 2px solid white;
            }

    .submit-join-btn {
        width: 100%;
        background: #444;
        color: white;
        border: none;
        padding: 12px;
        border-radius: 8px;
        cursor: pointer;
    }

    .profile-dropdown {
        position: fixed;
        top: 75px;
        right: 20px;
        background: #1a1a1a;
        border: 1px solid #333;
        border-radius: 12px;
        z-index: 200;
        width: 220px;
        padding: 10px;
        color: white;
    }

    .profile-user-info {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px;
        font-weight: bold;
    }

    .dropdown-divider {
        height: 1px;
        background: #333;
        margin: 5px 0;
    }

    .drop-item {
        padding: 10px;
        color: #ccc;
        cursor: pointer;
        border-radius: 6px;
    }

        .drop-item:hover {
            background: #222;
            color: white;
        }

        .drop-item.logout {
            color: #ff4d4d;
        }

<!-- SECTION 4: LOGIC -->

@if (showMenu)
{
    <div class="drawer-menu">
        <div class="drawer-header">
            <i class="user-large-icon">👤</i>
            <button class="close-drawer" @onclick="ToggleMenu">✕</button>
        </div>
        <nav class="drawer-nav">
            <div class="drawer-nav-item" @onclick='() => Navigation.NavigateTo("/")'>⌂ Dashboard</div>
            <div class="drawer-nav-item">✉ Feedback</div>
            <div class="drawer-nav-item">📞 Contact Us</div>
            <div class="nav-divider"></div>
            <div class="nav-label">Top workspaces</div>
            <div class="nav-search-wrap">
                <input type="text" placeholder="Search workspace..." />
            </div>
            <div class="drawer-nav-item small">👤 Project Alpha</div>
            <div class="drawer-nav-item small">👤 Team Beta</div>
        </nav>
    </div>
    <div class="overlay" @onclick="ToggleMenu"></div>
}

@if (showSearch)
{
    <div class="search-modal">
        <div class="search-modal-bar">
            <span>⌕</span>
            <input type="text" placeholder="Search anything..." autofocus />
            <button @onclick="ToggleSearch">✕</button>
        </div>
    </div>
    <div class="overlay" @onclick="ToggleSearch"></div>
}

@if (showJoin)
{
    <div class="join-dropdown">
        <div class="dropdown-header">
            <span style="font-weight: bold;">Join new workspace</span>
            <button @onclick="ToggleJoin" style="background:none; border:none; color:white; cursor:pointer;">✕</button>
        </div>
        <div class="dropdown-body">
            <div class="input-row-dark">
                <i>👤</i>
                <input type="text" placeholder="Username" />
                <button class="copy-btn">⧉</button>
            </div>
            <div class="tab-row-dark">
                <span class="active">HTTPS</span>
                <span>Users</span>
                <span>Workspace ID</span>
            </div>
            <div class="input-row-dark">
                <input type="text" placeholder="Workspace Link/ID" />
                <button class="copy-btn">⧉</button>
            </div>
            <button class="submit-join-btn">Send request to join workspace</button>
        </div>
    </div>
    <div class="overlay transparent" @onclick="ToggleJoin"></div>
}
</style>