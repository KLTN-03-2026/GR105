@page "/upload"
@inject NavigationManager Navigation
@rendermode InteractiveServer

<div class="app-wrapper">
    @* --- TOPBAR (Gốc) --- *@
    <header class="top-navbar">
        <div class="nav-left">
            <button class="menu-toggle" @onclick="ToggleMenu">☰</button>
            <div class="app-logo"></div>
            <span class="nav-title">Username</span>
        </div>
        <div class="nav-center">
            <div class="search-box" @onclick="ToggleSearch">
                <span class="search-icon">🔍</span>
                <input type="text" placeholder="Search anything..." readonly />
            </div>
        </div>
        <div class="nav-right">
            <button class="btn-join" @onclick="ToggleJoin">+ Join</button>
            <button class="icon-btn" @onclick='() => Navigation.NavigateTo("/noti")'>🔔</button>
            <button class="icon-btn" @onclick="ToggleProfile">👤</button>
        </div>
    </header>

    @* --- TAB NAVIGATION (Gốc) --- *@
    <nav class="sub-nav">
        <div class="tab-btn">📄 Document</div>
        <div class="tab-btn active">✉ Feedback</div>
        <div class="tab-btn">🕒 Versioning</div>
        <div class="tab-btn">📋 Logs</div>
        <div class="tab-btn">⚙ Settings</div>
    </nav>

    <main class="content-area">
        <div class="content-body">
            <h3 class="directory-title">Directory /</h3>

            @* Upload Zone (Gốc - thêm logic Drag) *@
            <div class="upload-zone" @ondragover:preventDefault @ondragenter="() => isDragOver = true" @ondragleave="() => isDragOver = false" @ondrop="HandleDrop">
                <div class="upload-content">
                    <i class="far fa-file"></i>
                    <p>Drag files here to add them to your workspace</p>
                    <span>Or <label for="fileInput" class="browse-link">choose your file</label></span>
                    <InputFile id="fileInput" OnChange="HandleFileSelected" Multiple style="display:none" />
                </div>
            </div>

            @* --- FILE LIST  --- *@
            @if (selectedFiles.Any())
            {
                <div class="file-list-container">
                    @foreach (var file in selectedFiles)
                    {
                        <div class="file-item">
                            <div class="file-item-left">
                                <i class="far fa-file"></i>
                                <span class="file-name">@file.Name</span>
                            </div>
                            <button class="remove-file-btn" @onclick="() => RemoveFile(file)">✕</button>
                        </div>
                    }
                </div>
            }

            @* Form Fields  *@
            <div class="form-container">
                <div class="input-group">
                    <i class="far fa-user profile-icon"></i>
                    <div class="fields">
                        <input type="text" placeholder="Update name" class="form-input" @bind="updateName" />
                        <textarea placeholder="Update description" class="form-textarea" @bind="updateDescription"></textarea>
                    </div>
                </div>
            </div>

            @* Action Buttons  *@
            <div class="action-footer">
                <button class="btn btn-submit" @onclick="OnSubmit">Submit</button>
                <button class="btn btn-cancel" @onclick="OnCancel">Cancel</button>
            </div>
        </div>
    </main>

    @* --- OVERLAYS  --- *@
    @if (showMenu)
    {
        <div class="drawer-menu">
            <div class="drawer-header">
                <i class="user-large-icon">👤</i>
                <button class="close-drawer" @onclick="ToggleMenu">✕</button>
            </div>
            <nav class="drawer-nav">
                <div class="drawer-nav-item" @onclick='() => Navigation.NavigateTo("/")'>⌂ Dashboard</div>
                <div class="drawer-nav-item">✉ Feedback</div>
                <div class="drawer-nav-item">📞 Contact Us</div>
                <div class="nav-divider"></div>
                <div class="nav-label">Top workspaces</div>
                <div class="nav-search-wrap">
                    <input type="text" placeholder="Search workspace..." />
                </div>
                <div class="drawer-nav-item small">👤 Project Alpha</div>
                <div class="drawer-nav-item small">👤 Team Beta</div>
            </nav>
        </div>
        <div class="overlay" @onclick="ToggleMenu"></div>
    }

    @if (showSearch)
    {
        <div class="search-modal">
            <div class="search-modal-bar">
                <span>⌕</span>
                <input type="text" placeholder="Search anything..." autofocus />
                <button @onclick="ToggleSearch">✕</button>
            </div>
        </div>
        <div class="overlay" @onclick="ToggleSearch"></div>
    }

    @if (showJoin)
    {
        <div class="join-dropdown">
            <div class="dropdown-header">
                <span style="font-weight: bold;">Join new workspace</span>
                <button @onclick="ToggleJoin" style="background:none; border:none; color:white; cursor:pointer;">✕</button>
            </div>
            <div class="dropdown-body">
                <div class="input-row-dark">
                    <i>👤</i>
                    <input type="text" placeholder="Username" />
                    <button class="copy-btn">⧉</button>
                </div>
                <div class="tab-row-dark">
                    <span class="active">HTTPS</span>
                    <span>Users</span>
                    <span>Workspace ID</span>
                </div>
                <div class="input-row-dark">
                    <input type="text" placeholder="Workspace Link/ID" />
                    <button class="copy-btn">⧉</button>
                </div>
                <button class="submit-join-btn">Send request to join workspace</button>
            </div>
        </div>
        <div class="overlay transparent" @onclick="ToggleJoin"></div>
    }

    @if (showProfile)
    {
        <div class="profile-dropdown">
            <div class="profile-user-info">
                <i>👤</i>
                <span>Username</span>
            </div>
            <div class="dropdown-divider"></div>
            <div class="drop-item" @onclick='() => Navigation.NavigateTo("/profile-detail")'>👤 Profile</div>
            <div class="drop-item">📁 Workspaces</div>
            <div class="drop-item">✉ Feedback</div>
            <div class="drop-item">⚙ Settings</div>
            <div class="drop-item logout">↪ Sign out</div>
        </div>
        <div class="overlay transparent" @onclick="ToggleProfile"></div>
    }
</div>

@code {
    private bool showMenu = false;
    private bool showSearch = false;
    private bool showJoin = false;
    private bool showProfile = false;

    
    private string updateName = "";
    private string updateDescription = "";
    private List<IBrowserFile> selectedFiles = new();
    private bool isDragOver = false;

    private void ToggleMenu() => showMenu = !showMenu;
    private void ToggleSearch() => showSearch = !showSearch;
    private void ToggleJoin() => showJoin = !showJoin;
    private void ToggleProfile() => showProfile = !showProfile;

    private void HandleFileSelected(InputFileChangeEventArgs e)
    {
        foreach (var file in e.GetMultipleFiles())
        {
            selectedFiles.Add(file);
        }
    }

    private void HandleDrop(DragEventArgs e)
    {
        isDragOver = false;
        
    }

    private void RemoveFile(IBrowserFile file) => selectedFiles.Remove(file);

    private void OnSubmit()
    {
        
        Console.WriteLine($"Submit {selectedFiles.Count} files");
    }

    private void OnCancel()
    {
        selectedFiles.Clear();
        updateName = "";
        updateDescription = "";
    }
}

<style>
    
    :root {
        --dark-bg: #1e1e1e;
        --nav-bg: #2d2d2d;
        --text-white: #ffffff;
        --border-color: #333;
        --accent-blue: #4a90e2;
    }

    .app-wrapper {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        background-color: #fff;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
    }

    .top-navbar {
        height: 65px;
        background: #1a1a1a;
        color: white;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 20px;
        z-index: 100;
        position: relative;
    }

    .nav-left {
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .menu-toggle {
        background: none;
        border: none;
        color: white;
        font-size: 22px;
        cursor: pointer;
    }

    .app-logo {
        width: 32px;
        height: 32px;
        background: #444;
        border-radius: 6px;
    }

    .search-box {
        background: #333;
        border-radius: 8px;
        padding: 8px 15px;
        display: flex;
        align-items: center;
        width: 400px;
        cursor: pointer;
    }

        .search-box input {
            background: transparent;
            border: none;
            color: white;
            width: 100%;
            outline: none;
            margin-left: 10px;
        }

    .nav-right {
        display: flex;
        gap: 15px;
        align-items: center;
    }

    .icon-btn {
        background: none;
        border: none;
        color: white;
        font-size: 20px;
        cursor: pointer;
    }

    .btn-join {
        background: transparent;
        border: 1px solid #555;
        color: white;
        padding: 5px 15px;
        border-radius: 6px;
        cursor: pointer;
    }

    .sub-nav {
        background-color: var(--nav-bg);
        padding: 8px 16px;
        display: flex;
        gap: 20px;
        border-top: 1px solid #444;
    }

    .tab-btn {
        background: transparent;
        border: none;
        color: #aaa;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 14px;
        padding: 6px 12px;
    }

        .tab-btn.active {
            background: white;
            color: black;
            border-radius: 8px;
        }

    .content-body {
        padding: 24px 40px;
    }

    .directory-title {
        font-weight: bold;
        margin-bottom: 20px;
    }

    .upload-zone {
        border: 1.5px dashed #000;
        border-radius: 12px;
        padding: 60px;
        text-align: center;
        margin-bottom: 24px;
        transition: background 0.3s;
    }

        .upload-zone:hover {
            background: #f9f9f9;
        }

    .upload-content i {
        font-size: 40px;
        margin-bottom: 12px;
    }

    .upload-content p {
        font-weight: bold;
        font-size: 18px;
        margin: 8px 0;
    }

    .browse-link {
        color: blue;
        text-decoration: underline;
        cursor: pointer;
    }

    
    .file-list-container {
        display: flex;
        flex-direction: column;
        margin-bottom: 24px;
    }

    .file-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 12px 20px;
        border: 1px solid #000;
        border-radius: 8px;
        margin-bottom: 8px;
        background: #fff;
    }

    .file-item-left {
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .remove-file-btn {
        background: none;
        border: none;
        cursor: pointer;
        font-size: 18px;
        color: #666;
    }

    /* TIẾP TỤC STYLE GỐC */
    .form-container {
        display: flex;
        align-items: flex-start;
        gap: 15px;
        margin-top: 20px;
    }

    .profile-icon {
        font-size: 24px;
        color: #555;
        padding-top: 8px;
    }

    .fields {
        flex-grow: 1;
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .form-input, .form-textarea {
        width: 100%;
        border: 1px solid #ccc;
        padding: 10px;
        border-radius: 4px;
        outline: none;
    }

    .form-textarea {
        height: 100px;
        resize: vertical;
    }

    .action-footer {
        margin-left: 40px;
        margin-top: 20px;
        display: flex;
        gap: 12px;
    }

    .btn {
        padding: 8px 24px;
        border-radius: 6px;
        font-weight: bold;
        cursor: pointer;
        border: none;
    }

    .btn-submit {
        background-color: #222;
        color: white;
    }

    .btn-cancel {
        background-color: #eee;
        color: #333;
    }

    
    .overlay {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.5);
        z-index: 150;
    }

        .overlay.transparent {
            background: transparent;
        }

    .drawer-menu {
        position: fixed;
        top: 0;
        left: 0;
        width: 280px;
        height: 100%;
        background: #000;
        color: white;
        z-index: 200;
        padding: 20px;
    }

    .drawer-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
    }

    .user-large-icon {
        font-size: 40px;
    }

    .close-drawer {
        background: transparent;
        border: none;
        color: white;
        font-size: 20px;
        cursor: pointer;
    }

    .drawer-nav-item {
        padding: 12px;
        color: #ccc;
        cursor: pointer;
        border-radius: 8px;
        font-size: 16px;
    }

        .drawer-nav-item:hover {
            background: #222;
            color: white;
        }

    .nav-divider {
        height: 1px;
        background: #333;
        margin: 15px 0;
    }

    .nav-label {
        color: #666;
        font-size: 12px;
        text-transform: uppercase;
        margin-bottom: 10px;
    }

    .nav-search-wrap input {
        width: 100%;
        background: #222;
        border: 1px solid #444;
        padding: 8px;
        color: white;
        border-radius: 4px;
        margin-bottom: 10px;
    }

    .search-modal {
        position: fixed;
        top: 20px;
        left: 50%;
        transform: translateX(-50%);
        width: 90%;
        max-width: 600px;
        z-index: 200;
    }

    .search-modal-bar {
        background: #1a1a1a;
        display: flex;
        padding: 15px;
        border-radius: 12px;
        border: 1px solid #333;
        align-items: center;
        color: white;
    }

        .search-modal-bar input {
            flex: 1;
            background: transparent;
            border: none;
            color: white;
            outline: none;
            margin: 0 15px;
            font-size: 18px;
        }

    .join-dropdown {
        position: fixed;
        top: 75px;
        right: 80px;
        background: #222;
        padding: 20px;
        border-radius: 15px;
        border: 1px solid #444;
        z-index: 200;
        width: 400px;
        color: white;
    }

    .input-row-dark {
        display: flex;
        gap: 10px;
        margin: 15px 0;
        background: #000;
        padding: 10px;
        border-radius: 8px;
        align-items: center;
    }

        .input-row-dark input {
            flex: 1;
            background: transparent;
            border: none;
            color: white;
            outline: none;
        }

    .tab-row-dark {
        display: flex;
        gap: 20px;
        border-bottom: 1px solid #444;
        margin-bottom: 15px;
    }

        .tab-row-dark span {
            cursor: pointer;
            color: #888;
            padding-bottom: 5px;
            font-size: 14px;
        }

            .tab-row-dark span.active {
                color: white;
                border-bottom: 2px solid white;
            }

    .submit-join-btn {
        width: 100%;
        background: #444;
        color: white;
        border: none;
        padding: 12px;
        border-radius: 8px;
        cursor: pointer;
    }

    .profile-dropdown {
        position: fixed;
        top: 75px;
        right: 20px;
        background: #1a1a1a;
        border: 1px solid #333;
        border-radius: 12px;
        z-index: 200;
        width: 220px;
        padding: 10px;
        color: white;
    }

    .profile-user-info {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px;
        font-weight: bold;
    }

    .dropdown-divider {
        height: 1px;
        background: #333;
        margin: 5px 0;
    }

    .drop-item {
        padding: 10px;
        color: #ccc;
        cursor: pointer;
        border-radius: 6px;
    }

        .drop-item:hover {
            background: #222;
            color: white;
        }

        .drop-item.logout {
            color: #ff4d4d;
        }
</style>