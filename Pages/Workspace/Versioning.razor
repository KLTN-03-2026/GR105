@page "/versioning"
@inject NavigationManager Navigation
@rendermode InteractiveServer

<div class="workspace-container">
    <!-- SECTION 1: TOP NAVIGATION BAR -->
    <header class="top-navbar">
        <div class="nav-left">
            <button class="menu-toggle" @onclick="ToggleMenu">☰</button>
            <div class="app-logo"></div>
            <span class="nav-title">Username</span>
        </div>
        <div class="nav-center">
            <div class="search-box" @onclick="ToggleSearch">
                <span class="search-icon">🔍</span>
                <input type="text" placeholder="Search anything..." readonly />
            </div>
        </div>
        <div class="nav-right">
            <button class="btn-join" @onclick="ToggleJoin">+ Join</button>
            <button class="icon-btn" @onclick='() => Navigation.NavigateTo("/noti")'>🔔</button>
            <button class="icon-btn" @onclick="ToggleProfile">👤</button>
        </div>
    </header>

    <!-- SECTION 2: SUB-TAB NAVIGATION -->
    <nav class="sub-nav">
        <div class="nav-links">
            <a href="#"><i class="oi oi-file"></i> Document</a>
            <a href="#"><i class="oi oi-envelope-closed"></i> Feedback</a>
            <a href="#" class="active"><i class="oi oi-layers"></i> Versioning</a>
            <a href="#"><i class="oi oi-list"></i> Logs</a>
            <a href="#"><i class="oi oi-cog"></i> Settings</a>
        </div>
    </nav>

    <!-- SECTION 3: ACTION CONTROLS -->
    <section class="action-bar">
        <div class="toggle-group">
            <button class="toggle-btn active">Version</button>
            <button class="toggle-btn">Tags</button>
        </div>

        <div class="search-feedback">
            <input type="text" placeholder="Search feedbacks..." />
            <button class="search-icon-btn"><i class="oi oi-magnifying-glass"></i></button>
        </div>

        <button class="new-version-btn">New version</button>
    </section>

    <!-- SECTION 4: VERSION LIST -->
    <main class="content-area">
        @for (int i = 0; i < 2; i++)
        {
            <div class="version-row">
                <!-- Metadata Sidebar -->
                <div class="version-meta">
                    <div class="meta-item"><i class="oi oi-person"></i> Username</div>
                    <div class="meta-item"><i class="oi oi-tag"></i> Tags</div>
                    <div class="meta-date">Created X days ago</div>
                </div>

                <!-- Version Card -->
                <div class="version-card">
                    <div class="card-header">
                        <div class="header-text">
                            <h3>Version name</h3>
                            <p>Description</p>
                        </div>
                        <div class="header-actions">
                            <button class="card-icon-btn"><i class="oi oi-pencil"></i></button>
                            <button class="card-icon-btn"><i class="oi oi-trash"></i></button>
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="expandable-section @(i == 0 ? "expanded" : "")">
                            <div class="section-title">
                                <i class="oi @(i == 0 ? "oi-caret-bottom" : "oi-caret-right")"></i>
                                Documents <span class="badge">@(i == 0 ? "2" : "3")</span>
                            </div>

                            @if (i == 0)
                            {
                                <div class="document-list">
                                    <div class="doc-item">
                                        <span><i class="oi oi-file"></i> Documents.pdf</span>
                                        <span class="time">X days ago</span>
                                    </div>
                                    <div class="doc-item">
                                        <span><i class="oi oi-file"></i> Documents (zip)</span>
                                        <span class="time">X days ago</span>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </main>
</div>

<style>

    :root {
        --bg-dark: #1e1e1e;
        --nav-dark: #252525;
        --accent-white: #ffffff;
        --text-gray: #b0b0b0;
        --border-color: #444;
        --dark-bg: #1a1a1a;
        --header-h: 65px;
    }

    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    .workspace-container {
        width: 100%;
        min-height: 100vh;
        background-color: #f5f5f5;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .top-navbar {
        height: #1a1a1a;
        background: var(--dark-bg);
        color: white;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 20px;
        z-index: 100;
        position: relative;
    }

    .nav-left {
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .menu-toggle {
        background: none;
        border: none;
        color: white;
        font-size: 22px;
        cursor: pointer;
    }

    .app-logo {
        width: 32px;
        height: 32px;
        background: #444;
        border-radius: 6px;
    }

    .search-box {
        background: #333;
        border-radius: 8px;
        padding: 8px 15px;
        display: flex;
        align-items: center;
        width: 400px;
        cursor: pointer;
    }

        .search-box input {
            background: transparent;
            border: none;
            color: white;
            width: 100%;
            outline: none;
            margin-left: 10px;
        }

    .nav-right {
        display: flex;
        gap: 15px;
        align-items: center;
    }

    .icon-btn {
        background: none;
        border: none;
        color: white;
        font-size: 20px;
        cursor: pointer;
    }

    .btn-join {
        background: transparent;
        border: 1px solid #555;
        color: white;
        padding: 5px 15px;
        border-radius: 6px;
        cursor: pointer;
    }

    .nav-left {
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .menu-toggle {
        background: none;
