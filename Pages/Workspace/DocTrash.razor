@page "/doctrash"
@inject NavigationManager Navigation
@rendermode InteractiveServer

<div class="app-container">
    @* --- SECTION 1: TOP NAVIGATION BAR --- *@
    <header class="top-navbar">
        <div class="nav-left">
            <button class="menu-toggle" @onclick="ToggleMenu">☰</button>
            <div class="app-logo"></div>
            <span class="nav-title">Username / Workspace</span>
        </div>
        <div class="nav-center">
            <div class="search-box" @onclick="ToggleSearch">
                <span class="search-icon">🔍</span>
                <input type="text" placeholder="Search anything..." readonly />
            </div>
        </div>
        <div class="nav-right">
            <button class="btn-join" @onclick="ToggleJoin">+ Join</button>
            <button class="icon-btn" @onclick='() => Navigation.NavigateTo("/noti")'>🔔</button>
            <button class="icon-btn" @onclick="ToggleProfile">👤</button>
        </div>
    </header>

    @* --- SECTION 2: SUB-TAB NAVIGATION --- *@
    <nav class="ws-tabs-bar">
        <button class="tab-item" @onclick='() => Navigation.NavigateTo("/docread")'>📄 Document</button>
        <button class="tab-item">✉ Feedback</button>
        <button class="tab-item" @onclick='() => Navigation.NavigateTo("/docver")'>🕒 Versioning</button>
        <button class="tab-item">📋 Logs</button>
        <button class="tab-item active">⚙ Settings</button>
    </nav>

    @* --- MAIN CONTENT (TRASHBIN) --- *@
    <main class="content">
        <div class="content-header-trash">
            <h1 class="trash-title">Trashbin</h1>
            <div class="trash-search-wrapper">
                <span class="search-inner-icon">🔍</span>
                <input type="text" class="trash-search-input" placeholder="Search deleted file..." @bind="searchQuery" @bind:event="oninput" />
            </div>
        </div>

        <div class="trash-table-container">
            <table class="trash-table">
                <thead>
                    <tr class="table-header-row">
                        <th style="width: 50px;">
                            <input type="checkbox" class="custom-checkbox" checked="@isAllSelected" @onchange="SelectAllItems" />
                        </th>
                        <th style="width: 120px;">Select all</th>
                        <th>Name</th>
                        <th style="width: 150px;">Size</th>
                        <th style="width: 200px;">Last deleted date</th>
                        <th style="width: 100px;"></th>
                    </tr>
                </thead>
                <tbody>
                    @if (DeletedItems != null && DeletedItems.Any())
                    {
                        @foreach (var item in FilteredItems)
                        {
                            <tr class="table-body-row @(item.IsSelected ? "selected-row" : "")">
                                <td>
                                    <input type="checkbox" class="custom-checkbox" @bind="item.IsSelected" />
                                </td>
                                <td class="status-cell">@(item.IsSelected ? "Selected" : "")</td>
                                <td class="name-cell">
                                    <span class="folder-icon">📁</span> @item.Name
                                </td>
                                <td class="size-cell">@item.Size</td>
                                <td class="date-cell">@item.DeletedDate.ToString("yyyy-MM-dd HH:mm")</td>
                                <td class="action-cell">
                                    <div class="action-stack">
                                        <button class="action-btn restore" title="Restore" @onclick="() => RestoreItem(item)">↺</button>
                                        <button class="action-btn delete" title="Delete permanently" @onclick="() => PermanentDelete(item)">🗑</button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </main>
</div>
@if (showMenu)
{
    <div class="drawer-menu">
        <div class="drawer-header">
            <i class="user-large-icon">👤</i>
            <button class="close-drawer" @onclick="ToggleMenu">✕</button>
        </div>
        <nav class="drawer-nav">
            <div class="drawer-nav-item" @onclick='() => Navigation.NavigateTo("/")'>⌂ Dashboard</div>
            <div class="drawer-nav-item">✉ Feedback</div>
            <div class="drawer-nav-item">📞 Contact Us</div>
            <div class="nav-divider"></div>
            <div class="nav-label">Top workspaces</div>
            <div class="nav-search-wrap">
                <input type="text" placeholder="Search workspace..." />
            </div>
            <div class="drawer-nav-item small">👤 Project Alpha</div>
            <div class="drawer-nav-item small">👤 Team Beta</div>
        </nav>
    </div>
    <div class="overlay" @onclick="ToggleMenu"></div>
}

@if (showSearch)
{
    <div class="search-modal">
        <div class="search-modal-bar">
            <span>⌕</span>
            <input type="text" placeholder="Search anything..." autofocus />
            <button @onclick="ToggleSearch">✕</button>
        </div>
    </div>
    <div class="overlay" @onclick="ToggleSearch"></div>
}

@if (showJoin)
{
    <div class="join-dropdown">
        <div class="dropdown-header">
            <span style="font-weight: bold;">Join new workspace</span>
            <button @onclick="ToggleJoin" style="background:none; border:none; color:white; cursor:pointer;">✕</button>
        </div>
        <div class="dropdown-body">
            <div class="input-row-dark">
                <i>👤</i>
                <input type="text" placeholder="Username" />
                <button class="copy-btn">⧉</button>
            </div>
            <div class="tab-row-dark">
                <span class="active">HTTPS</span>
                <span>Users</span>
                <span>Workspace ID</span>
            </div>
            <div class="input-row-dark">
                <input type="text" placeholder="Workspace Link/ID" />
                <button class="copy-btn">⧉</button>
            </div>
            <button class="submit-join-btn">Send request to join workspace</button>
        </div>
    </div>
    <div class="overlay transparent" @onclick="ToggleJoin"></div>
}

@if (showProfile)
{
    <div class="profile-dropdown">
        <div class="profile-user-info">
            <i>👤</i>
            <span>Username</span>
        </div>
        <div class="dropdown-divider"></div>
        <div class="drop-item" @onclick='() => Navigation.NavigateTo("/profile-detail")'>👤 Profile</div>
        <div class="drop-item">📁 Workspaces</div>
        <div class="drop-item">✉ Feedback</div>
        <div class="drop-item">⚙ Settings</div>
        <div class="drop-item logout">↪ Sign out</div>
    </div>
    <div class="overlay transparent" @onclick="ToggleProfile"></div>
}
<style>
    /* --- PHẦN 1: FIX VỠ KHUNG (ROOT & LAYOUT) --- */
    :root {
        --bg-dark: #1a1a1a;
    }

    .app-container {
        display: flex;
        flex-direction: column;
        min-height: 100vh;
        background: #fff;
        font-family: sans-serif;
    }

    .top-navbar {
        height: 65px;
        background: #1a1a1a;
        color: white;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 20px;
        z-index: 100;
        position: relative;
    }

    .nav-left {
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .menu-toggle {
        background: none;
        border: none;
        color: white;
        font-size: 22px;
        cursor: pointer;
    }

    .app-logo {
        width: 32px;
        height: 32px;
        background: #444;
        border-radius: 6px;
    }

    .search-box {
        background: #333;
        border-radius: 8px;
        padding: 8px 15px;
        display: flex;
        align-items: center;
        width: 400px;
        cursor: pointer;
    }

        .search-box input {
            background: transparent;
            border: none;
            color: white;
            width: 100%;
            outline: none;
            margin-left: 10px;
        }

    .nav-right {
        display: flex;
        gap: 15px;
        align-items: center;
    }

    .icon-btn {
        background: none;
        border: none;
        color: white;
        font-size: 20px;
        cursor: pointer;
    }

    .btn-join {
        background: transparent;
        border: 1px solid #555;
        color: white;
        padding: 5px 15px;
        border-radius: 6px;
        cursor: pointer;
    }

    .ws-tabs-bar {
        background: #2d2d2d;
        padding: 10px 20px 0;
        display: flex;
        gap: 5px;
    }

    .tab-item {
        background: transparent;
        border: none;
        color: #aaa;
        padding: 10px 15px;
        cursor: pointer;
        border-radius: 8px 8px 0 0;
    }

        .tab-item.active {
            background: #fff;
            color: #000;
            font-weight: bold;
        }

    /* --- PHẦN 2: TRASHBIN CONTENT --- */
    .content {
        padding: 30px 50px;
        flex-grow: 1;
    }

    .content-header-trash {
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 2px solid #000;
        padding-bottom: 15px;
        margin-bottom: 25px;
    }

    .trash-title {
        font-size: 28px;
        font-weight: bold;
        margin: 0;
    }

    .trash-search-wrapper {
        position: relative;
        width: 350px;
    }

    .trash-search-input {
        width: 100%;
        padding: 10px 15px 10px 40px;
        border: 1px solid #000;
        border-radius: 25px;
        outline: none;
    }

    .search-inner-icon {
        position: absolute;
        left: 15px;
        top: 50%;
        transform: translateY(-50%);
    }

    /* Table */
    .trash-table-container {
        border: 1px solid #000;
        border-radius: 8px;
        overflow: hidden;
    }

    .trash-table {
        width: 100%;
        border-collapse: collapse;
        background: #fff;
    }

    .table-header-row {
        background: #1a1a1a;
        color: white;
    }

    .trash-table th {
        padding: 15px;
        text-align: left;
        font-weight: 600;
    }

    .trash-table td {
        padding: 12px 15px;
        border-bottom: 1px solid #eee;
        vertical-align: middle;
    }

    .table-body-row:hover {
        background-color: #fcfcfc;
    }

    .selected-row {
        background-color: #f5f5f5 !important;
    }

    .folder-icon {
        font-size: 18px;
        margin-right: 10px;
    }

    .status-cell {
        font-size: 13px;
        color: #666;
        font-weight: bold;
    }

    /* Actions */
    .action-stack {
        display: flex;
        flex-direction: column;
        gap: 4px;
        align-items: center;
    }

    .action-btn {
        background: #fff;
        border: 1px solid #ddd;
        border-radius: 4px;
        width: 32px;
        height: 32px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: 0.2s;
    }

        .action-btn.restore:hover {
            background: #e8f5e9;
            border-color: #2e7d32;
            color: #2e7d32;
        }

        .action-btn.delete:hover {
            background: #ffebee;
            border-color: #c62828;
            color: #c62828;
        }

    .custom-checkbox {
        width: 18px;
        height: 18px;
        cursor: pointer;
        accent-color: #000;
    }

    .overlay {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.5);
        z-index: 150;
    }

        .overlay.transparent {
            background: transparent;
        }

    .drawer-menu {
        position: fixed;
        top: 0;
        left: 0;
        width: 280px;
        height: 100%;
        background: #000;
        color: white;
        z-index: 200;
        padding: 20px;
    }

    .drawer-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
    }

    .user-large-icon {
        font-size: 40px;
    }

    .close-drawer {
        background: transparent;
        border: none;
        color: white;
        font-size: 20px;
        cursor: pointer;
    }

    .drawer-nav-item {
        padding: 12px;
        color: #ccc;
        cursor: pointer;
        border-radius: 8px;
        font-size: 16px;
    }

        .drawer-nav-item:hover {
            background: #222;
            color: white;
        }

    .nav-divider {
        height: 1px;
        background: #333;
        margin: 15px 0;
    }

    .nav-label {
        color: #666;
        font-size: 12px;
        text-transform: uppercase;
        margin-bottom: 10px;
    }

    .nav-search-wrap input {
        width: 100%;
        background: #222;
        border: 1px solid #444;
        padding: 8px;
        color: white;
        border-radius: 4px;
        margin-bottom: 10px;
    }

    .search-modal {
        position: fixed;
        top: 20px;
        left: 50%;
        transform: translateX(-50%);
        width: 90%;
        max-width: 600px;
        z-index: 200;
    }

    .search-modal-bar {
        background: #1a1a1a;
        display: flex;
        padding: 15px;
        border-radius: 12px;
        border: 1px solid #333;
        align-items: center;
        color: white;
    }

        .search-modal-bar input {
            flex: 1;
            background: transparent;
            border: none;
            color: white;
            outline: none;
            margin: 0 15px;
            font-size: 18px;
        }

    .join-dropdown {
        position: fixed;
        top: 75px;
        right: 80px;
        background: #222;
        padding: 20px;
        border-radius: 15px;
        border: 1px solid #444;
        z-index: 200;
        width: 400px;
        color: white;
    }

    .input-row-dark {
        display: flex;
        gap: 10px;
        margin: 15px 0;
        background: #000;
        padding: 10px;
        border-radius: 8px;
        align-items: center;
    }

        .input-row-dark input {
            flex: 1;
            background: transparent;
            border: none;
            color: white;
            outline: none;
        }

    .tab-row-dark {
        display: flex;
        gap: 20px;
        border-bottom: 1px solid #444;
        margin-bottom: 15px;
    }

        .tab-row-dark span {
            cursor: pointer;
            color: #888;
            padding-bottom: 5px;
            font-size: 14px;
        }

            .tab-row-dark span.active {
                color: white;
                border-bottom: 2px solid white;
            }

    .submit-join-btn {
        width: 100%;
        background: #444;
        color: white;
        border: none;
        padding: 12px;
        border-radius: 8px;
        cursor: pointer;
    }

    .profile-dropdown {
        position: fixed;
        top: 75px;
        right: 20px;
        background: #1a1a1a;
        border: 1px solid #333;
        border-radius: 12px;
        z-index: 200;
        width: 220px;
        padding: 10px;
        color: white;
    }

    .profile-user-info {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px;
        font-weight: bold;
    }

    .dropdown-divider {
        height: 1px;
        background: #333;
        margin: 5px 0;
    }

    .drop-item {
        padding: 10px;
        color: #ccc;
        cursor: pointer;
        border-radius: 6px;
    }

        .drop-item:hover {
            background: #222;
            color: white;
        }

        .drop-item.logout {
            color: #ff4d4d;
        }
</style>

@code {
    private bool showMenu = false;
    private bool showSearch = false;
    private bool showJoin = false;
    private bool showProfile = false;

    private void ToggleMenu() => showMenu = !showMenu;
    private void ToggleSearch() => showSearch = !showSearch;
    private void ToggleJoin() => showJoin = !showJoin;
    private void ToggleProfile() => showProfile = !showProfile;

    private string searchQuery = "";
    private bool isAllSelected = false;

    public class TrashItem
    {
        public string Name { get; set; } = "";
        public string Size { get; set; } = "";
        public DateTime DeletedDate { get; set; }
        public bool IsSelected { get; set; }
    }

    private List<TrashItem> DeletedItems = new() {
        new TrashItem { Name = "Folder name", Size = "Size", DeletedDate = new DateTime(2026, 05, 13, 20, 21, 0) },
        new TrashItem { Name = "Draft_Project_A.docx", Size = "1.2 MB", DeletedDate = new DateTime(2026, 05, 10, 20, 21, 0), IsSelected = true }
    };

    private IEnumerable<TrashItem> FilteredItems =>
        string.IsNullOrWhiteSpace(searchQuery) ? DeletedItems : DeletedItems.Where(i => i.Name.Contains(searchQuery, StringComparison.OrdinalIgnoreCase));

    private void SelectAllItems(ChangeEventArgs e)
    {
        isAllSelected = (bool)e.Value!;
        foreach (var item in DeletedItems) item.IsSelected = isAllSelected;
    }

    private void RestoreItem(TrashItem item) => DeletedItems.Remove(item);
    private void PermanentDelete(TrashItem item) => DeletedItems.Remove(item);
}