@page "/settings/security"
@inject NavigationManager Navigation
@rendermode InteractiveServer

<div class="ws-container">
    <!-- TOPBAR -->
    <header class="top-navbar">
        <div class="nav-left">
            <button class="menu-toggle" @onclick="ToggleMenu">☰</button>
            <div class="app-logo"></div>
            <span class="nav-title">Username</span>
        </div>
        <div class="nav-center">
            <div class="search-box" @onclick="ToggleSearch">
                <span class="search-icon">🔍</span>
                <input type="text" placeholder="Search anything..." readonly />
            </div>
        </div>
        <div class="nav-right">
            <button class="btn-join" @onclick="ToggleJoin">+ Join</button>
            <button class="icon-btn" @onclick='() => Navigation.NavigateTo("/noti")'>🔔</button>
            <button class="icon-btn" @onclick="ToggleProfile">👤</button>
        </div>
    </header>

    <!-- TAB NAVIGATION -->
    <nav class="ws-tabs-bar">
        <button class="tab-item" @onclick='() => Navigation.NavigateTo("/docread")'>📄 Document</button>
        <button class="tab-item">✉ Feedback</button>
        <button class="tab-item" @onclick='() => Navigation.NavigateTo("/docver")'>🕒 Versioning</button>
        <button class="tab-item">📋 Logs</button>
        <button class="tab-item active">⚙ Settings</button>
    </nav>

    <!-- MAIN CONTENT AREA -->
    <div class="settings-layout">
        <!-- SIDEBAR -->
        <aside class="settings-sidebar">
            <button class="side-item" @onclick='() => Navigation.NavigateTo("/settings/general")'>
                <span class="icon">⚙</span> General
            </button>
            <button class="side-item" @onclick='() => Navigation.NavigateTo("/settings/co-writers")'>
                <span class="icon">👥</span> Co-Writers
            </button>
            <button class="side-item active" @onclick='() => Navigation.NavigateTo("/settings/security")'>
                <span class="icon">🛡</span> Security
            </button>
        </aside>

        <!-- CONTENT AREA -->
        <main class="settings-content">
            <h2 class="content-title-line">Security</h2>

            <!-- SECTION 1: VISIBILITY -->
            <div class="visibility-row">
                <div class="security-icon-box">
                    <span class="folder-icon">📂</span>
                </div>
                <div class="visibility-text">
                    <div class="feature-name">Private workspace</div>
                    <div class="feature-desc">Workspace này đang ở chế độ công khai</div>
                </div>
                <button class="btn-change-visibility">Change visibility</button>
            </div>

            <!-- SECTION 2: ALERTS BOX -->
            <div class="settings-group-box">
                <div class="feature-item">
                    <label class="custom-checkbox">
                        <input type="checkbox" checked />
                        <span class="checkmark"></span>
                    </label>
                    <div class="feature-text">
                        <div class="feature-name">Version alert</div>
                        <div class="feature-desc">Cảnh báo phiên bản được chỉnh sửa bởi thành viên khác</div>
                    </div>
                </div>

                <div class="feature-item">
                    <label class="custom-checkbox">
                        <input type="checkbox" />
                        <span class="checkmark"></span>
                    </label>
                    <div class="feature-text">
                        <div class="feature-name">Co-writer alert</div>
                    </div>
                </div>
            </div>

            <!-- SECTION 3: DANGER ZONE BOX -->
            <div class="settings-group-box">
                <div class="danger-item">
                    <div class="danger-text">
                        <div class="feature-name">Archive this workspace</div>
                        <div class="feature-desc">Đóng workspace và chuyển sang chế độ read-only</div>
                    </div>
                    <button class="btn-danger">Archive this workspace</button>
                </div>

                <div class="danger-item">
                    <div class="danger-text">
                        <div class="feature-name">Delete this workspace</div>
                        <div class="feature-desc">Xóa workspace một lần và vĩnh viễn</div>
                    </div>
                    <button class="btn-danger">Delete this workspace</button>
                </div>
            </div>
        </main>
    </div>
</div>
@if (showMenu)
{
    <div class="drawer-menu">
        <div class="drawer-header">
            <i class="user-large-icon">👤</i>
            <button class="close-drawer" @onclick="ToggleMenu">✕</button>
        </div>
        <nav class="drawer-nav">
            <div class="drawer-nav-item" @onclick='() => Navigation.NavigateTo("/")'>⌂ Dashboard</div>
            <div class="drawer-nav-item">✉ Feedback</div>
            <div class="drawer-nav-item">📞 Contact Us</div>
            <div class="nav-divider"></div>
            <div class="nav-label">Top workspaces</div>
            <div class="nav-search-wrap">
                <input type="text" placeholder="Search workspace..." />
            </div>
            <div class="drawer-nav-item small">👤 Project Alpha</div>
            <div class="drawer-nav-item small">👤 Team Beta</div>
        </nav>
    </div>
    <div class="overlay" @onclick="ToggleMenu"></div>
}

@if (showSearch)
{
    <div class="search-modal">
        <div class="search-modal-bar">
            <span>⌕</span>
            <input type="text" placeholder="Search anything..." autofocus />
            <button @onclick="ToggleSearch">✕</button>
        </div>
    </div>
    <div class="overlay" @onclick="ToggleSearch"></div>
}

@if (showJoin)
{
    <div class="join-dropdown">
        <div class="dropdown-header">
            <span style="font-weight: bold;">Join new workspace</span>
            <button @onclick="ToggleJoin" style="background:none; border:none; color:white; cursor:pointer;">✕</button>
        </div>
        <div class="dropdown-body">
            <div class="input-row-dark">
                <i>👤</i>
                <input type="text" placeholder="Username" />
                <button class="copy-btn">⧉</button>
            </div>
            <div class="tab-row-dark">
                <span class="active">HTTPS</span>
                <span>Users</span>
                <span>Workspace ID</span>
            </div>
            <div class="input-row-dark">
                <input type="text" placeholder="Workspace Link/ID" />
                <button class="copy-btn">⧉</button>
            </div>
            <button class="submit-join-btn">Send request to join workspace</button>
        </div>
    </div>
    <div class="overlay transparent" @onclick="ToggleJoin"></div>
}

@if (showProfile)
{
    <div class="profile-dropdown">
        <div class="profile-user-info">
            <i>👤</i>
            <span>Username</span>
        </div>
        <div class="dropdown-divider"></div>
        <div class="drop-item" @onclick='() => Navigation.NavigateTo("/profile-detail")'>👤 Profile</div>
        <div class="drop-item">📁 Workspaces</div>
        <div class="drop-item">✉ Feedback</div>
        <div class="drop-item">⚙ Settings</div>
        <div class="drop-item logout">↪ Sign out</div>
    </div>
    <div class="overlay transparent" @onclick="ToggleProfile"></div>
}
<style>
    /* CSS CƠ BẢN */
    .ws-container {
        font-family: 'Segoe UI', sans-serif;
        background: #fff;
        min-height: 100vh;
    }

    /* HEADER & TABS */
    .top-navbar {
        height: 65px;
        background: #1a1a1a;
        color: white;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 20px;
        z-index: 100;
        position: relative;
    }

    .nav-left {
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .menu-toggle {
        background: none;
        border: none;
        color: white;
        font-size: 22px;
        cursor: pointer;
    }

    .app-logo {
        width: 32px;
        height: 32px;
        background: #444;
        border-radius: 6px;
    }

    .search-box {
        background: #333;
        border-radius: 8px;
        padding: 8px 15px;
        display: flex;
        align-items: center;
        width: 400px;
        cursor: pointer;
    }

        .search-box input {
            background: transparent;
            border: none;
            color: white;
            width: 100%;
            outline: none;
            margin-left: 10px;
        }

    .nav-right {
        display: flex;
        gap: 15px;
        align-items: center;
    }

    .icon-btn {
        background: none;
        border: none;
        color: white;
        font-size: 20px;
        cursor: pointer;
    }

    .btn-join {
        background: transparent;
        border: 1px solid #555;
        color: white;
        padding: 5px 15px;
        border-radius: 6px;
        cursor: pointer;
    }

    .ws-tabs-bar {
        background: #333;
        padding: 8px 20px 0;
        display: flex;
        gap: 10px;
    }

    .tab-item {
        background: transparent;
        border: none;
        color: #ccc;
        padding: 8px 16px;
        cursor: pointer;
    }

        .tab-item.active {
            background: #fff;
            color: #000;
            border-radius: 6px 6px 0 0;
            font-weight: bold;
        }

    /* LAYOUT */
    .settings-layout {
        display: flex;
        padding: 30px 50px;
        gap: 40px;
    }

    .settings-sidebar {
        width: 220px;
    }

    .side-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 12px;
        border: none;
        background: transparent;
        width: 100%;
        text-align: left;
        cursor: pointer;
        border-radius: 8px;
        font-size: 16px;
    }

        .side-item.active {
            background: #1a1a1a;
            color: white;
        }

    /* NỘI DUNG CHÍNH*/
    .settings-content {
        flex: 1;
    }

    .content-title-line {
        font-size: 24px;
        font-weight: bold;
        border-bottom: 1.5px solid #ccc;
        padding-bottom: 8px;
        margin-bottom: 25px;
    }

    .visibility-row {
        display: flex;
        align-items: center;
        gap: 15px;
        margin-bottom: 25px;
    }

    .security-icon-box {
        width: 50px;
        height: 50px;
        border: 1px solid #333;
        border-radius: 6px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
    }

    .visibility-text {
        flex: 1;
    }

    .btn-change-visibility {
        background: #333;
        color: white;
        border: none;
        padding: 8px 16px;
        border-radius: 6px;
        cursor: pointer;
        font-size: 14px;
    }

    /* KHỐI BOX CÓ VIỀN */
    .settings-group-box {
        border: 1px solid #333;
        border-radius: 15px;
        padding: 20px;
        margin-bottom: 25px;
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .feature-item {
        display: flex;
        gap: 12px;
        align-items: flex-start;
    }

    .feature-name {
        font-weight: bold;
        font-size: 16px;
    }

    .feature-desc {
        font-size: 14px;
        color: #666;
        margin-top: 2px;
    }

    /* DANGER ZONE */
    .danger-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .btn-danger {
        background: #ff4d4d;
        color: white;
        border: none;
        padding: 10px 20px;
        border-radius: 8px;
        cursor: pointer;
        font-weight: 500;
        min-width: 180px;
    }

    /* CUSTOM CHECKBOX */
    .custom-checkbox {
        position: relative;
        width: 20px;
        height: 20px;
        cursor: pointer;
    }

        .custom-checkbox input {
            opacity: 0;
            width: 0;
            height: 0;
        }

    .checkmark {
        position: absolute;
        top: 0;
        left: 0;
        height: 20px;
        width: 20px;
        background-color: #fff;
        border: 2px solid #333;
        border-radius: 4px;
    }

    .custom-checkbox input:checked ~ .checkmark {
        background-color: #333;
    }

    .checkmark:after {
        content: "";
        position: absolute;
        display: none;
        left: 6px;
        top: 2px;
        width: 5px;
        height: 10px;
        border: solid white;
        border-width: 0 2px 2px 0;
        transform: rotate(45deg);
    }

    .custom-checkbox input:checked ~ .checkmark:after {
        display: block;
    }

    .overlay {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.5);
        z-index: 150;
    }

        .overlay.transparent {
            background: transparent;
        }

    .drawer-menu {
        position: fixed;
        top: 0;
        left: 0;
        width: 280px;
        height: 100%;
        background: #000;
        color: white;
        z-index: 200;
        padding: 20px;
    }

    .drawer-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
    }

    .user-large-icon {
        font-size: 40px;
    }

    .close-drawer {
        background: transparent;
        border: none;
        color: white;
        font-size: 20px;
        cursor: pointer;
    }

    .drawer-nav-item {
        padding: 12px;
        color: #ccc;
        cursor: pointer;
        border-radius: 8px;
        font-size: 16px;
    }

        .drawer-nav-item:hover {
            background: #222;
            color: white;
        }

    .nav-divider {
        height: 1px;
        background: #333;
        margin: 15px 0;
    }

    .nav-label {
        color: #666;
        font-size: 12px;
        text-transform: uppercase;
        margin-bottom: 10px;
    }

    .nav-search-wrap input {
        width: 100%;
        background: #222;
        border: 1px solid #444;
        padding: 8px;
        color: white;
        border-radius: 4px;
        margin-bottom: 10px;
    }

    .search-modal {
        position: fixed;
        top: 20px;
        left: 50%;
        transform: translateX(-50%);
        width: 90%;
        max-width: 600px;
        z-index: 200;
    }

    .search-modal-bar {
        background: #1a1a1a;
        display: flex;
        padding: 15px;
        border-radius: 12px;
        border: 1px solid #333;
        align-items: center;
        color: white;
    }

        .search-modal-bar input {
            flex: 1;
            background: transparent;
            border: none;
            color: white;
            outline: none;
            margin: 0 15px;
            font-size: 18px;
        }

    .join-dropdown {
        position: fixed;
        top: 75px;
        right: 80px;
        background: #222;
        padding: 20px;
        border-radius: 15px;
        border: 1px solid #444;
        z-index: 200;
        width: 400px;
        color: white;
    }

    .input-row-dark {
        display: flex;
        gap: 10px;
        margin: 15px 0;
        background: #000;
        padding: 10px;
        border-radius: 8px;
        align-items: center;
    }

        .input-row-dark input {
            flex: 1;
            background: transparent;
            border: none;
            color: white;
            outline: none;
        }

    .tab-row-dark {
        display: flex;
        gap: 20px;
        border-bottom: 1px solid #444;
        margin-bottom: 15px;
    }

        .tab-row-dark span {
            cursor: pointer;
            color: #888;
            padding-bottom: 5px;
            font-size: 14px;
        }

            .tab-row-dark span.active {
                color: white;
                border-bottom: 2px solid white;
            }

    .submit-join-btn {
        width: 100%;
        background: #444;
        color: white;
        border: none;
        padding: 12px;
        border-radius: 8px;
        cursor: pointer;
    }

    .profile-dropdown {
        position: fixed;
        top: 75px;
        right: 20px;
        background: #1a1a1a;
        border: 1px solid #333;
        border-radius: 12px;
        z-index: 200;
        width: 220px;
        padding: 10px;
        color: white;
    }

    .profile-user-info {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px;
        font-weight: bold;
    }

    .dropdown-divider {
        height: 1px;
        background: #333;
        margin: 5px 0;
    }

    .drop-item {
        padding: 10px;
        color: #ccc;
        cursor: pointer;
        border-radius: 6px;
    }

        .drop-item:hover {
            background: #222;
            color: white;
        }

        .drop-item.logout {
            color: #ff4d4d;
        }
</style>

@code {
    private bool showMenu = false;
    private bool showSearch = false;
    private bool showJoin = false;
    private bool showProfile = false;

    private void ToggleMenu() => showMenu = !showMenu;
    private void ToggleSearch() => showSearch = !showSearch;
    private void ToggleJoin() => showJoin = !showJoin;
    private void ToggleProfile() => showProfile = !showProfile;
}