@page "/docveredit"
@inject NavigationManager Navigation
@rendermode InteractiveServer

<div class="page-wrapper">
    <header class="top-navbar">
        <div class="nav-left">
            <button class="menu-toggle" @onclick="ToggleMenu">☰</button>
            <div class="app-logo"></div>
            <span class="nav-title">Username / Workspace</span>
        </div>
        <div class="nav-center">
            <div class="search-box" @onclick="ToggleSearch">
                <span class="search-icon">🔍</span>
                <input type="text" placeholder="Search anything..." readonly />
            </div>
        </div>
        <div class="nav-right">
            <button class="btn-join" @onclick="ToggleJoin">+ Join</button>
            <button class="icon-btn" @onclick='() => Navigation.NavigateTo("/noti")'>🔔</button>
            <button class="icon-btn" @onclick="ToggleProfile">👤</button>
        </div>
    </header>

    <nav class="ws-tabs-bar">
        <button class="tab-item" @onclick='() => Navigation.NavigateTo("/docread")'>📄 Document</button>
        <button class="tab-item">✉ Feedback</button>
        <button class="tab-item" @onclick='() => Navigation.NavigateTo("/docver")'>🕒 Versioning</button>
        <button class="tab-item">📋 Logs</button>
        <button class="tab-item active">⚙ Settings</button>
    </nav>

    <main class="main-content">
        <div class="breadcrumb-container">
            <h2 class="breadcrumb-text">Directory / <strong>Folder</strong> / <strong>File</strong></h2>
            <div class="search-version-wrapper">
                <span class="search-icon-inline">🔍</span>
                <input type="text" class="search-version-input" placeholder="Search version.." />
            </div>
        </div>

        <div class="edit-card">
            <div class="form-container">
                <div class="form-row">
                    <div class="label-with-icon">
                        <span class="user-icon">👤</span>
                        <label>Version Name</label>
                    </div>
                    <input type="text" class="input-field" />
                </div>

                <div class="form-row">
                    <label class="label-no-icon">Version Description</label>
                    <textarea class="textarea-field"></textarea>
                </div>
            </div>

            <div class="table-footer-info">
                <div class="col-file">File name</div>
                <div class="col-size">Size</div>
                <div class="col-time">Last updated time</div>
                <div class="col-action">
                    <button class="btn-delete">🗑️</button>
                </div>
            </div>
        </div>

        <div class="action-buttons">
            <button class="btn-save">Save</button>
            <button class="btn-cancel">Cancel</button>
        </div>
    </main>

    @if (showMenu)
    {
        <div class="drawer-menu">
            <div class="drawer-header">
                <i class="user-large-icon">👤</i>
                <button class="close-drawer" @onclick="ToggleMenu">✕</button>
            </div>
            <nav class="drawer-nav">
                <div class="drawer-nav-item" @onclick='() => Navigation.NavigateTo("/")'>⌂ Dashboard</div>
                <div class="drawer-nav-item">✉ Feedback</div>
                <div class="drawer-nav-item">📞 Contact Us</div>
                <div class="nav-divider"></div>
                <div class="nav-label">Top workspaces</div>
                <div class="nav-search-wrap">
                    <input type="text" placeholder="Search workspace..." />
                </div>
                <div class="drawer-nav-item small">👤 Project Alpha</div>
                <div class="drawer-nav-item small">👤 Team Beta</div>
            </nav>
        </div>
        <div class="overlay" @onclick="ToggleMenu"></div>
    }

    @if (showSearch)
    {
        <div class="search-modal">
            <div class="search-modal-bar">
                <span>⌕</span>
                <input type="text" placeholder="Search anything..." autofocus />
                <button @onclick="ToggleSearch">✕</button>
            </div>
        </div>
        <div class="overlay" @onclick="ToggleSearch"></div>
    }

    @if (showJoin)
    {
        <div class="join-dropdown">
            <div class="dropdown-header">
                <span style="font-weight: bold;">Join new workspace</span>
                <button @onclick="ToggleJoin" style="background:none; border:none; color:white; cursor:pointer;">✕</button>
            </div>
            <div class="dropdown-body">
                <div class="input-row-dark">
                    <i>👤</i>
                    <input type="text" placeholder="Username" />
                    <button class="copy-btn">⧉</button>
                </div>
                <div class="tab-row-dark">
                    <span class="active">HTTPS</span>
                    <span>Users</span>
                    <span>Workspace ID</span>
                </div>
                <div class="input-row-dark">
                    <input type="text" placeholder="Workspace Link/ID" />
                    <button class="copy-btn">⧉</button>
                </div>
                <button class="submit-join-btn">Send request to join workspace</button>
            </div>
        </div>
        <div class="overlay transparent" @onclick="ToggleJoin"></div>
    }

    @if (showProfile)
    {
        <div class="profile-dropdown">
            <div class="profile-user-info">
                <i>👤</i>
                <span>Username</span>
            </div>
            <div class="dropdown-divider"></div>
            <div class="drop-item" @onclick='() => Navigation.NavigateTo("/profile-detail")'>👤 Profile</div>
            <div class="drop-item">📁 Workspaces</div>
            <div class="drop-item">✉ Feedback</div>
            <div class="drop-item">⚙ Settings</div>
            <div class="drop-item logout">↪ Sign out</div>
        </div>
        <div class="overlay transparent" @onclick="ToggleProfile"></div>
    }
</div>

<style>
    .page-wrapper {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        background-color: #fff;
        min-height: 100vh;
    }

    .top-navbar {
        height: 65px;
        background: #1a1a1a;
        color: white;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 20px;
        z-index: 100;
        position: relative;
    }

    .nav-left {
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .menu-toggle {
        background: none;
        border: none;
        color: white;
        font-size: 22px;
        cursor: pointer;
    }

    .app-logo {
        width: 32px;
        height: 32px;
        background: #444;
        border-radius: 6px;
    }

    .search-box {
        background: #333;
        border-radius: 8px;
        padding: 8px 15px;
        display: flex;
        align-items: center;
        width: 400px;
        cursor: pointer;
    }

        .search-box input {
            background: transparent;
            border: none;
            color: white;
            width: 100%;
            outline: none;
            margin-left: 10px;
        }

    .nav-right {
        display: flex;
        gap: 15px;
        align-items: center;
    }

    .icon-btn {
        background: none;
        border: none;
        color: white;
        font-size: 20px;
        cursor: pointer;
    }

    .btn-join {
        background: transparent;
        border: 1px solid #555;
        color: white;
        padding: 5px 15px;
        border-radius: 6px;
        cursor: pointer;
    }

    .ws-tabs-bar {
        background: #2d2d2d;
        padding: 10px 20px 0;
        display: flex;
        gap: 5px;
    }

    .tab-item {
        background: transparent;
        border: none;
        color: #aaa;
        padding: 10px 15px;
        cursor: pointer;
        border-radius: 8px 8px 0 0;
    }

        .tab-item.active {
            background: #fff;
            color: #000;
            font-weight: bold;
        }

    .content-container {
        padding: 40px 60px;
        max-width: 1000px;
    }

    .content-title {
        font-size: 24px;
        font-weight: bold;
        margin-bottom: 10px;
    }

    .title-divider {
        border: 0;
        border-top: 2px solid #000;
        margin-bottom: 30px;
    }

    .form-group {
        display: flex;
        align-items: flex-start;
        margin-bottom: 25px;
    }

    .section-label {
        width: 150px;
        font-size: 18px;
        font-weight: 500;
        padding-top: 8px;
    }

    .ws-input {
        padding: 12px 15px;
        border: 1px solid #000;
        border-radius: 8px;
        font-size: 16px;
        outline: none;
    }

    .main-content {
        padding: 20px 40px;
    }

    .breadcrumb-container {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
    }

    .breadcrumb-text {
        font-size: 1.2rem;
        color: #333;
        font-weight: normal;
    }

    .search-version-wrapper {
        position: relative;
        width: 400px;
    }

    .search-version-input {
        width: 100%;
        padding: 8px 12px 8px 35px;
        border: 1.5px solid #000;
        border-radius: 8px;
        outline: none;
    }

    .search-icon-inline {
        position: absolute;
        left: 10px;
        top: 50%;
        transform: translateY(-50%);
    }

    .edit-card {
        border: 1.5px solid #000;
        border-radius: 12px;
        overflow: hidden;
        margin-bottom: 20px;
    }

    .form-container {
        padding: 30px;
    }

    .form-row {
        display: flex;
        margin-bottom: 20px;
        align-items: flex-start;
    }

    .label-with-icon {
        width: 180px;
        display: flex;
        align-items: center;
        gap: 10px;
        font-weight: 500;
    }

    .label-no-icon {
        width: 180px;
        padding-left: 30px;
        font-weight: 500;
    }

    .user-icon {
        font-size: 1.2rem;
    }

    .input-field, .textarea-field {
        flex: 1;
        border: 1.5px solid #000;
        border-radius: 8px;
        padding: 10px;
        outline: none;
    }

    .textarea-field {
        min-height: 150px;
        resize: vertical;
    }

    .table-footer-info {
        display: flex;
        border-top: 1.5px solid #000;
        padding: 12px 30px;
        background-color: #fff;
        font-size: 0.9rem;
        color: #555;
        align-items: center;
    }

    .col-file {
        flex: 2;
    }

    .col-size {
        flex: 1;
    }

    .col-time {
        flex: 2;
    }

    .col-action {
        flex: 0.2;
        text-align: right;
    }

    .btn-delete {
        background: none;
        border: none;
        cursor: pointer;
        font-size: 1.1rem;
    }

    .action-buttons {
        display: flex;
        justify-content: flex-end;
        gap: 15px;
    }

    .btn-save, .btn-cancel {
        padding: 10px 30px;
        border-radius: 8px;
        border: none;
        cursor: pointer;
        font-weight: bold;
        min-width: 100px;
    }

    .btn-save {
        background-color: #222;
        color: #fff;
    }

    .btn-cancel {
        background-color: #333;
        color: #fff;
    }

    .overlay {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.5);
        z-index: 150;
    }

        .overlay.transparent {
            background: transparent;
        }

    .drawer-menu {
        position: fixed;
        top: 0;
        left: 0;
        width: 280px;
        height: 100%;
        background: #000;
        color: white;
        z-index: 200;
        padding: 20px;
    }

    .drawer-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
    }

    .user-large-icon {
        font-size: 40px;
    }

    .close-drawer {
        background: transparent;
        border: none;
        color: white;
        font-size: 20px;
        cursor: pointer;
    }

    .drawer-nav-item {
        padding: 12px;
        color: #ccc;
        cursor: pointer;
        border-radius: 8px;
        font-size: 16px;
    }

        .drawer-nav-item:hover {
            background: #222;
            color: white;
        }

    .nav-divider {
        height: 1px;
        background: #333;
        margin: 15px 0;
    }

    .nav-label {
        color: #666;
        font-size: 12px;
        text-transform: uppercase;
        margin-bottom: 10px;
    }

    .nav-search-wrap input {
        width: 100%;
        background: #222;
        border: 1px solid #444;
        padding: 8px;
        color: white;
        border-radius: 4px;
        margin-bottom: 10px;
    }

    .search-modal {
        position: fixed;
        top: 20px;
        left: 50%;
        transform: translateX(-50%);
        width: 90%;
        max-width: 600px;
        z-index: 200;
    }

    .search-modal-bar {
        background: #1a1a1a;
        display: flex;
        padding: 15px;
        border-radius: 12px;
        border: 1px solid #333;
        align-items: center;
        color: white;
    }

        .search-modal-bar input {
            flex: 1;
            background: transparent;
            border: none;
            color: white;
            outline: none;
            margin: 0 15px;
            font-size: 18px;
        }

    .join-dropdown {
        position: fixed;
        top: 75px;
        right: 80px;
        background: #222;
        padding: 20px;
        border-radius: 15px;
        border: 1px solid #444;
        z-index: 200;
        width: 400px;
        color: white;
    }

    .input-row-dark {
        display: flex;
        gap: 10px;
        margin: 15px 0;
        background: #000;
        padding: 10px;
        border-radius: 8px;
        align-items: center;
    }

        .input-row-dark input {
            flex: 1;
            background: transparent;
            border: none;
            color: white;
            outline: none;
        }

    .tab-row-dark {
        display: flex;
        gap: 20px;
        border-bottom: 1px solid #444;
        margin-bottom: 15px;
    }

        .tab-row-dark span {
            cursor: pointer;
            color: #888;
            padding-bottom: 5px;
            font-size: 14px;
        }

            .tab-row-dark span.active {
                color: white;
                border-bottom: 2px solid white;
            }

    .submit-join-btn {
        width: 100%;
        background: #444;
        color: white;
        border: none;
        padding: 12px;
        border-radius: 8px;
        cursor: pointer;
    }

    .profile-dropdown {
        position: fixed;
        top: 75px;
        right: 20px;
        background: #1a1a1a;
        border: 1px solid #333;
        border-radius: 12px;
        z-index: 200;
        width: 220px;
        padding: 10px;
        color: white;
    }

    .profile-user-info {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px;
        font-weight: bold;
    }

    .dropdown-divider {
        height: 1px;
        background: #333;
        margin: 5px 0;
    }

    .drop-item {
        padding: 10px;
        color: #ccc;
        cursor: pointer;
        border-radius: 6px;
    }

        .drop-item:hover {
            background: #222;
            color: white;
        }

        .drop-item.logout {
            color: #ff4d4d;
        }
</style>

@code {
    private bool showMenu = false;
    private bool showSearch = false;
    private bool showJoin = false;
    private bool showProfile = false;

    private void ToggleMenu() => showMenu = !showMenu;
    private void ToggleSearch() => showSearch = !showSearch;
    private void ToggleJoin() => showJoin = !showJoin;
    private void ToggleProfile() => showProfile = !showProfile;
}