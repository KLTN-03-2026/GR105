@page "/passwordreissue"
@inject NavigationManager Navigation
@rendermode InteractiveServer
<div class="admin-wrapper">
    @* --- TOP NAVBAR --- *@
    <header class="top-navbar">
        <div class="nav-left">
            <button class="menu-toggle" @onclick="ToggleMenu">☰</button>
            <div class="app-logo"></div>
            <span class="nav-title">Password Reissue Manager</span>
        </div>
        <div class="nav-center">
            <div class="search-box" @onclick="ToggleSearch">
                <span class="search-icon">🔍</span>
                <input type="text" placeholder="Search anything..." readonly />
            </div>
        </div>
        <div class="nav-right">
            <button class="btn-join" @onclick="ToggleJoin">+ Add new</button>
            <button class="icon-btn" @onclick='() => Navigation.NavigateTo("/noti")'>🔔</button>
            <button class="icon-btn" @onclick="ToggleProfile">👤</button>
        </div>
    </header>

    @* --- MAIN CONTENT --- *@
    <main class="main-content">
        <div class="tab-bar">
            <div class="tab-item active">In Progress</div>
            <div class="tab-item">Done</div>
            <div class="tab-item">Denied</div>
        </div>

        <div class="data-card">
            <div class="table-toolbar">
                <div class="toolbar-left">
                    <button class="btn-collapse">
                        <span class="minus-icon"></span>
                    </button>
                    <div class="status-group">
                        <span class="status-badge open">Open <span class="count-pill">4</span></span>
                        <span class="status-badge closed">Closed <span class="count-pill">0</span></span>
                    </div>
                </div>
                <div class="toolbar-right">
                    <div class="sort-header">User <span class="arrow">▼</span></div>
                    <div class="sort-header">Reason</div>
                    <div class="sort-header">Newest <span class="arrow">▼</span></div>
                </div>
            </div>

            <div class="table-body">
                @for (int i = 1; i <= 4; i++)
                {
                    <div class="table-row">
                        <div class="cell cell-check">
                            <input type="checkbox" checked="@(i == 1)" />
                        </div>
                        <div class="cell cell-id">Password Reissue #ID</div>
                        <div class="cell cell-user">username</div>
                        <div class="cell cell-reason">reason</div>
                        <div class="cell cell-time">X days ago</div>
                        <div class="cell cell-actions">
                            <button class="btn-action check">✔</button>
                            <button class="btn-action cross">✖</button>
                        </div>
                    </div>
                }
            </div>
        </div>
    </main>

    @if (showMenu)
    {
        <div class="drawer-menu">
            <div class="drawer-header">
                <i class="user-large-icon">👤</i>
                <button class="close-drawer" @onclick="ToggleMenu">✕</button>
            </div>
            <nav class="drawer-nav">
                <div class="drawer-nav-item" @onclick='() => Navigation.NavigateTo("/")'>⌂ Dashboard</div>
                <div class="drawer-nav-item">✉ Feedback</div>
                <div class="drawer-nav-item">📞 Contact Us</div>
                <div class="nav-divider"></div>
                <div class="nav-label">Top workspaces</div>
                <div class="nav-search-wrap">
                    <input type="text" placeholder="Search workspace..." />
                </div>
                <div class="drawer-nav-item small">👤 Project Alpha</div>
                <div class="drawer-nav-item small">👤 Team Beta</div>
            </nav>
        </div>
        <div class="overlay" @onclick="ToggleMenu"></div>
    }

    @if (showSearch)
    {
        <div class="search-modal">
            <div class="search-modal-bar">
                <span>⌕</span>
                <input type="text" placeholder="Search anything..." autofocus />
                <button @onclick="ToggleSearch">✕</button>
            </div>
        </div>
        <div class="overlay" @onclick="ToggleSearch"></div>
    }

    @if (showJoin)
    {
        <div class="join-dropdown">
            <div class="dropdown-header">
                <span style="font-weight: bold;">Join new workspace</span>
                <button @onclick="ToggleJoin" style="background:none; border:none; color:white; cursor:pointer;">✕</button>
            </div>
            <div class="dropdown-body">
                <div class="input-row-dark">
                    <i>👤</i>
                    <input type="text" placeholder="Username" />
                    <button class="copy-btn">⧉</button>
                </div>
                <div class="tab-row-dark">
                    <span class="active">HTTPS</span>
                    <span>Users</span>
                    <span>Workspace ID</span>
                </div>
                <div class="input-row-dark">
                    <input type="text" placeholder="Workspace Link/ID" />
                    <button class="copy-btn">⧉</button>
                </div>
                <button class="submit-join-btn">Send request to join workspace</button>
            </div>
        </div>
        <div class="overlay transparent" @onclick="ToggleJoin"></div>
    }

    @if (showProfile)
    {
        <div class="profile-dropdown">
            <div class="profile-user-info">
                <i>👤</i>
                <span>Username</span>
            </div>
            <div class="dropdown-divider"></div>
            <div class="drop-item" @onclick='() => Navigation.NavigateTo("/profile-detail")'>👤 Profile</div>
            <div class="drop-item">📁 Workspaces</div>
            <div class="drop-item">✉ Feedback</div>
            <div class="drop-item">⚙ Settings</div>
            <div class="drop-item logout">↪ Sign out</div>
        </div>
        <div class="overlay transparent" @onclick="ToggleProfile"></div>
    }
</div>

<style>
    :root {
        --primary-red: #e63946;
        --dark-bg: #1a1a1a;
        --toolbar-bg: #333131;
        --border-color: #e0e0e0;
    }

    .admin-wrapper {
        background-color: #fff;
        min-height: 100vh;
        font-family: 'Segoe UI', Arial, sans-serif;
    }

    /* Navbar Styles */
    .top-navbar {
        height: 65px;
        background: #1a1a1a;
        color: white;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 20px;
        z-index: 100;
        position: relative;
    }

    .nav-left {
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .menu-toggle {
        background: none;
        border: none;
        color: white;
        font-size: 22px;
        cursor: pointer;
    }

    .app-logo {
        width: 32px;
        height: 32px;
        background: #444;
        border-radius: 6px;
    }

    .search-box {
        background: #333;
        border-radius: 8px;
        padding: 8px 15px;
        display: flex;
        align-items: center;
        width: 400px;
        cursor: pointer;
    }

        .search-box input {
            background: transparent;
            border: none;
            color: white;
            width: 100%;
            outline: none;
            margin-left: 10px;
        }

    .nav-right {
        display: flex;
        gap: 15px;
        align-items: center;
    }

    .icon-btn {
        background: none;
        border: none;
        color: white;
        font-size: 20px;
        cursor: pointer;
    }

    .btn-join {
        background: transparent;
        border: 1px solid #555;
        color: white;
        padding: 5px 15px;
        border-radius: 6px;
        cursor: pointer;
    }

    /* Main Content & Tabs */
    .main-content {
        padding: 20px 40px;
    }

    .tab-bar {
        display: flex;
        gap: 40px;
        border-bottom: 2px solid #f0f0f0;
        margin-bottom: 25px;
    }

    .tab-item {
        padding: 10px 5px;
        font-size: 1.2rem;
        color: #666;
        cursor: pointer;
        position: relative;
    }

        .tab-item.active {
            color: #000;
            font-weight: bold;
        }

            .tab-item.active::after {
                content: '';
                position: absolute;
                bottom: -2px;
                left: 0;
                width: 100%;
                height: 3px;
                background-color: var(--primary-red);
            }

    /* Table Design */
    .data-card {
        border: 1px solid #333;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 4px 6px rgba(0,0,0,0.05);
    }

    .table-toolbar {
        background: var(--toolbar-bg);
        color: white;
        padding: 12px 20px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .toolbar-left {
        display: flex;
        align-items: center;
        gap: 20px;
    }

    .btn-collapse {
        width: 24px;
        height: 24px;
        background: #444;
        border: none;
        border-radius: 4px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
    }

    .minus-icon {
        width: 10px;
        height: 2px;
        background: white;
    }

    .status-badge {
        font-size: 0.9rem;
        margin-right: 15px;
        cursor: pointer;
    }

    .count-pill {
        background: #555;
        padding: 1px 8px;
        border-radius: 10px;
        font-size: 0.8rem;
        margin-left: 5px;
    }

    .toolbar-right {
        display: flex;
        gap: 150px; /* Tùy chỉnh theo tỉ lệ màn hình */
        font-size: 0.9rem;
        color: #bbb;
    }

    /* Table Rows */
    .table-row {
        display: grid;
        grid-template-columns: 50px 1.5fr 1fr 1fr 1fr 100px;
        align-items: center;
        padding: 15px 20px;
        border-bottom: 1px solid #eee;
        color: #333;
    }

    .cell-id {
        font-weight: 500;
    }

    .cell-actions {
        display: flex;
        gap: 12px;
        justify-content: flex-end;
    }

    .btn-action {
        width: 28px;
        height: 28px;
        border: 1px solid #ccc;
        border-radius: 4px;
        background: white;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .btn-action.check:hover {
            color: green;
            border-color: green;
        }

        .btn-action.cross:hover {
            color: red;
            border-color: red;
        }

   
    .overlay {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.5);
        z-index: 150;
    }

        .overlay.transparent {
            background: transparent;
        }

    .drawer-menu {
        position: fixed;
        top: 0;
        left: 0;
        width: 280px;
        height: 100%;
        background: #000;
        color: white;
        z-index: 200;
        padding: 20px;
    }

    .drawer-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
    }

    .user-large-icon {
        font-size: 40px;
    }

    .close-drawer {
        background: transparent;
        border: none;
        color: white;
        font-size: 20px;
        cursor: pointer;
    }

    .drawer-nav-item {
        padding: 12px;
        color: #ccc;
        cursor: pointer;
        border-radius: 8px;
        font-size: 16px;
    }

        .drawer-nav-item:hover {
            background: #222;
            color: white;
        }

    .nav-divider {
        height: 1px;
        background: #333;
        margin: 15px 0;
    }

    .nav-label {
        color: #666;
        font-size: 12px;
        text-transform: uppercase;
        margin-bottom: 10px;
    }

    .nav-search-wrap input {
        width: 100%;
        background: #222;
        border: 1px solid #444;
        padding: 8px;
        color: white;
        border-radius: 4px;
        margin-bottom: 10px;
    }

    .search-modal {
        position: fixed;
        top: 20px;
        left: 50%;
        transform: translateX(-50%);
        width: 90%;
        max-width: 600px;
        z-index: 200;
    }

    .search-modal-bar {
        background: #1a1a1a;
        display: flex;
        padding: 15px;
        border-radius: 12px;
        border: 1px solid #333;
        align-items: center;
        color: white;
    }

        .search-modal-bar input {
            flex: 1;
            background: transparent;
            border: none;
            color: white;
            outline: none;
            margin: 0 15px;
            font-size: 18px;
        }

    .join-dropdown {
        position: fixed;
        top: 75px;
        right: 80px;
        background: #222;
        padding: 20px;
        border-radius: 15px;
        border: 1px solid #444;
        z-index: 200;
        width: 400px;
        color: white;
    }

    .input-row-dark {
        display: flex;
        gap: 10px;
        margin: 15px 0;
        background: #000;
        padding: 10px;
        border-radius: 8px;
        align-items: center;
    }

        .input-row-dark input {
            flex: 1;
            background: transparent;
            border: none;
            color: white;
            outline: none;
        }

    .tab-row-dark {
        display: flex;
        gap: 20px;
        border-bottom: 1px solid #444;
        margin-bottom: 15px;
    }

        .tab-row-dark span {
            cursor: pointer;
            color: #888;
            padding-bottom: 5px;
            font-size: 14px;
        }

            .tab-row-dark span.active {
                color: white;
                border-bottom: 2px solid white;
            }

    .submit-join-btn {
        width: 100%;
        background: #444;
        color: white;
        border: none;
        padding: 12px;
        border-radius: 8px;
        cursor: pointer;
    }

    .profile-dropdown {
        position: fixed;
        top: 75px;
        right: 20px;
        background: #1a1a1a;
        border: 1px solid #333;
        border-radius: 12px;
        z-index: 200;
        width: 220px;
        padding: 10px;
        color: white;
    }

    .profile-user-info {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px;
        font-weight: bold;
    }

    .dropdown-divider {
        height: 1px;
        background: #333;
        margin: 5px 0;
    }

    .drop-item {
        padding: 10px;
        color: #ccc;
        cursor: pointer;
        border-radius: 6px;
    }

        .drop-item:hover {
            background: #222;
            color: white;
        }

        .drop-item.logout {
            color: #ff4d4d;
        }
</style>

@code {
    private bool showMenu = false;
    private bool showSearch = false;
    private bool showJoin = false;
    private bool showProfile = false;

    private void ToggleMenu() => showMenu = !showMenu;
    private void ToggleSearch() => showSearch = !showSearch;
    private void ToggleJoin() => showJoin = !showJoin;
    private void ToggleProfile() => showProfile = !showProfile;
}