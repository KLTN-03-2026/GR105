@page "/system-logs"
@inject NavigationManager Navigation
@rendermode InteractiveServer

<div class="admin-wrapper">
    @* --- SECTION 1: TOP NAVIGATION BAR --- *@
    <header class="top-navbar">
        <div class="nav-left">
            <button class="menu-toggle" @onclick="ToggleMenu">☰</button>
            <div class="app-logo"></div>
            <span class="nav-title">System Logs</span>
        </div>
        <div class="nav-center">
            <div class="search-box" @onclick="ToggleSearch">
                <span class="search-icon">🔍</span>
                <input type="text" placeholder="Search anything..." readonly />
            </div>
        </div>
        <div class="nav-right">
            <button class="btn-join" @onclick="ToggleJoin">+ Join</button>
            <button class="icon-btn" @onclick='() => Navigation.NavigateTo("/noti")'>🔔</button>
            <button class="icon-btn" @onclick="ToggleProfile">👤</button>
        </div>
    </header>

    @* --- MAIN CONTENT --- *@
    <main class="main-content">
        <div class="content-header-row">
            <h1 class="page-title">System Logs</h1>

            <div class="header-filters">
                <div class="custom-select">
                    <span class="select-icon">👥</span>
                    <select>
                        <option>All user</option>
                    </select>
                    <span class="arrow">▼</span>
                </div>
                <div class="custom-select">
                    <span class="select-icon">📅</span>
                    <select>
                        <option>All time</option>
                    </select>
                    <span class="arrow">▼</span>
                </div>
            </div>
        </div>

        <section class="log-timeline">
            @if (LogGroups != null)
            {
                @foreach (var group in LogGroups)
                {
                    <div class="timeline-group">
                        <div class="timeline-sidebar">
                            <div class="dot-marker"></div>
                            <div class="vertical-line"></div>
                        </div>
                        <div class="timeline-body">
                            <h3 class="day-label">@group.DateLabel</h3>
                            <div class="log-list-container">
                                @foreach (var log in group.Logs)
                                {
                                    <div class="log-entry">
                                        <div class="log-info-top">@log.Title</div>
                                        <div class="log-info-bottom">
                                            <span class="meta-item"><i class="small-icon">👤</i> @log.Username</span>
                                            <span class="meta-item">@log.Workspace</span>
                                            <span class="meta-item">@log.TimeAgo</span>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }
            }
            <div class="timeline-group">
                <div class="timeline-sidebar">
                    <div class="dot-marker"></div>
                </div>
                <div class="timeline-body">
                    <h3 class="day-label">Day X</h3>
                </div>
            </div>
        </section>
    </main>

    @if (showMenu)
    {
        <div class="drawer-menu">
            <div class="drawer-header">
                <i class="user-large-icon">👤</i>
                <button class="close-drawer" @onclick="ToggleMenu">✕</button>
            </div>
            <nav class="drawer-nav">
                <div class="drawer-nav-item" @onclick='() => Navigation.NavigateTo("/")'>⌂ Dashboard</div>
                <div class="drawer-nav-item">✉ Feedback</div>
                <div class="drawer-nav-item">📞 Contact Us</div>
                <div class="nav-divider"></div>
                <div class="nav-label">Top workspaces</div>
                <div class="nav-search-wrap">
                    <input type="text" placeholder="Search workspace..." />
                </div>
                <div class="drawer-nav-item small">👤 Project Alpha</div>
                <div class="drawer-nav-item small">👤 Team Beta</div>
            </nav>
        </div>
        <div class="overlay" @onclick="ToggleMenu"></div>
    }

    @if (showSearch)
    {
        <div class="search-modal">
            <div class="search-modal-bar">
                <span>⌕</span>
                <input type="text" placeholder="Search anything..." autofocus />
                <button @onclick="ToggleSearch">✕</button>
            </div>
        </div>
        <div class="overlay" @onclick="ToggleSearch"></div>
    }

    @if (showJoin)
    {
        <div class="join-dropdown">
            <div class="dropdown-header">
                <span style="font-weight: bold;">Join new workspace</span>
                <button @onclick="ToggleJoin" style="background:none; border:none; color:white; cursor:pointer;">✕</button>
            </div>
            <div class="dropdown-body">
                <div class="input-row-dark">
                    <i>👤</i>
                    <input type="text" placeholder="Username" />
                    <button class="copy-btn">⧉</button>
                </div>
                <div class="tab-row-dark">
                    <span class="active">HTTPS</span>
                    <span>Users</span>
                    <span>Workspace ID</span>
                </div>
                <div class="input-row-dark">
                    <input type="text" placeholder="Workspace Link/ID" />
                    <button class="copy-btn">⧉</button>
                </div>
                <button class="submit-join-btn">Send request to join workspace</button>
            </div>
        </div>
        <div class="overlay transparent" @onclick="ToggleJoin"></div>
    }

    @if (showProfile)
    {
        <div class="profile-dropdown">
            <div class="profile-user-info">
                <i>👤</i>
                <span>Username</span>
            </div>
            <div class="dropdown-divider"></div>
            <div class="drop-item" @onclick='() => Navigation.NavigateTo("/profile-detail")'>👤 Profile</div>
            <div class="drop-item">📁 Workspaces</div>
            <div class="drop-item">✉ Feedback</div>
            <div class="drop-item">⚙ Settings</div>
            <div class="drop-item logout">↪ Sign out</div>
        </div>
        <div class="overlay transparent" @onclick="ToggleProfile"></div>
    }
</div>

<style>
    /* Reset & Base */
    .admin-wrapper {
        background: #fff;
        min-height: 100vh;
        font-family: 'Segoe UI', sans-serif;
    }

    /* Top Navbar */
    .top-navbar {
        height: 65px;
        background: #1a1a1a;
        color: white;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 20px;
        z-index: 100;
        position: relative;
    }

    .nav-left {
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .menu-toggle {
        background: none;
        border: none;
        color: white;
        font-size: 22px;
        cursor: pointer;
    }

    .app-logo {
        width: 32px;
        height: 32px;
        background: #444;
        border-radius: 6px;
    }

    .search-box {
        background: #333;
        border-radius: 8px;
        padding: 8px 15px;
        display: flex;
        align-items: center;
        width: 400px;
        cursor: pointer;
    }

        .search-box input {
            background: transparent;
            border: none;
            color: white;
            width: 100%;
            outline: none;
            margin-left: 10px;
        }

    .nav-right {
        display: flex;
        gap: 15px;
        align-items: center;
    }

    .icon-btn {
        background: none;
        border: none;
        color: white;
        font-size: 20px;
        cursor: pointer;
    }

    .btn-join {
        background: transparent;
        border: 1px solid #555;
        color: white;
        padding: 5px 15px;
        border-radius: 6px;
        cursor: pointer;
    }

    /* Content Header */
    .main-content {
        padding: 30px 60px;
    }

    .content-header-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 2px solid #000;
        padding-bottom: 15px;
        margin-bottom: 40px;
    }

    .page-title {
        font-size: 2.2rem;
        font-weight: bold;
        margin: 0;
    }

    .header-filters {
        display: flex;
        gap: 15px;
    }

    .custom-select {
        display: flex;
        align-items: center;
        border: 1.5px solid #000;
        border-radius: 12px;
        padding: 5px 15px;
        gap: 10px;
        background: white;
        min-width: 160px;
    }

        .custom-select select {
            border: none;
            outline: none;
            background: transparent;
            font-size: 1rem;
            flex: 1;
            appearance: none;
        }

        .custom-select .arrow {
            font-size: 0.7rem;
        }

    /* Timeline Styling */
    .log-timeline {
        display: flex;
        flex-direction: column;
    }

    .timeline-group {
        display: flex;
        gap: 25px;
    }

    .timeline-sidebar {
        display: flex;
        flex-direction: column;
        align-items: center;
        width: 20px;
    }

    .dot-marker {
        width: 12px;
        height: 12px;
        background: #000;
        border-radius: 50%;
        margin-top: 8px;
    }

    .vertical-line {
        width: 2px;
        background: #000;
        flex-grow: 1;
        min-height: 50px;
    }

    .timeline-body {
        flex: 1;
        padding-bottom: 30px;
    }

    .day-label {
        font-size: 1.2rem;
        font-weight: bold;
        margin: 0 0 15px 0;
    }

    .log-list-container {
        border: 1.5px solid #000;
        border-radius: 12px;
        overflow: hidden;
        max-width: 900px;
    }

    .log-entry {
        padding: 15px 25px;
        border-bottom: 1.5px solid #000;
        background: #fff;
    }

        .log-entry:last-child {
            border-bottom: none;
        }

    .log-info-top {
        font-weight: 500;
        font-size: 1.05rem;
        margin-bottom: 5px;
    }

    .log-info-bottom {
        display: flex;
        gap: 30px;
        color: #666;
        font-size: 0.85rem;
    }

    .meta-item {
        display: flex;
        align-items: center;
        gap: 5px;
    }

    .small-icon {
        font-style: normal;
    }

    .overlay {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.5);
        z-index: 150;
    }

        .overlay.transparent {
            background: transparent;
        }

    .drawer-menu {
        position: fixed;
        top: 0;
        left: 0;
        width: 280px;
        height: 100%;
        background: #000;
        color: white;
        z-index: 200;
        padding: 20px;
    }

    .drawer-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
    }

    .user-large-icon {
        font-size: 40px;
    }

    .close-drawer {
        background: transparent;
        border: none;
        color: white;
        font-size: 20px;
        cursor: pointer;
    }

    .drawer-nav-item {
        padding: 12px;
        color: #ccc;
        cursor: pointer;
        border-radius: 8px;
        font-size: 16px;
    }

        .drawer-nav-item:hover {
            background: #222;
            color: white;
        }

    .nav-divider {
        height: 1px;
        background: #333;
        margin: 15px 0;
    }

    .nav-label {
        color: #666;
        font-size: 12px;
        text-transform: uppercase;
        margin-bottom: 10px;
    }

    .nav-search-wrap input {
        width: 100%;
        background: #222;
        border: 1px solid #444;
        padding: 8px;
        color: white;
        border-radius: 4px;
        margin-bottom: 10px;
    }

    .search-modal {
        position: fixed;
        top: 20px;
        left: 50%;
        transform: translateX(-50%);
        width: 90%;
        max-width: 600px;
        z-index: 200;
    }

    .search-modal-bar {
        background: #1a1a1a;
        display: flex;
        padding: 15px;
        border-radius: 12px;
        border: 1px solid #333;
        align-items: center;
        color: white;
    }

        .search-modal-bar input {
            flex: 1;
            background: transparent;
            border: none;
            color: white;
            outline: none;
            margin: 0 15px;
            font-size: 18px;
        }

    .join-dropdown {
        position: fixed;
        top: 75px;
        right: 80px;
        background: #222;
        padding: 20px;
        border-radius: 15px;
        border: 1px solid #444;
        z-index: 200;
        width: 400px;
        color: white;
    }

    .input-row-dark {
        display: flex;
        gap: 10px;
        margin: 15px 0;
        background: #000;
        padding: 10px;
        border-radius: 8px;
        align-items: center;
    }

        .input-row-dark input {
            flex: 1;
            background: transparent;
            border: none;
            color: white;
            outline: none;
        }

    .tab-row-dark {
        display: flex;
        gap: 20px;
        border-bottom: 1px solid #444;
        margin-bottom: 15px;
    }

        .tab-row-dark span {
            cursor: pointer;
            color: #888;
            padding-bottom: 5px;
            font-size: 14px;
        }

            .tab-row-dark span.active {
                color: white;
                border-bottom: 2px solid white;
            }

    .submit-join-btn {
        width: 100%;
        background: #444;
        color: white;
        border: none;
        padding: 12px;
        border-radius: 8px;
        cursor: pointer;
    }

    .profile-dropdown {
        position: fixed;
        top: 75px;
        right: 20px;
        background: #1a1a1a;
        border: 1px solid #333;
        border-radius: 12px;
        z-index: 200;
        width: 220px;
        padding: 10px;
        color: white;
    }

    .profile-user-info {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px;
        font-weight: bold;
    }

    .dropdown-divider {
        height: 1px;
        background: #333;
        margin: 5px 0;
    }

    .drop-item {
        padding: 10px;
        color: #ccc;
        cursor: pointer;
        border-radius: 6px;
    }

        .drop-item:hover {
            background: #222;
            color: white;
        }

        .drop-item.logout {
            color: #ff4d4d;
        }
</style>

@code {
    private bool showMenu = false;
    private bool showSearch = false;
    private bool showJoin = false;
    private bool showProfile = false;

    private void ToggleMenu() => showMenu = !showMenu;
    private void ToggleSearch() => showSearch = !showSearch;
    private void ToggleJoin() => showJoin = !showJoin;
    private void ToggleProfile() => showProfile = !showProfile;

    // Mock Data Updated for System Logs
    private List<LogGroup> LogGroups = new()
    {
        new LogGroup {
            DateLabel = "Day X",
            Logs = new List<LogItem> {
                new LogItem { Title = "Log title", Username = "username", Workspace = "workspace", TimeAgo = "X days ago" },
                new LogItem { Title = "Log title", Username = "username", Workspace = "workspace", TimeAgo = "X days ago" }
            }
        }
    };

    public class LogGroup
    {
        public string DateLabel { get; set; } = "";
        public List<LogItem> Logs { get; set; } = new();
    }

    public class LogItem
    {
        public string Title { get; set; } = "";
        public string Username { get; set; } = "";
        public string Workspace { get; set; } = ""; 
        public string TimeAgo { get; set; } = "";
    }
}