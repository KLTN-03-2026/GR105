@page "/adminpanel"
@inject NavigationManager Navigation
@rendermode InteractiveServer

<div class="admin-layout">
    <aside class="sidebar">
        <div class="sidebar-header">
            <span class="user-icon">👤</span>
            <span class="admin-text">Admin</span>
        </div>

        <nav class="sidebar-nav">
            <div class="nav-item active" @onclick='() => Navigation.NavigateTo("/admin")'>
                <span class="icon">⊞</span> Overview
            </div>
            <div class="nav-item" @onclick='() => Navigation.NavigateTo("/accounts")'>
                <span class="icon">👤</span> Account Manage
            </div>
            <div class="nav-item">
                <span class="icon">✉</span> Feedback Manage
            </div>
            <div class="nav-item">
                <span class="icon">🔒</span> Password Reissue
            </div>
            <div class="nav-item">
                <span class="icon">📁</span> Workspace Manage
            </div>
            <div class="nav-item">
                <span class="icon">⚙</span> System Log
            </div>
        </nav>
    </aside>

    <main class="main-content">
        <header class="top-bar">
            <div class="top-left">
                <button class="menu-toggle" @onclick="ToggleMenu">☰</button>
                <div class="app-logo"></div>
                <span class="nav-title">Username</span>
            </div>
            <div class="nav-center">
                <div class="search-box" @onclick="ToggleSearch">
                    <span class="search-icon">🔍</span>
                    <input type="text" placeholder="Search anything..." readonly />
                </div>
            </div>
            <div class="nav-right">
                <button class="btn-join" @onclick="ToggleJoin">+ Join</button>
                <button class="icon-btn" @onclick='() => Navigation.NavigateTo("/noti")'>🔔</button>
                <button class="icon-btn" @onclick="ToggleProfile">👤</button>
            </div>
        </header>

        <section class="page-body">
            <h2 class="overview-title">Overview</h2>
            <hr class="divider" />

            <div class="placeholder-content">
            </div>
        </section>
    </main>
</div>
@if (showMenu)
{
    <div class="drawer-menu">
        <div class="drawer-header">
            <i class="user-large-icon">👤</i>
            <button class="close-drawer" @onclick="ToggleMenu">✕</button>
        </div>
        <nav class="drawer-nav">
            <div class="drawer-nav-item" @onclick='() => Navigation.NavigateTo("/")'>⌂ Dashboard</div>
            <div class="drawer-nav-item">✉ Feedback</div>
            <div class="drawer-nav-item">📞 Contact Us</div>
            <div class="nav-divider"></div>
            <div class="nav-label">Top workspaces</div>
            <div class="nav-search-wrap">
                <input type="text" placeholder="Search workspace..." />
            </div>
            <div class="drawer-nav-item small">👤 Project Alpha</div>
            <div class="drawer-nav-item small">👤 Team Beta</div>
        </nav>
    </div>
    <div class="overlay" @onclick="ToggleMenu"></div>
}

@if (showSearch)
{
    <div class="search-modal">
        <div class="search-modal-bar">
            <span>⌕</span>
            <input type="text" placeholder="Search anything..." autofocus />
            <button @onclick="ToggleSearch">✕</button>
        </div>
    </div>
    <div class="overlay" @onclick="ToggleSearch"></div>
}

@if (showJoin)
{
    <div class="join-dropdown">
        <div class="dropdown-header">
            <span style="font-weight: bold;">Join new workspace</span>
            <button @onclick="ToggleJoin" style="background:none; border:none; color:white; cursor:pointer;">✕</button>
        </div>
        <div class="dropdown-body">
            <div class="input-row-dark">
                <i>👤</i>
                <input type="text" placeholder="Username" />
                <button class="copy-btn">⧉</button>
            </div>
            <div class="tab-row-dark">
                <span class="active">HTTPS</span>
                <span>Users</span>
                <span>Workspace ID</span>
            </div>
            <div class="input-row-dark">
                <input type="text" placeholder="Workspace Link/ID" />
                <button class="copy-btn">⧉</button>
            </div>
            <button class="submit-join-btn">Send request to join workspace</button>
        </div>
    </div>
    <div class="overlay transparent" @onclick="ToggleJoin"></div>
}

@if (showProfile)
{
    <div class="profile-dropdown">
        <div class="profile-user-info">
            <i>👤</i>
            <span>Username</span>
        </div>
        <div class="dropdown-divider"></div>
        <div class="drop-item" @onclick='() => Navigation.NavigateTo("/profile-detail")'>👤 Profile</div>
        <div class="drop-item">📁 Workspaces</div>
        <div class="drop-item">✉ Feedback</div>
        <div class="drop-item">⚙ Settings</div>
        <div class="drop-item logout">↪ Sign out</div>
    </div>
    <div class="overlay transparent" @onclick="ToggleProfile"></div>
}

<style>
    :root {
        --sidebar-bg: #000000;
        --sidebar-text: #ffffff;
        --topbar-bg: #1a1a1a;
        --active-item-bg: #ffffff;
        --active-item-text: #000000;
    }

    .admin-layout {
        display: flex;
        height: 100vh;
        width: 100%;
        overflow: hidden;
    }

    /* --- SIDEBAR --- */
    .sidebar {
        width: 260px;
        background: var(--sidebar-bg);
        color: var(--sidebar-text);
        display: flex;
        flex-direction: column;
        padding-top: 20px;
    }

    .sidebar-header {
        display: flex;
        align-items: center;
        padding: 0 25px 30px;
        gap: 15px;
    }

    .user-icon {
        font-size: 24px;
    }

    .admin-text {
        font-size: 22px;
        font-weight: bold;
    }

    .sidebar-nav {
        display: flex;
        flex-direction: column;
        gap: 5px;
        padding: 0 10px;
    }

    .nav-item {
        padding: 12px 15px;
        border-radius: 8px;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 12px;
        transition: 0.2s;
        font-size: 15px;
    }

        .nav-item.active {
            background: var(--active-item-bg);
            color: var(--active-item-text);
            font-weight: bold;
        }

        .nav-item:hover:not(.active) {
            background: #222;
        }

    /* --- MAIN CONTENT --- */
    .main-content {
        flex: 1;
        display: flex;
        flex-direction: column;
        background: #fff;
    }

    .top-bar {
        height: 60px;
        background: var(--topbar-bg);
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 20px;
        color: white;
    }

    .top-left {
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .logo-box {
        width: 30px;
        height: 30px;
        background: #ccc;
        border-radius: 4px;
    }

    .menu-btn {
        background: none;
        border: none;
        color: white;
        font-size: 20px;
        cursor: pointer;
    }

    .search-container {
        background: #2a2a2a;
        padding: 6px 15px;
        border-radius: 6px;
        display: flex;
        align-items: center;
        width: 350px;
    }

        .search-container input {
            background: transparent;
            border: none;
            color: white;
            margin-left: 10px;
            width: 100%;
            outline: none;
        }

    .top-right {
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .btn-join {
        border: 1px solid #555;
        background: transparent;
        color: white;
        padding: 4px 15px;
        border-radius: 4px;
        cursor: pointer;
    }

    .icon-btn {
        background: none;
        border: none;
        color: white;
        font-size: 18px;
        cursor: pointer;
    }

    /* --- PAGE CONTENT --- */
    .page-body {
        padding: 30px 40px;
    }

    .overview-title {
        font-size: 28px;
        font-weight: bold;
        margin-bottom: 5px;
    }

    .divider {
        border: none;
        border-top: 2px solid #000;
        margin-bottom: 20px;
    }

    .overlay {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.5);
        z-index: 150;
    }

        .overlay.transparent {
            background: transparent;
        }

    .drawer-menu {
        position: fixed;
        top: 0;
        left: 0;
        width: 280px;
        height: 100%;
        background: #000;
        color: white;
        z-index: 200;
        padding: 20px;
    }

    .drawer-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
    }

    .user-large-icon {
        font-size: 40px;
    }

    .close-drawer {
        background: transparent;
        border: none;
        color: white;
        font-size: 20px;
        cursor: pointer;
    }

    .drawer-nav-item {
        padding: 12px;
        color: #ccc;
        cursor: pointer;
        border-radius: 8px;
        font-size: 16px;
    }

        .drawer-nav-item:hover {
            background: #222;
            color: white;
        }

    .nav-divider {
        height: 1px;
        background: #333;
        margin: 15px 0;
    }

    .nav-label {
        color: #666;
        font-size: 12px;
        text-transform: uppercase;
        margin-bottom: 10px;
    }

    .nav-search-wrap input {
        width: 100%;
        background: #222;
        border: 1px solid #444;
        padding: 8px;
        color: white;
        border-radius: 4px;
        margin-bottom: 10px;
    }

    .search-modal {
        position: fixed;
        top: 20px;
        left: 50%;
        transform: translateX(-50%);
        width: 90%;
        max-width: 600px;
        z-index: 200;
    }

    .search-modal-bar {
        background: #1a1a1a;
        display: flex;
        padding: 15px;
        border-radius: 12px;
        border: 1px solid #333;
        align-items: center;
        color: white;
    }

        .search-modal-bar input {
            flex: 1;
            background: transparent;
            border: none;
            color: white;
            outline: none;
            margin: 0 15px;
            font-size: 18px;
        }

    .join-dropdown {
        position: fixed;
        top: 75px;
        right: 80px;
        background: #222;
        padding: 20px;
        border-radius: 15px;
        border: 1px solid #444;
        z-index: 200;
        width: 400px;
        color: white;
    }

    .input-row-dark {
        display: flex;
        gap: 10px;
        margin: 15px 0;
        background: #000;
        padding: 10px;
        border-radius: 8px;
        align-items: center;
    }

        .input-row-dark input {
            flex: 1;
            background: transparent;
            border: none;
            color: white;
            outline: none;
        }

    .tab-row-dark {
        display: flex;
        gap: 20px;
        border-bottom: 1px solid #444;
        margin-bottom: 15px;
    }

        .tab-row-dark span {
            cursor: pointer;
            color: #888;
            padding-bottom: 5px;
            font-size: 14px;
        }

            .tab-row-dark span.active {
                color: white;
                border-bottom: 2px solid white;
            }

    .submit-join-btn {
        width: 100%;
        background: #444;
        color: white;
        border: none;
        padding: 12px;
        border-radius: 8px;
        cursor: pointer;
    }

    .profile-dropdown {
        position: fixed;
        top: 75px;
        right: 20px;
        background: #1a1a1a;
        border: 1px solid #333;
        border-radius: 12px;
        z-index: 200;
        width: 220px;
        padding: 10px;
        color: white;
    }

    .profile-user-info {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px;
        font-weight: bold;
    }

    .dropdown-divider {
        height: 1px;
        background: #333;
        margin: 5px 0;
    }

    .drop-item {
        padding: 10px;
        color: #ccc;
        cursor: pointer;
        border-radius: 6px;
    }

        .drop-item:hover {
            background: #222;
            color: white;
        }

        .drop-item.logout {
            color: #ff4d4d;
        }

    .top-navbar {
        height: 65px;
        background: #1a1a1a;
        color: white;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 20px;
        z-index: 100;
        position: relative;
    }

    .nav-left {
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .menu-toggle {
        background: none;
        border: none;
        color: white;
        font-size: 22px;
        cursor: pointer;
    }

    .app-logo {
        width: 32px;
        height: 32px;
        background: #444;
        border-radius: 6px;
    }

    .search-box {
        background: #333;
        border-radius: 8px;
        padding: 8px 15px;
        display: flex;
        align-items: center;
        width: 400px;
        cursor: pointer;
    }

        .search-box input {
            background: transparent;
            border: none;
            color: white;
            width: 100%;
            outline: none;
            margin-left: 10px;
        }

    .nav-right {
        display: flex;
        gap: 15px;
        align-items: center;
    }

    .icon-btn {
        background: none;
        border: none;
        color: white;
        font-size: 20px;
        cursor: pointer;
    }

    .btn-join {
        background: transparent;
        border: 1px solid #555;
        color: white;
        padding: 5px 15px;
        border-radius: 6px;
        cursor: pointer;
    }
</style>
@code {
    private bool showMenu = false;
    private bool showSearch = false;
    private bool showJoin = false;
    private bool showProfile = false;

    private void ToggleMenu() => showMenu = !showMenu;
    private void ToggleSearch() => showSearch = !showSearch;
    private void ToggleJoin() => showJoin = !showJoin;
    private void ToggleProfile() => showProfile = !showProfile;
}