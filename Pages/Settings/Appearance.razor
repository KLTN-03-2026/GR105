@page "/appearance"
@inject NavigationManager Navigation
@rendermode InteractiveServer

<div class="app-wrapper">

    <!-- TOP NAVBAR -->
    <header class="top-navbar">
        <div class="nav-left">
            <button class="menu-toggle" @onclick="ToggleMenu">☰</button>
            <div class="app-logo"></div>
            <span class="nav-title">Dashboard</span>
        </div>

        <div class="nav-center">
            <div class="search-box" @onclick="ToggleSearch">
                <span class="search-icon">⌕</span>
                <input type="text" placeholder="Search anything..." readonly />
            </div>
        </div>

        <div class="nav-right">
            <button class="btn-join" @onclick="ToggleJoin">+ Join</button>
            <button class="icon-btn" @onclick='() => Navigation.NavigateTo("/notifications")'>🔔</button>
            <button class="icon-btn" @onclick="ToggleProfile">👤</button>
        </div>
    </header>

    <!-- MAIN LAYOUT -->
    <div class="appearance-layout">

        <!-- SIDEBAR -->
        <aside class="sidebar">
            <div class="profile-header">
                <span class="avatar-icon">👤</span>
                <span class="profile-name">Username</span>
            </div>

            <nav class="nav-menu">
                <a href="/profile" class="nav-link">
                    <span class="icon">👤</span> Profile
                </a>

                <a href="/account" class="nav-link">
                    <span class="icon">⚙️</span> Account
                </a>

                <a href="/appearance" class="nav-link active">
                    <span class="icon">🎨</span> Appearance
                </a>

                <a href="/notifications" class="nav-link">
                    <span class="icon">🔔</span> Notification
                </a>

                <a href="/workspace" class="nav-link">
                    <span class="icon">📁</span> Workspace
                </a>

                <a href="/email" class="nav-link">
                    <span class="icon">✉️</span> Email
                </a>
            </nav>
        </aside>

        <!-- MAIN CONTENT -->
        <main class="main-content">

            <div class="page-header">
                <h1 class="page-title">Appearance</h1>
                <button class="btn-personal-profile">Personal profile</button>
            </div>

            <div class="appearance-body">

                <div class="theme-grid">

                    <!-- DARK THEME -->
                    <div class="theme-card dark-mode">
                        <div class="theme-info">
                            <div class="theme-label">
                                <span class="theme-icon">🌙</span>
                                <span class="theme-name">Dark Theme</span>
                            </div>

                            <button class="btn-theme-action">
                                Change
                            </button>
                        </div>

                        <div class="mockup-container">
                            <div class="mockup-header"></div>

                            <div class="mockup-main">
                                <div class="mockup-sidebar"></div>

                                <div class="mockup-content">
                                    <div class="mockup-bar short"></div>
                                    <div class="mockup-bar long"></div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- LIGHT THEME -->
                    <div class="theme-card light-mode active">
                        <div class="theme-info">
                            <div class="theme-label">
                                <span class="theme-icon">☀️</span>
                                <span class="theme-name">Light Theme</span>
                            </div>

                            <button class="btn-theme-action activated">
                                Activated
                            </button>
                        </div>

                        <div class="mockup-container">
                            <div class="mockup-header"></div>

                            <div class="mockup-main">
                                <div class="mockup-sidebar"></div>

                                <div class="mockup-content">
                                    <div class="mockup-bar short"></div>
                                    <div class="mockup-bar long"></div>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>

            </div>

        </main>
    </div>
</div>

<!-- MENU DRAWER -->
@if (showMenu)
{
    <div class="drawer-menu">
        <div class="drawer-header">
            <i class="user-large-icon">👤</i>

            <button class="close-drawer" @onclick="ToggleMenu">
                ✕
            </button>
        </div>

        <nav class="drawer-nav">
            <div class="drawer-nav-item"
                 @onclick='() => Navigation.NavigateTo("/")'>
                ⌂ Dashboard
            </div>

            <div class="drawer-nav-item">✉ Feedback</div>
            <div class="drawer-nav-item">📞 Contact Us</div>

            <div class="nav-divider"></div>

            <div class="nav-label">Top workspaces</div>

            <div class="nav-search-wrap">
                <input type="text"
                       placeholder="Search workspace..." />
            </div>

            <div class="drawer-nav-item small">
                👤 Project Alpha
            </div>

            <div class="drawer-nav-item small">
                👤 Team Beta
            </div>
        </nav>
    </div>

    <div class="overlay" @onclick="ToggleMenu"></div>
}

<!-- SEARCH MODAL -->
@if (showSearch)
{
    <div class="search-modal">
        <div class="search-modal-bar">
            <span>⌕</span>

            <input type="text"
                   placeholder="Search anything..."
                   autofocus />

            <button @onclick="ToggleSearch">✕</button>
        </div>
    </div>

    <div class="overlay" @onclick="ToggleSearch"></div>
}

<!-- JOIN MODAL -->
@if (showJoin)
{
    <div class="join-dropdown">

        <div class="dropdown-header">
            <span style="font-weight:bold;">
                Join new workspace
            </span>

            <button @onclick="ToggleJoin"
                    style="background:none;border:none;color:white;cursor:pointer;">
                ✕
            </button>
        </div>

        <div class="dropdown-body">

            <div class="input-row-dark">
                <i>👤</i>

                <input type="text"
                       placeholder="Username" />

                <button class="copy-btn">⧉</button>
            </div>

            <div class="tab-row-dark">
                <span class="active">HTTPS</span>
                <span>Users</span>
                <span>Workspace ID</span>
            </div>

            <div class="input-row-dark">
                <input type="text"
                       placeholder="Workspace Link/ID" />

                <button class="copy-btn">⧉</button>
            </div>

            <button class="submit-join-btn">
                Send request to join workspace
            </button>
        </div>
    </div>

    <div class="overlay transparent"
         @onclick="ToggleJoin"></div>
}

<!-- PROFILE DROPDOWN -->
@if (showProfile)
{
    <div class="profile-dropdown">

        <div class="profile-user-info">
            <i>👤</i>
            <span>Username</span>
        </div>

        <div class="dropdown-divider"></div>

        <div class="drop-item"
             @onclick='() => Navigation.NavigateTo("/profile-detail")'>
            👤 Profile
        </div>

        <div class="drop-item">📁 Workspaces</div>
        <div class="drop-item">✉ Feedback</div>
        <div class="drop-item">⚙ Settings</div>

        <div class="drop-item logout">
            ↪ Sign out
        </div>
    </div>

    <div class="overlay transparent"
         @onclick="ToggleProfile"></div>
}

@code {
    private bool showMenu = false;
    private bool showSearch = false;
    private bool showJoin = false;
    private bool showProfile = false;

    private void ToggleMenu() => showMenu = !showMenu;
    private void ToggleSearch() => showSearch = !showSearch;
    private void ToggleJoin() => showJoin = !showJoin;
    private void ToggleProfile() => showProfile = !showProfile;
}

<style>
    :root {
        --dark-bg: #1a1a1a;
        --header-h: 65px;
    }

    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    body {
        overflow-x: hidden;
    }

    .app-wrapper {
        min-height: 100vh;
        background: #f5f5f5;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    /* TOPBAR */

    .top-navbar {
        height: var(--header-h);
        background: var(--dark-bg);
        color: white;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 20px;
        position: sticky;
        top: 0;
        z-index: 100;
    }

    .nav-left,
    .nav-right {
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .menu-toggle,
    .icon-btn {
        background: none;
        border: none;
        color: white;
        font-size: 20px;
        cursor: pointer;
    }

    .app-logo {
        width: 32px;
        height: 32px;
        background: #444;
        border-radius: 6px;
    }

    .nav-title {
        font-size: 1.1rem;
        font-weight: 600;
    }

    .search-box {
        width: 380px;
        background: #2c2c2c;
        padding: 10px 15px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        cursor: pointer;
    }

        .search-box input {
            width: 100%;
            background: transparent;
            border: none;
            outline: none;
            color: white;
            margin-left: 10px;
        }

    .btn-join {
        background: transparent;
        border: 1px solid #666;
        color: white;
        padding: 8px 18px;
        border-radius: 8px;
        cursor: pointer;
    }

    /* MAIN LAYOUT */

    .appearance-layout {
        display: flex;
        min-height: calc(100vh - var(--header-h));
    }

    /* SIDEBAR */

    .sidebar {
        width: 280px;
        background: #000;
        color: white;
        padding-top: 20px;
        flex-shrink: 0;
    }

    .profile-header {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 20px 25px;
        border-bottom: 1px solid #333;
        margin-bottom: 10px;
    }

    .profile-name {
        font-size: 1.05rem;
        font-weight: 700;
    }

    .nav-link {
        display: flex;
        align-items: center;
        gap: 15px;
        padding: 14px 25px;
        color: #888;
        text-decoration: none;
        transition: 0.2s;
    }

        .nav-link:hover {
            background: #111;
            color: white;
        }

        .nav-link.active {
            background: white;
            color: black;
            margin-left: 15px;
            border-radius: 12px 0 0 12px;
            font-weight: 700;
        }

    /* MAIN CONTENT */

    .main-content {
        flex: 1;
        background: white;
        padding-top: 40px;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0 60px 20px;
        border-bottom: 1px solid #ddd;
        margin-bottom: 50px;
    }

    .page-title {
        font-size: 2.3rem;
        font-weight: 800;
    }

    .btn-personal-profile {
        background: #111;
        color: white;
        border: none;
        padding: 12px 20px;
        border-radius: 8px;
        cursor: pointer;
    }

    /* THEME */

    .appearance-body {
        padding: 0 60px 60px;
    }

    .theme-grid {
        display: flex;
        gap: 35px;
        flex-wrap: wrap;
    }

    .theme-card {
        flex: 1;
        min-width: 320px;
        max-width: 470px;
        border-radius: 24px;
        padding: 25px;
        transition: 0.25s;
        border: 2px solid #eee;
    }

        .theme-card:hover {
            transform: translateY(-5px);
        }

        .theme-card.active {
            border-color: black;
        }

    .dark-mode {
        background: #222;
        color: white;
    }

    .light-mode {
        background: #fafafa;
        color: black;
    }

    .theme-info {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 25px;
    }

    .theme-label {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .theme-name {
        font-size: 1.15rem;
        font-weight: 700;
    }

    .btn-theme-action {
        border: none;
        border-radius: 20px;
        padding: 8px 18px;
        font-weight: 700;
        cursor: pointer;
    }

    .dark-mode .btn-theme-action {
        background: white;
        color: black;
    }

    .light-mode .btn-theme-action {
        background: black;
        color: white;
    }

    .btn-theme-action.activated {
        opacity: 0.6;
        cursor: default;
    }

    /* MOCKUP */

    .mockup-container {
        aspect-ratio: 16/10;
        border-radius: 14px;
        overflow: hidden;
        display: flex;
        flex-direction: column;
    }

    .dark-mode .mockup-container {
        background: #333;
    }

    .light-mode .mockup-container {
        background: white;
        border: 1px solid #eee;
    }

    .mockup-header {
        height: 15%;
        margin: 10px;
        border-radius: 6px;
    }

    .dark-mode .mockup-header,
    .dark-mode .mockup-sidebar,
    .dark-mode .mockup-bar {
        background: #444;
    }

    .light-mode .mockup-header,
    .light-mode .mockup-sidebar,
    .light-mode .mockup-bar {
        background: #eee;
    }

    .mockup-main {
        flex: 1;
        display: flex;
        gap: 10px;
        padding: 0 10px 10px;
    }

    .mockup-sidebar {
        width: 25%;
        border-radius: 6px;
    }

    .mockup-content {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .mockup-bar {
        border-radius: 6px;
    }

        .mockup-bar.short {
            width: 40%;
            height: 20%;
        }

        .mockup-bar.long {
            width: 100%;
            height: 60%;
        }

    /* OVERLAY */

    .overlay {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.5);
        z-index: 150;
    }

        .overlay.transparent {
            background: transparent;
        }

    /* DRAWER */

    .drawer-menu {
        position: fixed;
        top: 0;
        left: 0;
        width: 280px;
        height: 100%;
        background: black;
        color: white;
        z-index: 200;
        padding: 20px;
    }

    .drawer-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
    }

    .close-drawer {
        background: none;
        border: none;
        color: white;
        cursor: pointer;
        font-size: 20px;
    }

    .drawer-nav-item {
        padding: 12px;
        border-radius: 8px;
        color: #ccc;
        cursor: pointer;
    }

        .drawer-nav-item:hover {
            background: #222;
            color: white;
        }

    .nav-divider {
        height: 1px;
        background: #333;
        margin: 15px 0;
    }

    .nav-label {
        color: #666;
        font-size: 12px;
        text-transform: uppercase;
        margin-bottom: 10px;
    }

    .nav-search-wrap input {
        width: 100%;
        padding: 8px;
        border-radius: 6px;
        border: 1px solid #444;
        background: #222;
        color: white;
        margin-bottom: 10px;
    }

    /* SEARCH MODAL */

    .search-modal {
        position: fixed;
        top: 20px;
        left: 50%;
        transform: translateX(-50%);
        width: 90%;
        max-width: 600px;
        z-index: 300;
    }

    .search-modal-bar {
        background: #1a1a1a;
        border: 1px solid #333;
        border-radius: 12px;
        padding: 15px;
        display: flex;
        align-items: center;
        color: white;
    }

        .search-modal-bar input {
            flex: 1;
            background: transparent;
            border: none;
            outline: none;
            color: white;
            margin: 0 15px;
        }

    /* JOIN */

    .join-dropdown {
        position: fixed;
        top: 75px;
        right: 80px;
        width: 400px;
        background: #222;
        border: 1px solid #444;
        border-radius: 15px;
        padding: 20px;
        z-index: 250;
        color: white;
    }

    .input-row-dark {
        display: flex;
        align-items: center;
        gap: 10px;
        background: black;
        border-radius: 8px;
        padding: 10px;
        margin: 15px 0;
    }

        .input-row-dark input {
            flex: 1;
            background: transparent;
            border: none;
            outline: none;
            color: white;
        }

    .tab-row-dark {
        display: flex;
        gap: 20px;
        border-bottom: 1px solid #444;
        margin-bottom: 15px;
    }

        .tab-row-dark span {
            padding-bottom: 5px;
            color: #888;
            cursor: pointer;
        }

            .tab-row-dark span.active {
                color: white;
                border-bottom: 2px solid white;
            }

    .submit-join-btn {
        width: 100%;
        border: none;
        border-radius: 8px;
        background: #444;
        color: white;
        padding: 12px;
        cursor: pointer;
    }

    /* PROFILE DROPDOWN */

    .profile-dropdown {
        position: fixed;
        top: 75px;
        right: 20px;
        width: 220px;
        background: #1a1a1a;
        border: 1px solid #333;
        border-radius: 12px;
        padding: 10px;
        z-index: 250;
        color: white;
    }

    .profile-user-info {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px;
        font-weight: 700;
    }

    .dropdown-divider {
        height: 1px;
        background: #333;
        margin: 5px 0;
    }

    .drop-item {
        padding: 10px;
        border-radius: 6px;
        color: #ccc;
        cursor: pointer;
    }

        .drop-item:hover {
            background: #222;
            color: white;
        }

        .drop-item.logout {
            color: #ff4d4d;
        }
</style>